showFULifecycle    = input.bool  (true,  "Show FU Lifecycle State",          group=GRP_DIE)
enableClustering   = input.bool  (true,  "Enable Entry Cycle Clustering",    group=GRP_DIE)
clusterWindow      = input.int   (8,     "Cluster Detection Window (bars)",  group=GRP_DIE, minval=3, maxval=20)
showNarrative      = input.bool  (true,  "Show Active Narrative Label",      group=GRP_DIE)
showDIE_Dashboard  = input.bool  (true,  "Show DIE Status in Dashboard",     group=GRP_DIE)

// ─── Future Return Zone Engine (Sections 17 & 18) ───────────────────────────
showFRZ            = input.bool  (true,  "Show Future Return Zones",           group=GRP_FRZ)
showFRZ_Labels     = input.bool  (true,  "Show FRZ Labels on Chart",           group=GRP_FRZ)
showFRZ_Dashboard  = input.bool  (true,  "Show FRZ Section in Dashboard",      group=GRP_FRZ)
frz_minScore       = input.int   (26,    "Min FRZ Score to Display (0-100)",   group=GRP_FRZ, minval=0, maxval=100)
