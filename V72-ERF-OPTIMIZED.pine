// ─── SECTION 9 — ADAPTIVE ENTRY CYCLE VISIBILITY ──────────────────────────────
// Trader controls where Entry Cycle markers/labels appear. No presets, no
// profiles, no assumptions — every category below independently gates the
// existing label/box rendering for that category. "All Locations" is a master
// override that forces every category on regardless of individual settings.
ecvSupply        = input.bool(true,  "Supply",            group=GRP_CYCLEVIS, inline="ecv1")
ecvDemand        = input.bool(true,  "Demand",            group=GRP_CYCLEVIS, inline="ecv1")
ecvHighs         = input.bool(true,  "Highs",             group=GRP_CYCLEVIS, inline="ecv2")
ecvLows          = input.bool(true,  "Lows",              group=GRP_CYCLEVIS, inline="ecv2")
ecvExpansion     = input.bool(true,  "Expansion",         group=GRP_CYCLEVIS, inline="ecv3")
ecvPreConvexity  = input.bool(true,  "Pre-Convexity",     group=GRP_CYCLEVIS, inline="ecv3")
ecvConvexity     = input.bool(true,  "Convexity",         group=GRP_CYCLEVIS, inline="ecv4")
ecvAbsorption    = input.bool(true,  "Absorption",        group=GRP_CYCLEVIS, inline="ecv4")
ecvRetracement   = input.bool(true,  "Retracement",       group=GRP_CYCLEVIS, inline="ecv5")
ecvInduction     = input.bool(true,  "Induction",         group=GRP_CYCLEVIS, inline="ecv5")
ecvLiquidation   = input.bool(true,  "Liquidation",       group=GRP_CYCLEVIS, inline="ecv6")
ecvFUCandle      = input.bool(true,  "FU Candle",         group=GRP_CYCLEVIS, inline="ecv6")
ecvImbalance     = input.bool(true,  "Imbalance",         group=GRP_CYCLEVIS, inline="ecv7")
ecvFUImbalance   = input.bool(true,  "FU + Imbalance",    group=GRP_CYCLEVIS, inline="ecv7")
ecvOrigin        = input.bool(true,  "Origin",            group=GRP_CYCLEVIS, inline="ecv8")
ecvWaveCompletion= input.bool(true,  "Wave Completion",   group=GRP_CYCLEVIS, inline="ecv8")
ecvAllLocations  = input.bool(false, "All Locations (override all above)", group=GRP_CYCLEVIS)

