// ─── Energy Resolution Framework ────────────────────────────────────────────
showERF_Dashboard  = input.bool  (true,  "Show ERF Panel in Dashboard",        group=GRP_ERF)

// ─── V72 — Dashboard Mode ──────────────────────────────────────────────────
var string GRP_V72  = "V72 Decision Architecture"
dashAdvancedMode   = input.bool  (false, "Advanced Mode (Diagnostic Depth)",    group=GRP_V72)

// ─── V72 — Invalidation Engine (IE2) ───────────────────────────────────────
var string GRP_IE2  = "V72 Invalidation Engine"
invOriginBuffer    = input.float (0.25,  "Origin Stop ATR Buffer",              group=GRP_IE2, minval=0.05, maxval=1.0, step=0.05)
invZoneBuffer      = input.float (0.10,  "Zone Stop ATR Buffer",                group=GRP_IE2, minval=0.02, maxval=0.5, step=0.02)

// ─── V72 — Target Engine (TE) ──────────────────────────────────────────────
var string GRP_TE   = "V72 Target Engine"
rrMinimum          = input.float (1.5,   "Min R:R Ratio for Entry",             group=GRP_TE, minval=0.5, maxval=5.0, step=0.1)

// ─── V72 — ERF Entry Gate ──────────────────────────────────────────────────
var string GRP_ERFG = "V72 ERF Entry Gate"
erfEntryThreshold  = input.float (45.0,  "ERF Trade Readiness Threshold",       group=GRP_ERFG, minval=20.0, maxval=80.0, step=5.0)

// ─── V72 — Multi-Timeframe Consensus (MCE) ─────────────────────────────────
var string GRP_MCE  = "V72 Multi-Timeframe Consensus"
tf3                = input.timeframe("240", "Timeframe 3 (H4)",                 group=GRP_MCE)
tf4                = input.timeframe("D",   "Timeframe 4 (Daily)",              group=GRP_MCE)
mce_weightMode     = input.string("Equal", "TF Weight Mode",
     options=["Equal", "HTF-Biased"], group=GRP_MCE)

// ─── V72 — Rotation Intelligence Engine (RIE) ──────────────────────────────
var string GRP_RIE  = "V72 Rotation Intelligence"
// RIE weights hardcoded to reduce external element count (CE10116 limit=254)
float rie_w_decay      = 0.35
float rie_w_absorption = 0.30
float rie_w_convexity  = 0.20
float rie_w_liquidity  = 0.15

// ─── V72 — Trade Qualification Engine (TQE) ────────────────────────────────
var string GRP_TQE  = "V72 Trade Qualification"
// TQE weights/thresholds hardcoded to reduce external element count (CE10116)
float tqe_w_ie1a  = 0.167
float tqe_w_erf   = 0.167
float tqe_w_frz   = 0.167
float tqe_w_mce   = 0.167
float tqe_w_re    = 0.167
float tqe_w_liq   = 0.167
int tqe_gradeA_plus = 80
int tqe_gradeA      = 65
int tqe_gradeB      = 50
int tqe_gradeC      = 35

// ─── V72 — Decision Output Engine (DOE) ────────────────────────────────────
var string GRP_DOE  = "V72 Decision Output"
// DOE confidence caps hardcoded to reduce external element count (CE10116)
int doe_confCap     = 88
int doe_confCapConv = 95

// ─── V72 — FRZ Integration ─────────────────────────────────────────────────
var string GRP_FRZV72 = "V72 FRZ Integration"
frz_proximityATR   = input.float (2.0,   "FRZ Proximity ATR Threshold",         group=GRP_FRZV72, minval=0.5, maxval=5.0, step=0.25)
frz_convergenceATR = input.float (0.5,   "FRZ-Attractor Convergence ATR",       group=GRP_FRZV72, minval=0.2, maxval=2.0, step=0.1)

showOriginShort    = originMode == "Short" or originMode == "Both"
showOriginLong     = originMode == "Long"  or originMode == "Both"

// ────────────────────
// Text Size Helper
// ────────────────────
f_tsize(string s) =>
    s == "tiny" ? size.tiny : s == "normal" ? size.normal : size.small

// ═══════════════
// SECTION 2 — CORE PHYSICS ENGINE
// ═══════════════

float atr          = ta.atr(atrLen)
float velocity     = ta.ema(close - close[1], 3)
float acceleration = velocity - velocity[1]
float convexity    = acceleration - acceleration[1]
float convSmooth   = ta.ema(convexity, 3)

float move         = math.abs(close - close[effLen])
float pathSum      = math.sum(math.abs(close - close[1]), effLen)
float efficiency   = pathSum > 0 ? move / pathSum : 0.0
float displacement = (high - low) / math.max(atr, 1e-10)

float convThreshold = atr * convMult
bool  bullConvShift = convSmooth >  convThreshold and convSmooth[1] <=  convThreshold
bool  bearConvShift = convSmooth < -convThreshold and convSmooth[1] >= -convThreshold

float atrSma     = ta.sma(atr, 20)
float volRatio   = atr / math.max(atrSma, 1e-10)
string volRegime = volRatio > 1.5 ? "HIGH" : volRatio < 0.7 ? "LOW" : "NORMAL"
float volMult    = math.max(0.5, math.min(volRatio, 2.5))

bool bullImpulse  = efficiency > effThresh and velocity > velocity[1] and acceleration > 0 and close > open and displacement > dispThresh
bool bearImpulse  = efficiency > effThresh and velocity < velocity[1] and acceleration < 0 and close < open and displacement > dispThresh
bool bullMomDecay = math.abs(acceleration) < math.abs(acceleration[1]) * 0.8 and velocity > 0
bool bearMomDecay = math.abs(acceleration) < math.abs(acceleration[1]) * 0.8 and velocity < 0

bool bullMicroImpulse = efficiency > effThresh * 0.80 and velocity > velocity[1] and acceleration > 0 and close > open and displacement > dispThresh * 0.50
bool bearMicroImpulse = efficiency > effThresh * 0.80 and velocity < velocity[1] and acceleration < 0 and close < open and displacement > dispThresh * 0.50

// ═══════════════
// SECTION 3 — HTF BELIEF ENGINE
// ═══════════════

f_htfBeliefs(float _open, float _high, float _low, float _close,
             float _effT, float _dispT,
             int   _acceptB, float _convMult,
             int   _obLook) =>
    float _atr_htf  = ta.atr(atrLen)
    float _vel_htf  = ta.ema(_close - _close[1], 3)
    float _acc_htf  = _vel_htf - _vel_htf[1]
    float _conv_htf = _acc_htf - _acc_htf[1]
    float _convSm   = ta.ema(_conv_htf, 3)
    float _convTh   = _atr_htf * _convMult
    float _move     = math.abs(_close - _close[_obLook])
    float _pathSum  = math.sum(math.abs(_close - _close[1]), _obLook)
    float _eff      = _pathSum > 0 ? _move / _pathSum : 0.0
    float _disp     = (_high - _low) / math.max(_atr_htf, 1e-10)

    float _expScore  = math.min(_eff / math.max(_effT, 1e-10) * 50.0 + _disp / math.max(_dispT, 1e-10) * 50.0, 100.0)
    float _decayScr  = math.abs(_acc_htf) < math.abs(_acc_htf[1]) * 0.8 ? math.min(math.abs(_conv_htf) / math.max(_convTh, 1e-10) * 50.0, 100.0) : 0.0
    float _curvScr   = math.min(math.abs(_convSm) / math.max(_convTh, 1e-10) * 50.0, 100.0)
    float _abScr     = (_eff < _effT * 0.7 and math.abs(_vel_htf) < math.abs(_vel_htf[1]) * 0.6) ? 60.0 + _curvScr * 0.4 : _curvScr * 0.3
    float _liqScr    = (math.abs(_convSm) > _convTh * 1.5 and _disp > _dispT) ? math.min(_curvScr * 1.2, 100.0) : _curvScr * 0.5

    bool  _bullImp   = _eff > _effT and _vel_htf > _vel_htf[1] and _acc_htf > 0 and _close > _open and _disp > _dispT
    bool  _bearImp   = _eff > _effT and _vel_htf < _vel_htf[1] and _acc_htf < 0 and _close < _open and _disp > _dispT
    int   _dir       = _bullImp ? 1 : _bearImp ? -1 : 0
    float _dispStr   = math.min(_disp / math.max(_dispT, 1e-10), 3.0)
    int   _structB   = _bullImp ? 1 : _bearImp ? -1 : _dir

    [_dir, _structB, _dispStr, _expScore, _decayScr, _curvScr, _abScr, _liqScr]

[raw_dir_tf1, raw_structB_tf1, raw_disp_tf1, raw_expScr_tf1, raw_decScr_tf1, raw_curvScr_tf1, raw_abScr_tf1, raw_liqScr_tf1] = request.security(syminfo.tickerid, tf1,
    f_htfBeliefs(open, high, low, close, effThresh, dispThresh, acceptBars, convMult, obLookback),
    lookahead=barmerge.lookahead_off)

[raw_dir_tf2, raw_structB_tf2, raw_disp_tf2, raw_expScr_tf2, raw_decScr_tf2, raw_curvScr_tf2, raw_abScr_tf2, raw_liqScr_tf2] = request.security(syminfo.tickerid, tf2,
    f_htfBeliefs(open, high, low, close, effThresh, dispThresh, acceptBars, convMult, obLookback),
    lookahead=barmerge.lookahead_off)

int   dir_tf1     = nz(raw_dir_tf1)
int   dir_tf2     = nz(raw_dir_tf2)
int   structB_tf1 = nz(raw_structB_tf1)
int   structB_tf2 = nz(raw_structB_tf2)
float expScr_tf1  = nz(raw_expScr_tf1)
float expScr_tf2  = nz(raw_expScr_tf2)
float decScr_tf1  = nz(raw_decScr_tf1)
float decScr_tf2  = nz(raw_decScr_tf2)
float curvScr_tf1 = nz(raw_curvScr_tf1)
float curvScr_tf2 = nz(raw_curvScr_tf2)
float abScr_tf1   = nz(raw_abScr_tf1)
float abScr_tf2   = nz(raw_abScr_tf2)
float liqScr_tf1  = nz(raw_liqScr_tf1)
float liqScr_tf2  = nz(raw_liqScr_tf2)

// ── Phase 1 (visualization) — HTF / ITF / M1 zone ranges ─────────────────────
// Reuses the SAME tf1 / tf2 timeframes (and "1" = M1) already defined above for
// the belief engines. This does not add new detection logic — it simply reads
// Helper to return [highest, lowest] over 20 bars for zone visualization
f_zoneRange() => [ta.highest(high, 20), ta.lowest(low, 20)]

// each timeframe's recent price range so the L2/L1/L3 layers can be SHOWN
// spatially on the chart instead of only as numeric dashboard readouts.
[l2_zoneHigh, l2_zoneLow] = request.security(syminfo.tickerid, tf2,
     f_zoneRange(), lookahead=barmerge.lookahead_off)

[l1_zoneHigh, l1_zoneLow] = request.security(syminfo.tickerid, tf1,
     f_zoneRange(), lookahead=barmerge.lookahead_off)

[l3_zoneHigh, l3_zoneLow] = request.security(syminfo.tickerid, "1",
     f_zoneRange(), lookahead=barmerge.lookahead_off)

var int htfBias1  = 0
var int htfBias2  = 0
if expScr_tf1 > 60 and dir_tf1 != 0
    htfBias1 := dir_tf1
if expScr_tf2 > 60 and dir_tf2 != 0
    htfBias2 := dir_tf2
if decScr_tf1 > 70 and dir_tf1 == htfBias1
    htfBias1 := 0
if decScr_tf2 > 70 and dir_tf2 == htfBias2
    htfBias2 := 0

int htfAlign = (htfBias1 == 1  and htfBias2 == 1)  ?  1 :
               (htfBias1 == -1 and htfBias2 == -1) ? -1 : 0

// ═══════════════
// V72 — MCE MULTI-TIMEFRAME CONSENSUS ENGINE (request.security calls)
// 4-level extension: tf3 (H4) and tf4 (Daily) added to existing tf1/tf2
// ═══════════════

[raw_dir_tf3, raw_structB_tf3, raw_disp_tf3, raw_expScr_tf3, raw_decScr_tf3, raw_curvScr_tf3, raw_abScr_tf3, raw_liqScr_tf3] = request.security(syminfo.tickerid, tf3,
    f_htfBeliefs(open, high, low, close, effThresh, dispThresh, acceptBars, convMult, obLookback),
    lookahead=barmerge.lookahead_off)

[raw_dir_tf4, raw_structB_tf4, raw_disp_tf4, raw_expScr_tf4, raw_decScr_tf4, raw_curvScr_tf4, raw_abScr_tf4, raw_liqScr_tf4] = request.security(syminfo.tickerid, tf4,
    f_htfBeliefs(open, high, low, close, effThresh, dispThresh, acceptBars, convMult, obLookback),
    lookahead=barmerge.lookahead_off)

int   dir_tf3     = nz(raw_dir_tf3)
int   dir_tf4     = nz(raw_dir_tf4)
int   structB_tf3 = nz(raw_structB_tf3)
int   structB_tf4 = nz(raw_structB_tf4)
float expScr_tf3  = nz(raw_expScr_tf3)
float expScr_tf4  = nz(raw_expScr_tf4)
float decScr_tf3  = nz(raw_decScr_tf3)
float decScr_tf4  = nz(raw_decScr_tf4)
float curvScr_tf3 = nz(raw_curvScr_tf3)
float curvScr_tf4 = nz(raw_curvScr_tf4)
float abScr_tf3   = nz(raw_abScr_tf3)
float abScr_tf4   = nz(raw_abScr_tf4)
float liqScr_tf3  = nz(raw_liqScr_tf3)
float liqScr_tf4  = nz(raw_liqScr_tf4)

// ═══════════════
// SECTION 4 — MARKET STRUCTURE
// ═══════════════

float structPivH = ta.pivothigh(high, structLen, structLen)
float structPivL = ta.pivotlow (low,  structLen, structLen)

var float lastPivHigh = na
var float prevPivHigh = na
var float lastPivLow  = na
var float prevPivLow  = na
var int   structBias  = 0

if not na(structPivH)
    prevPivHigh := lastPivHigh
    lastPivHigh := structPivH
if not na(structPivL)
    prevPivLow  := lastPivLow
    lastPivLow  := structPivL

bool isHH = not na(lastPivHigh) and not na(prevPivHigh) and lastPivHigh > prevPivHigh
bool isLH = not na(lastPivHigh) and not na(prevPivHigh) and lastPivHigh < prevPivHigh
bool isHL = not na(lastPivLow)  and not na(prevPivLow)  and lastPivLow  > prevPivLow
bool isLL = not na(lastPivLow)  and not na(prevPivLow)  and lastPivLow  < prevPivLow

var float prevSwingHigh = na
var float prevSwingLow  = na
var float currSwingHigh = na
var float currSwingLow  = na

float swPivH = ta.pivothigh(high, pivotLen, pivotLen)
float swPivL = ta.pivotlow (low,  pivotLen, pivotLen)

if not na(swPivH)
    prevSwingHigh := na(currSwingHigh) ? swPivH : currSwingHigh
    currSwingHigh := swPivH
if not na(swPivL)
    prevSwingLow  := na(currSwingLow)  ? swPivL : currSwingLow
    currSwingLow  := swPivL

bool bullBOS = not na(prevSwingHigh) and close > prevSwingHigh
bool bearBOS = not na(prevSwingLow)  and close < prevSwingLow

if useStrictStructure
    if isHH and isHL
        structBias := 1
    if isLH and isLL
        structBias := -1
else
    if bullBOS
        structBias := 1
    if bearBOS
        structBias := -1

bool _structLabelsOK = displayMode != "Execution"
if showStruct and _structLabelsOK and useStrictStructure and not na(structPivH) and (ecvAllLocations or ecvHighs)
    label.new(bar_index[structLen], structPivH, isHH ? "HH" : "LH",
         style=label.style_label_down,
         color=isHH ? color.new(color.lime, 55) : color.new(color.red, 55),
         textcolor=color.white, size=size.tiny)

if showStruct and _structLabelsOK and useStrictStructure and not na(structPivL) and (ecvAllLocations or ecvLows)
    label.new(bar_index[structLen], structPivL, isHL ? "HL" : "LL",
         style=label.style_label_up,
         color=isHL ? color.new(color.lime, 55) : color.new(color.red, 55),
         textcolor=color.white, size=size.tiny)

if showStruct and _structLabelsOK and not useStrictStructure and bullBOS and (ecvAllLocations or ecvHighs)
    label.new(bar_index, low - atr * 0.3, "BOS ▲",
         style=label.style_label_up, color=color.new(color.lime, 40), textcolor=color.black, size=size.tiny)

if showStruct and _structLabelsOK and not useStrictStructure and bearBOS and (ecvAllLocations or ecvLows)
    label.new(bar_index, high + atr * 0.3, "BOS ▼",
         style=label.style_label_down, color=color.new(color.red, 40), textcolor=color.white, size=size.tiny)

bool structLongOK  = not requireStruct or (useStrictStructure and structBias ==  1 and isHH) or (not useStrictStructure and structBias ==  1)
bool structShortOK = not requireStruct or (useStrictStructure and structBias == -1 and isLL) or (not useStrictStructure and structBias == -1)

// ═══════════════
// SECTION 5 — MAX PIVOT MEMORY ENGINE
// ═══════════════

float pivH = ta.pivothigh(high, pivotLen, pivotLen)
float pivL = ta.pivotlow (low,  pivotLen, pivotLen)

var float lastPivotPrice = na
var int   lastPivotBar   = na
var int   lastPivotDir   = 0
var float prevPivotPrice = na
var int   prevPivotBar   = na
var int   prevPivotDir   = 0

float pivotEventPrice = na
int   pivotEventBar   = na
int   pivotEventDir   = 0

if not na(pivH)
    pivotEventPrice := pivH
    pivotEventBar   := bar_index - pivotLen
    pivotEventDir   := 1
else if not na(pivL)
    pivotEventPrice := pivL
    pivotEventBar   := bar_index - pivotLen
    pivotEventDir   := -1

if pivotEventDir != 0
    prevPivotPrice := lastPivotPrice
    prevPivotBar   := lastPivotBar
    prevPivotDir   := lastPivotDir
    lastPivotPrice := pivotEventPrice
    lastPivotBar   := pivotEventBar
    lastPivotDir   := pivotEventDir

// ═══════════════
// SECTION 6 — MAX IMPULSE DETECTION
// ═══════════════

bool eliteShortImpulse = not na(pivL) and prevPivotDir == 1  and (prevPivotPrice - pivL) > atr * impulseAtrMult
bool eliteLongImpulse  = not na(pivH) and prevPivotDir == -1 and (pivH - prevPivotPrice) > atr * impulseAtrMult

// ═══════════════
// SECTION 7 — MAX INDUCEMENT / FLIPZONE PRICE FINDER
// ═══════════════

f_findInducPrice(int _anchorRefBar, float _anchorTop, float _anchorBot, int _lookback) =>
    float _best     = na
    float _bestDist = na
    int   _maxI     = math.min(_lookback, bar_index - _anchorRefBar)
    if _maxI >= 1
        for i = 1 to _maxI
            if high[i] < _anchorTop and low[i] > _anchorBot
                float _d = math.abs((bar_index - i) - _anchorRefBar)
                if na(_bestDist) or _d < _bestDist
                    _bestDist := _d
                    _best     := (high[i] + low[i]) / 2.0
    _best

// ═══════════════
// SECTION 8 — WAVE CONTEXT VARIABLES
// ═══════════════

var int   direction     = 0
var float flipTop       = na
var float flipBot       = na
var box   flipBox       = na
var int   obBirthBar    = na
var int   barsInZone    = 0
var int   contBar       = na

var float point4OriginHigh = na
var float point4OriginLow  = na
var int   point4OriginBar  = na

var box   p4Box     = na
var line  p4LineTop = na
var line  p4LineBot = na
var box   demandBox = na
var box   supplyBox = na

var float flipzoneInducPrice = na
var float flipzoneInducLow   = na
var float flipzoneInducHigh  = na

var float inducExpOriginHigh  = na
var float inducExpExtremeLow  = na
var float inducExpOriginLow   = na
var float inducExpExtremeHigh = na

var float inducRetrOriginHigh  = na
var float inducRetrExtremeLow  = na
var float inducRetrOriginLow   = na
var float inducRetrExtremeHigh = na

var float inducZoneLow  = na
var float inducZoneHigh = na

var float cycleHigh = na
var float cycleLow  = na

var int   waveGeneration    = 0
var int   entryCycle        = 0
var bool  isRecursiveWave   = false
var int   waveDepth         = 0
var int   lastSpawnDir      = 0
var bool  recursiveComplete = false

float _g_highestAB = ta.highest(high, acceptBars)
float _g_lowestAB  = ta.lowest (low,  acceptBars)

var array<float> cycleObTop        = array.new_float(4, na)
var array<float> cycleObBot        = array.new_float(4, na)
var array<float> cycleFlipTop      = array.new_float(4, na)
var array<float> cycleFlipBot      = array.new_float(4, na)
var array<float> cycleP4High       = array.new_float(4, na)
var array<float> cycleP4Low        = array.new_float(4, na)
var array<int>   cycleStartBar     = array.new_int  (4, na)
var array<int>   cycleDir          = array.new_int  (4, 0)
var array<box>   cycleHistoryBoxes = array.new<box> (4, na)

// ═══════════════
// V72 — WAVE REGISTRY (WR) — Var Declarations
// Parallel arrays tracking wave identity, lineage, and lifecycle metadata.
// Max 50 entries with rolling eviction.
// ═══════════════
var array<int>    wr_waveId       = array.new_int()
var array<int>    wr_parentWaveId = array.new_int()
var array<int>    wr_rootWaveId   = array.new_int()
var array<int>    wr_birthBar     = array.new_int()
var array<int>    wr_deathBar     = array.new_int()
var array<string> wr_spawnPhase   = array.new_string()
var array<string> wr_deathPhase   = array.new_string()
var array<int>    wr_depth        = array.new_int()

var int wr_nextId        = 1
var int wr_activeWaveId  = 0
var int wr_activeParentId = 0
var int wr_activeRootId  = 0

// V72 — DELIVERY WAVE REGISTRY (DWR) — Var Declarations
var array<int>    dwr_waveId          = array.new_int()
var array<int>    dwr_parentWaveId    = array.new_int()
var array<int>    dwr_rootWaveId      = array.new_int()
var array<int>    dwr_startBar        = array.new_int()
var array<int>    dwr_endBar          = array.new_int()
var array<float>  dwr_energy          = array.new_float()
var array<string> dwr_resState        = array.new_string()
var array<int>    dwr_entryCycle      = array.new_int()
var array<string> dwr_lineage         = array.new_string()

var int dwr_nextId           = 1
var int dwr_activeDeliveryId = 0

f_storeCycleState(int _cycle, float _obT, float _obB, float _fT, float _fB,
                  float _p4H, float _p4L, int _startBar, int _dir) =>
    int _idx = math.min(_cycle - 1, 3)
    array.set(cycleObTop,    _idx, _obT)
    array.set(cycleObBot,    _idx, _obB)
    array.set(cycleFlipTop,  _idx, _fT)
    array.set(cycleFlipBot,  _idx, _fB)
    array.set(cycleP4High,   _idx, _p4H)
    array.set(cycleP4Low,    _idx, _p4L)
    array.set(cycleStartBar, _idx, _startBar)
    array.set(cycleDir,      _idx, _dir)
    box _oldBox = array.get(cycleHistoryBoxes, _idx)
    if not na(_oldBox)
        box.delete(_oldBox)
    if showCycleHistory and not na(_p4H) and not na(_p4L)
        color _histCol    = _dir == 1 ? color.new(color.teal, 93) : color.new(color.red, 93)
        color _histBorder = _dir == 1 ? color.new(color.teal, 60) : color.new(color.red, 60)
        box _hb = box.new(left=_startBar, top=_p4H, right=bar_index + 200,
             bottom=_p4L, bgcolor=_histCol, border_color=_histBorder,
             border_style=line.style_dashed, border_width=1)
        array.set(cycleHistoryBoxes, _idx, _hb)

// ─────────────────
// HELPER FUNCTIONS (defined after arrays are declared, before first use)
// ─────────────────

// Helper: WR eviction (removes oldest entry from all WR arrays)
f_wrEvict() =>
    array.shift(wr_waveId)
    array.shift(wr_parentWaveId)
    array.shift(wr_rootWaveId)
    array.shift(wr_birthBar)
    array.shift(wr_deathBar)
    array.shift(wr_spawnPhase)
    array.shift(wr_deathPhase)
    array.shift(wr_depth)

// Helper: Dominant narrative (compressed ternary chain)
f_getNarrative(int dir, float htfAl, string phase, float rotProb, string rotSt, string resSt) =>
    string result = "No Clear Narrative"
    if dir == 1 and htfAl >= 70 and (phase == "Expansion" or phase == "New High") and rotProb < 40
        result := "Bullish Continuation"
    else if dir == -1 and htfAl >= 70 and (phase == "Expansion" or phase == "New Low") and rotProb < 40
        result := "Bearish Continuation"
    else if dir == 1 and htfAl >= 55 and (phase == "Retracement" or phase == "Demand Return")
        result := "Bullish Pullback"
    else if dir == -1 and htfAl >= 55 and (phase == "Retracement" or phase == "Supply Return")
        result := "Bearish Pullback"
    else if rotProb >= 65 and dir == -1
        result := "Bullish Rotation"
    else if rotProb >= 65 and dir == 1 and htfAl < 50
        result := "Bearish Rotation"
    else if rotSt == "CONTESTED" and resSt == "UNRESOLVED"
        result := "Range Development"
    result

// Helper: DOE bias (compressed ternary chain)
f_getBias(int dir, float htfAl, float rotStab) =>
    string result = "Neutral"
    if dir == 1 and htfAl >= 75 and rotStab >= 65
        result := "Strong Bullish"
    else if dir == 1 and htfAl >= 50
        result := "Bullish"
    else if dir == -1 and htfAl >= 75 and rotStab >= 65
        result := "Strong Bearish"
    else if dir == -1 and htfAl >= 50
        result := "Bearish"
    result

// Helper: DOE action (compressed ternary chain)
f_getAction(bool inv, bool erfGate, bool rrGate, string phase, int dir, float rotProb, string narr) =>
    string result = "Wait"
    if inv
        result := "No Trade"
    else if not erfGate
        result := "Wait"
    else if not rrGate
        result := "Wait"
    else if phase == "Demand Return" and dir == 1
        result := "Long"
    else if phase == "Supply Return" and dir == -1
        result := "Short"
    else if rotProb >= 75 and narr == "Bullish Rotation"
        result := "Long"
    else if rotProb >= 75 and narr == "Bearish Rotation"
        result := "Short"
    result

// ═══════════════
// FORWARD DECLARATIONS
// ═══════════════

var bool inductionEvidence  = false
var bool preConvEvidence    = false
var bool closeInside        = false
var bool m1AbsorptionEmer   = false
var bool m1ConvexityEmer    = false
var bool m1LiquidityEmer    = false

// ═══════════════
// SECTION 9 — PHYSICS OBSERVATION LAYER
// (Moved before Engine 1A — Engine 1A momentum/physics dimensions require
//  obs_* scores, convexityScore, and physicsConsensus at evaluation time.)
// ═══════════════

float velocityScore     = math.min(math.abs(velocity)     / math.max(atr * 0.1, 1e-10) * 50.0, 100.0)
float accelerationScore = math.min(math.abs(acceleration) / math.max(atr * 0.05,1e-10) * 50.0, 100.0)
float convexityScore    = math.min(math.abs(convSmooth)   / math.max(atr * convMult, 1e-10) * 25.0, 100.0)
float expansionScore    = math.min(displacement / math.max(dispThresh, 1e-10) * 50.0, 100.0)

float obs_ExpansionScore  = math.min(
     (efficiency > effThresh ? efficiency * 60.0 : efficiency * 30.0) +
     (displacement > dispThresh ? (displacement / math.max(dispThresh, 1e-10) - 1.0) * 20.0 : 0.0) +
     (velocity > 0 and acceleration > 0 ? velocityScore * 0.2 : velocity < 0 and acceleration < 0 ? velocityScore * 0.2 : 0.0),
     100.0)

float obs_DecayScore      = math.min(
     (bullMomDecay or bearMomDecay ? 40.0 : 0.0) +
     (convexityScore > 30 ? convexityScore * 0.5 : 0.0) +
     (math.abs(velocity) < math.abs(velocity[1]) * 0.7 ? 30.0 : 0.0),
     100.0)

float obs_CurvatureScore  = convexityScore

float obs_AbsorptionScore = math.min(
     (efficiency < effThresh * 0.7 ? (1.0 - efficiency / math.max(effThresh, 1e-10)) * 50.0 : 0.0) +
     (math.abs(velocity) < math.abs(velocity[1]) * 0.5 ? 30.0 : 0.0) +
     (displacement < dispThresh * 0.5 ? 20.0 : 0.0),
     100.0)

float obs_LiquidityScore  = math.min(
     obs_DecayScore * 0.4 +
     obs_CurvatureScore * 0.4 +
     (displacement > dispThresh * 1.2 and (bullMomDecay or bearMomDecay) ? 20.0 : 0.0),
     100.0)

float physicsMax  = math.max(obs_ExpansionScore, obs_DecayScore, obs_AbsorptionScore, obs_LiquidityScore)
float physicsDiff = physicsMax - math.min(obs_ExpansionScore, obs_DecayScore, obs_AbsorptionScore, obs_LiquidityScore)
float physicsConsensus = math.max(0.0, 100.0 - physicsDiff)

// ── Forward declarations for liqHeat, nearFlipzone, convexityMaturity ──────────
// These are fully computed in Sections 10–12 below. The var declarations here
// allow Engine 1A (which runs before those sections) to reference them safely.
// On bar 0 they hold their initialised defaults; from bar 1 onward the Section
// 10–12 assignments run first on the PREVIOUS bar, so the values are valid.
var float liqHeat         = 0.0
var bool  nearFlipzone    = false
var float convexityMaturity = 0.0

// ═══════════════
// ENGINE 1A — UNIFIED WAVE LIFECYCLE & PHASE DEFINITION ENGINE
// SOLE LIFECYCLE AUTHORITY — ALL DOWNSTREAM SYSTEMS CONSUME THIS OUTPUT ONLY.
//
// ARCHITECTURE:
//   Phase is determined by THREE DIMENSIONS SIMULTANEOUSLY:
//     DIMENSION 1 — STRUCTURE  : BOS events, swing violations, induction objects
//     DIMENSION 2 — MOMENTUM   : Expansion efficiency, decay, directional impulse
//     DIMENSION 3 — WAVE PHYSICS: Convexity development, geometric capacity,
//                                 liquidity formation, expansion integrity
//
//   A lifecycle phase becomes active ONLY when all three dimensions describe
//   the same market condition.  Structure alone, Momentum alone, Physics alone,
//   or any two-dimension combination is INVALID for phase assignment.
//
// CANONICAL LIFECYCLE (sole permitted vocabulary):
//   Point 4 Origin → Expansion → Expansion Pre-Convexity → Expansion Induction
//   → Expansion Liquidity → New High / New Low → Absorption → Retracement
//   → Retracement Pre-Convexity → Retracement Induction → Retracement Liquidity
//   → Demand Return / Supply Return
//
// OUTPUTS:
//   ie1a_waveDirection  : "Bullish Wave" | "Bearish Wave"
//   ie1a_currentPhase   : one of the 14 canonical lifecycle phases above
// ═══════════════

// ── 1A-S: STRUCTURAL TRACKING OBJECTS ────────────────────────────────────────
// BOS-1 / BOS-2: first and second opposing Break Of Structure.
// Induction Origin / Induction Extreme: stored as persistent structural objects.
// A BOS occurs ONLY when a previously protected structural swing is violated.
//   Bullish wave  → protected swing = most recent Higher Low   (bearish BOS when violated)
//   Bearish wave  → protected swing = most recent Lower High   (bullish BOS when violated)

// Protected-swing tracking: most recent HL (bull) or LH (bear)
var float ie1a_protectedSwing   = na   // current protected swing level
var float ie1a_protectedSwing2  = na   // previous protected swing (for BOS-2)

// BOS event flags (structural evidence objects — NOT lifecycle phases)
var bool  ie1a_bos1Active      = false  // BOS-1 has been confirmed (expansion-phase)
var bool  ie1a_bos2Active      = false  // BOS-2 has been confirmed (expansion-phase)
var int   ie1a_bos1Bar         = na     // bar of BOS-1
var int   ie1a_bos2Bar         = na     // bar of BOS-2
var float ie1a_bos1Level       = na     // price at which BOS-1 was broken
var float ie1a_bos2Level       = na     // price at which BOS-2 was broken

// Retracement sub-lifecycle BOS objects (dedicated, distinct from expansion BOS)
var bool  ie1a_retrBos1Active  = false  // Retracement BOS-1 (first opposing BOS within retracement)
var bool  ie1a_retrBos2Active  = false  // Retracement BOS-2 (second opposing BOS within retracement)
var float ie1a_retrProtSwing   = na     // Retracement protected swing level
var float ie1a_retrProtSwing2  = na     // Retracement protected swing 2 (for BOS-2)

// Induction structural objects (must survive across phases)
var float ie1a_inductionOrigin   = na   // structural origin of induction sequence
var float ie1a_inductionExtreme  = na   // highest/lowest point reached by induction
var bool  ie1a_inductionOriginBroken = false  // true when induction origin is violated

// Wave direction (1=bull, -1=bear, 0=undefined) — mirrors `direction`
var int   ie1a_dir = 0

// Reset BOS / Induction state on new wave spawn
// (wave spawn resets direction, so we track resets via direction change)
var int   ie1a_lastDir = 0

bool ie1a_waveReset = direction != ie1a_lastDir
ie1a_lastDir := direction

if ie1a_waveReset
    ie1a_dir                   := direction
    ie1a_bos1Active            := false
    ie1a_bos2Active            := false
    ie1a_bos1Bar               := na
    ie1a_bos2Bar               := na
    ie1a_bos1Level             := na
    ie1a_bos2Level             := na
    ie1a_inductionOrigin       := na
    ie1a_inductionExtreme      := na
    ie1a_inductionOriginBroken := false
    ie1a_protectedSwing        := na
    ie1a_protectedSwing2       := na
    ie1a_retrBos1Active        := false
    ie1a_retrBos2Active        := false
    ie1a_retrProtSwing         := na
    ie1a_retrProtSwing2        := na
else
    ie1a_dir := direction

// ── Update protected swing: Bullish = track Higher Lows; Bearish = track Lower Highs
// Uses structPivH / structPivL from Section 4 (already computed)
if direction == 1 and not na(structPivL)
    // Bullish: protected swing = most recent confirmed pivot low (HL)
    ie1a_protectedSwing2 := ie1a_protectedSwing
    ie1a_protectedSwing  := structPivL

if direction == -1 and not na(structPivH)
    // Bearish: protected swing = most recent confirmed pivot high (LH)
    ie1a_protectedSwing2 := ie1a_protectedSwing
    ie1a_protectedSwing  := structPivH

// ── BOS Detection — structure must actually fail (not momentum/score proxy)
// BOS-1: first opposing BOS after expansion begins
// BOS-2: second opposing BOS (counter-structure developing)

bool _ie1a_bearBOS_opp = direction == 1  and not na(ie1a_protectedSwing)  and close < ie1a_protectedSwing
bool _ie1a_bullBOS_opp = direction == -1 and not na(ie1a_protectedSwing)  and close > ie1a_protectedSwing

// Register BOS-1 (first opposing BOS)
if not ie1a_bos1Active and (_ie1a_bearBOS_opp or _ie1a_bullBOS_opp)
    ie1a_bos1Active := true
    ie1a_bos1Bar    := bar_index
    ie1a_bos1Level  := ie1a_protectedSwing
    // On BOS-1, set induction origin to the expansion extreme at that moment
    ie1a_inductionOrigin := direction == 1 ? nz(cycleHigh, high) : nz(cycleLow, low)

// Register BOS-2 (second opposing BOS — counter-structure established)
if ie1a_bos1Active and not ie1a_bos2Active and (_ie1a_bearBOS_opp or _ie1a_bullBOS_opp) and
     not na(ie1a_protectedSwing2) and
     (direction == 1 ? close < ie1a_protectedSwing2 : close > ie1a_protectedSwing2)
    ie1a_bos2Active := true
    ie1a_bos2Bar    := bar_index
    ie1a_bos2Level  := ie1a_protectedSwing2

// ── Induction Extreme tracking (highest/lowest point of induction structure)
// Bull wave: induction moves DOWN (counter-flow), so extreme = new low made during induction
// Bear wave: induction moves UP   (counter-flow), so extreme = new high made during induction
if ie1a_bos1Active and direction == 1
    float _indExt = nz(ie1a_inductionExtreme, close)
    if close < _indExt or na(ie1a_inductionExtreme)
        ie1a_inductionExtreme := close

if ie1a_bos1Active and direction == -1
    float _indExt2 = nz(ie1a_inductionExtreme, close)
    if close > _indExt2 or na(ie1a_inductionExtreme)
        ie1a_inductionExtreme := close

// ── Induction Origin Break — New High / New Low trigger
// When price breaks the induction origin (the expansion extreme at BOS-1 time),
// dominant expansion has reclaimed control.
if ie1a_bos2Active and not na(ie1a_inductionOrigin)
    if direction == 1  and close > ie1a_inductionOrigin
        ie1a_inductionOriginBroken := true
    if direction == -1 and close < ie1a_inductionOrigin
        ie1a_inductionOriginBroken := true

// ── Retracement Sub-Lifecycle Structural Tracking ─────────────────────────────
// Dedicated BOS objects for the retracement sub-lifecycle; fully independent
// of the expansion-phase ie1a_bos1Active / ie1a_bos2Active flags.
// Bull wave retracement = counter-flow bears; pivot highs within the retrace
// become the retracement protected swings (LH structure within the retrace).
// Bear wave retracement = counter-flow bulls; pivot lows become protected swings.

// Update retracement protected swings (only when induction origin is broken)
if ie1a_inductionOriginBroken and direction == 1 and not na(structPivH)
    // Bull wave retracing: bears form LH structure — track pivot highs
    ie1a_retrProtSwing2 := ie1a_retrProtSwing
    ie1a_retrProtSwing  := structPivH

if ie1a_inductionOriginBroken and direction == -1 and not na(structPivL)
    // Bear wave retracing: bulls form HL structure — track pivot lows
    ie1a_retrProtSwing2 := ie1a_retrProtSwing
    ie1a_retrProtSwing  := structPivL

// Retracement opposing BOS detectors
bool _ie1a_retrBullBOS_opp = direction == 1  and not na(ie1a_retrProtSwing) and close > ie1a_retrProtSwing
bool _ie1a_retrBearBOS_opp = direction == -1 and not na(ie1a_retrProtSwing) and close < ie1a_retrProtSwing

// Register Retracement BOS-1 (first opposing BOS within the retracement sub-lifecycle)
if ie1a_inductionOriginBroken and not ie1a_retrBos1Active and
     (_ie1a_retrBullBOS_opp or _ie1a_retrBearBOS_opp)
    ie1a_retrBos1Active := true

// Register Retracement BOS-2 (second opposing BOS within the retracement)
if ie1a_retrBos1Active and not ie1a_retrBos2Active and
     (_ie1a_retrBullBOS_opp or _ie1a_retrBearBOS_opp) and
     not na(ie1a_retrProtSwing2) and
     (direction == 1 ? close > ie1a_retrProtSwing2 : close < ie1a_retrProtSwing2)
    ie1a_retrBos2Active := true

// ── 1A-M: MOMENTUM DIMENSION ─────────────────────────────────────────────────
// Provides momentum state for phase determination — not standalone phase assignment.

bool ie1a_momExpansionStrong =
     efficiency > effThresh and
     (direction == 1 ? (velocity > 0 and acceleration > 0) : (velocity < 0 and acceleration < 0))

bool ie1a_momDecaying =
     (direction == 1 ? bullMomDecay : bearMomDecay) and
     math.abs(velocity) < math.abs(velocity[1]) * 0.85

bool ie1a_momCounterFlowStrengthening =
     (direction == 1 ? bearImpulse : bullImpulse)

bool ie1a_momLiquidityVisible =
     obs_LiquidityScore > 45.0 and (bullMomDecay or bearMomDecay)

bool ie1a_momDirectionalReturn =
     (direction == 1 ? (bullImpulse and close > nz(cycleHigh[1], close)) :
                       (bearImpulse and close < nz(cycleLow[1],  close)))

bool ie1a_momExhaustionTerminal =
     efficiency < effThresh * 0.65 and
     obs_AbsorptionScore > 40.0 and
     math.abs(velocity) < math.abs(velocity[3]) * 0.55

bool ie1a_momRetracementControl =
     (direction == 1 ? (bearImpulse and efficiency > effThresh * 0.8) :
                       (bullImpulse and efficiency > effThresh * 0.8))

// ── 1A-P: WAVE PHYSICS DIMENSION ─────────────────────────────────────────────
// Provides physics state — not standalone phase assignment.

bool ie1a_physExpansionIntact =
     obs_ExpansionScore > 50.0 and convexityScore < 35.0

bool ie1a_physConvexityBeginning =
     convexityScore > 20.0 and obs_DecayScore > 25.0 and
     obs_ExpansionScore < obs_DecayScore * 1.5

bool ie1a_physConvexityMature =
     convexityScore > 40.0 and obs_DecayScore > 40.0 and convexityMaturity > 35.0

bool ie1a_physLiquidityPool =
     obs_LiquidityScore > 45.0 and liqHeat > 25.0

bool ie1a_physExpansionCapacityRestored =
     obs_ExpansionScore > 55.0 and efficiency > effThresh and
     (direction == 1 ? velocity > 0 and acceleration > 0 : velocity < 0 and acceleration < 0)

bool ie1a_physAbsorptionCapacityDeclines =
     obs_AbsorptionScore > 40.0 and obs_ExpansionScore < 50.0

bool ie1a_physRetracementParticipationDominant =
     obs_DecayScore > 35.0 and convexityScore > 15.0 and obs_ExpansionScore < obs_DecayScore * 1.2

bool ie1a_physRetrConvexityBeginning =
     ie1a_physConvexityBeginning and obs_DecayScore > 30.0 and convexityScore > 18.0

bool ie1a_physRetrLiquidityPool =
     ie1a_physLiquidityPool and nearFlipzone

bool ie1a_physRegenerationPresent =
     obs_ExpansionScore > 40.0 and
     (direction == 1 ? bullImpulse : bearImpulse)

// ── 1A-PHASE: THREE-DIMENSIONAL PHASE DETERMINATION ──────────────────────────
// CRITICAL: Phase activates ONLY when Structure AND Momentum AND Physics
// all describe the same market condition simultaneously.

// Compute direction for Engine 1A output
string ie1a_waveDirection = direction == 1 ? "Bullish Wave" : direction == -1 ? "Bearish Wave" : "Undefined"

// Evaluate each canonical phase using all three dimensions:

// POINT 4 ORIGIN: valid origin, no BOS yet
// Momentum dimension: nascent (pre-impulse) state — efficiency building but not yet
// crossing the strong-expansion threshold, with aligned but sub-threshold directional bias.
bool ie1a_momNascent =
     efficiency > effThresh * 0.5 and efficiency <= effThresh * 1.1 and
     (direction == 1 ? velocity > 0 : velocity < 0)

bool ie1a_cond_P4 =
     direction != 0 and
     not ie1a_bos1Active and
     ie1a_momNascent and
     ie1a_physExpansionIntact

// ── 1A-EVIDENCE: STRUCTURAL EVIDENCE SCORES ──────────────────────────────────
// BOS-1, BOS-2, InductionExtreme, and InductionOriginBroken are evidence objects.
// They contribute scored weight to the structural dimension alongside physics and
// momentum; they do NOT act as binary on/off gates that alone flip phase eligibility.
// Each structural evidence score reflects confidence in the structural state, scaled
// 0–100, and must clear a minimum threshold (50.0) to confirm the structure dimension.

// Structural evidence: pre-convexity state (BOS-1 confirmed, BOS-2 not yet)
float ie1a_strucScore_ExpPreConv =
     (ie1a_bos1Active and not ie1a_bos2Active ? 50.0 : 0.0) +
     (ie1a_bos1Active and not na(ie1a_bos1Level) and
      math.abs(close - ie1a_bos1Level) < atr * 3.0 ? 25.0 : 0.0) +
     (direction != 0 ? 25.0 : 0.0)

// Structural evidence: induction state (BOS-2 confirmed, origin not yet broken)
float ie1a_strucScore_ExpInduction =
     (ie1a_bos2Active and not ie1a_inductionOriginBroken ? 50.0 : 0.0) +
     (not na(ie1a_inductionOrigin) ? 25.0 : 0.0) +
     (ie1a_bos2Active and not na(ie1a_bos2Level) and
      math.abs(close - ie1a_bos2Level) < atr * 4.0 ? 25.0 : 0.0)

// Structural evidence: induction extreme set (liquidity pool exists in structure)
float ie1a_strucScore_ExpLiquidity =
     (ie1a_bos2Active and not ie1a_inductionOriginBroken ? 40.0 : 0.0) +
     (not na(ie1a_inductionExtreme) ? 35.0 : 0.0) +
     (not na(ie1a_inductionOrigin) ? 25.0 : 0.0)

// Structural evidence: induction origin broken (expansion reclaimed structural authority)
float ie1a_strucScore_NewHL =
     (ie1a_inductionOriginBroken ? 55.0 : 0.0) +
     (not na(ie1a_inductionOrigin) and
      (direction == 1 ? close > ie1a_inductionOrigin : close < ie1a_inductionOrigin) ? 30.0 : 0.0) +
     (ie1a_bos2Active ? 15.0 : 0.0)

// Structural evidence: expansion objective completed (origin broken, price extended)
float ie1a_strucScore_PostNew =
     (ie1a_inductionOriginBroken ? 50.0 : 0.0) +
     (not na(cycleHigh) and direction ==  1 and high >= nz(cycleHigh, high)  * 0.998 ? 30.0 :
      not na(cycleLow)  and direction == -1 and low  <= nz(cycleLow,  low)  * 1.002 ? 30.0 : 0.0) +
     (ie1a_bos2Active ? 20.0 : 0.0)

// Structural evidence: retracement BOS-1 confirmed within retracement sub-lifecycle
float ie1a_strucScore_RetrPreConv =
     (ie1a_retrBos1Active ? 50.0 : 0.0) +
     (ie1a_inductionOriginBroken ? 30.0 : 0.0) +
     (not na(ie1a_retrProtSwing) ? 20.0 : 0.0)

// Structural evidence: retracement BOS-2 confirmed (dedicated retracement induction)
float ie1a_strucScore_RetrInduction =
     (ie1a_retrBos2Active ? 50.0 : 0.0) +
     (ie1a_retrBos1Active ? 30.0 : 0.0) +
     (not na(ie1a_retrProtSwing2) ? 20.0 : 0.0)

// Structural evidence: induction extreme reached within retracement sub-lifecycle
float ie1a_strucScore_RetrLiquidity =
     (ie1a_retrBos1Active ? 40.0 : 0.0) +
     (not na(ie1a_inductionExtreme) ? 35.0 : 0.0) +
     (ie1a_inductionOriginBroken ? 25.0 : 0.0)

// Minimum structural score threshold: structure dimension requires >= 50 to confirm
float _ie1a_strucThresh = 50.0

// EXPANSION: structure intact, no opposing BOS, strong momentum, physics confirms
bool ie1a_cond_Expansion =
     direction != 0 and
     not ie1a_bos1Active and
     ie1a_momExpansionStrong and
     ie1a_physExpansionIntact

// EXPANSION PRE-CONVEXITY: BOS-1 scored evidence + momentum decaying + convexity beginning
bool ie1a_cond_ExpPreConv =
     ie1a_strucScore_ExpPreConv >= _ie1a_strucThresh and
     ie1a_momDecaying and
     ie1a_physConvexityBeginning

// EXPANSION INDUCTION: BOS-2 scored evidence + counter-flow strengthening + convexity matures
bool ie1a_cond_ExpInduction =
     ie1a_strucScore_ExpInduction >= _ie1a_strucThresh and
     ie1a_momCounterFlowStrengthening and
     ie1a_physConvexityMature

// EXPANSION LIQUIDITY: liquidity structure scored evidence + liquidity momentum + pool confirmed
bool ie1a_cond_ExpLiquidity =
     ie1a_strucScore_ExpLiquidity >= _ie1a_strucThresh and
     ie1a_momLiquidityVisible and
     ie1a_physLiquidityPool

// NEW HIGH / NEW LOW: induction origin broken (scored) + directional acceleration + expansion restored
bool ie1a_cond_NewHL =
     ie1a_strucScore_NewHL >= _ie1a_strucThresh and
     ie1a_momDirectionalReturn and
     ie1a_physExpansionCapacityRestored

// ABSORPTION: post-new structural evidence + momentum exhausting + capacity declines
bool ie1a_cond_Absorption =
     ie1a_strucScore_PostNew >= _ie1a_strucThresh and
     ie1a_momExhaustionTerminal and
     ie1a_physAbsorptionCapacityDeclines

// RETRACEMENT: post-new structural evidence + counter-flow control + physics confirms
bool ie1a_cond_Retracement =
     ie1a_strucScore_PostNew >= _ie1a_strucThresh and
     ie1a_momRetracementControl and
     ie1a_physRetracementParticipationDominant

// RETRACEMENT PRE-CONVEXITY: retracement BOS-1 scored evidence + decaying momentum + convexity
bool ie1a_cond_RetrPreConv =
     ie1a_cond_Retracement and
     ie1a_strucScore_RetrPreConv >= _ie1a_strucThresh and
     ie1a_momDecaying and
     ie1a_physRetrConvexityBeginning

// RETRACEMENT INDUCTION: retracement BOS-2 scored evidence + counter-structure + convexity matures
bool ie1a_cond_RetrInduction =
     ie1a_cond_Retracement and
     ie1a_strucScore_RetrInduction >= _ie1a_strucThresh and
     ie1a_momCounterFlowStrengthening and
     ie1a_physConvexityMature

// RETRACEMENT LIQUIDITY: retracement liquidity scored evidence + liquidity momentum + flipzone pool
bool ie1a_cond_RetrLiquidity =
     ie1a_cond_Retracement and
     ie1a_strucScore_RetrLiquidity >= _ie1a_strucThresh and
     ie1a_momLiquidityVisible and
     ie1a_physRetrLiquidityPool

// DEMAND RETURN / SUPPLY RETURN: price inside flipzone (structure) + regeneration physics + directional momentum
bool ie1a_cond_DemandReturn = direction == 1  and closeInside and
     ie1a_physRegenerationPresent and
     ie1a_momDirectionalReturn

bool ie1a_cond_SupplyReturn = direction == -1 and closeInside and
     ie1a_physRegenerationPresent and
     ie1a_momDirectionalReturn

// ── 1A-OUT: CANONICAL PHASE ASSIGNMENT ───────────────────────────────────────
// Priority ladder: most-advanced phase checked first (lifecycle is sequential).
// Only phases where ALL THREE dimensions confirm are permitted.

string ie1a_currentPhase =
     direction == 0                    ? "Point 4 Origin"              :
     ie1a_cond_DemandReturn            ? "Demand Return"               :
     ie1a_cond_SupplyReturn            ? "Supply Return"               :
     ie1a_cond_RetrLiquidity           ? "Retracement Liquidity"       :
     ie1a_cond_RetrInduction           ? "Retracement Induction"       :
     ie1a_cond_RetrPreConv             ? "Retracement Pre-Convexity"   :
     ie1a_cond_Retracement             ? "Retracement"                 :
     ie1a_cond_Absorption              ? "Absorption"                  :
     ie1a_cond_NewHL                   ? (direction == -1 ? "New Low"  : "New High") :
     ie1a_cond_ExpLiquidity            ? "Expansion Liquidity"         :
     ie1a_cond_ExpInduction            ? "Expansion Induction"         :
     ie1a_cond_ExpPreConv              ? "Expansion Pre-Convexity"     :
     ie1a_cond_Expansion               ? "Expansion"                   :
     ie1a_cond_P4                      ? "Point 4 Origin"              : "Point 4 Origin"

// ── 1A-CONF: IE1A CONFIDENCE (how many dimensions aligned for current phase)
// Used by downstream engines as phase integrity signal.
int ie1a_dimCount =
     (ie1a_cond_P4 or ie1a_cond_Expansion or ie1a_cond_ExpPreConv or ie1a_cond_ExpInduction or
      ie1a_cond_ExpLiquidity or ie1a_cond_NewHL or ie1a_cond_Absorption or
      ie1a_cond_Retracement or ie1a_cond_RetrPreConv or ie1a_cond_RetrInduction or
      ie1a_cond_RetrLiquidity or ie1a_cond_DemandReturn or ie1a_cond_SupplyReturn ? 3 : 0)
float ie1a_phaseConfidence = ie1a_dimCount >= 3 ? 100.0 : ie1a_dimCount == 2 ? 66.0 : ie1a_dimCount == 1 ? 33.0 : 0.0

// ── 1A-MAP: CANONICAL PHASE → HYPOTHESIS FAMILY MAP ─────────────────────────
// Maps IE1A phase back to the internal hypothesis vocabulary used by downstream
// belief engines (which remain as confidence providers, not phase assigners).
string ie1a_hypFamily =
     ie1a_currentPhase == "Expansion"                  ? "EXPANSION"          :
     ie1a_currentPhase == "Expansion Pre-Convexity"    ? "CONVEXITY FORMING"  :
     ie1a_currentPhase == "Expansion Induction"        ? "CONVEXITY FORMING"  :
     ie1a_currentPhase == "Expansion Liquidity"        ? "CONVEXITY FORMING"  :
     ie1a_currentPhase == "New High"                   ? "CREATION FORMING"   :
     ie1a_currentPhase == "New Low"                    ? "CREATION FORMING"   :
     ie1a_currentPhase == "Absorption"                 ? "ABSORPTION"         :
     ie1a_currentPhase == "Retracement"                ? "RETRACEMENT"        :
     ie1a_currentPhase == "Retracement Pre-Convexity"  ? "RETRACEMENT"        :
     ie1a_currentPhase == "Retracement Induction"      ? "RETRACEMENT"        :
     ie1a_currentPhase == "Retracement Liquidity"      ? "RETRACEMENT"        :
     ie1a_currentPhase == "Demand Return"              ? "DEMAND/SUPPLY RETURN" :
     ie1a_currentPhase == "Supply Return"              ? "DEMAND/SUPPLY RETURN" : "EXPANSION"

// Expansion-side flag (used by classifier for Retr Pre-Convexity/Induction/Liquidity mapping)
bool ie1a_isExpSide =
     ie1a_currentPhase == "Expansion"               or
     ie1a_currentPhase == "Expansion Pre-Convexity" or
     ie1a_currentPhase == "Expansion Induction"     or
     ie1a_currentPhase == "Expansion Liquidity"     or
     ie1a_currentPhase == "New High"                or
     ie1a_currentPhase == "New Low"

// END ENGINE 1A
// ═══════════════

// ═══════════════
// ENERGY RESOLUTION FRAMEWORK (ERF)
// Combines: Energy Dissipation Engine (EDE) + Resolution Engine (RE) + Energy Attractor Engine (EAE)
// Architecture:  Price → EDE → RE → EAE → Intelligence Engine
//
// FUNDAMENTAL MARKET AXIOM
//   Market = Energy Generation System
//   Expansion       = Energy Creation
//   Pre-Convexity   = Initial Dissipation
//   Induction       = Secondary Dissipation
//   Liquidation     = Delivery Dissipation
//   Supply/Demand   = Potential Resolution Node
//   Zone Revisit    = Incomplete Resolution
//   Rotation        = Competing Energy System
// ═══════════════

// ──────────────────────
// EDE — ENERGY DISSIPATION ENGINE
// Answers: How is energy cleaning itself?
// Tracks:  Expansion Energy | Dissipation Progress | Cleaning State | Delivery State
// ──────────────────────

// State 1-6 derived directly from IE1A canonical phase
// State 1: Energy Accumulation       → "Point 4 Origin" / "Expansion"
// State 2: Energy Release 1 (Pre-Conv)→ "Expansion Pre-Convexity"
// State 3: Energy Release 2 (Induction)→ "Expansion Induction"
// State 4: Energy Purge (Liquidation)→ "Expansion Liquidity"
// State 5: Objective Delivery        → "New High" / "New Low"
// State 6: Resolution Assessment     → "Absorption" onward

int ede_state =
     ie1a_currentPhase == "Point 4 Origin"            ? 1 :
     ie1a_currentPhase == "Expansion"                 ? 1 :
     ie1a_currentPhase == "Expansion Pre-Convexity"   ? 2 :
     ie1a_currentPhase == "Expansion Induction"       ? 3 :
     ie1a_currentPhase == "Expansion Liquidity"       ? 4 :
     ie1a_currentPhase == "New High"                  ? 5 :
     ie1a_currentPhase == "New Low"                   ? 5 : 6

string ede_cleaningState =
     ede_state == 1 ? "Accumulating" :
     ede_state == 2 ? "Cleaning — Initial Release"  :
     ede_state == 3 ? "Cleaning — Secondary Release" :
     ede_state == 4 ? "Cleaning — Purge"            :
     ede_state == 5 ? "Delivering"                  : "Resolving"

// Expansion energy: proxy from physics score during expansion phase
float ede_expansionEnergy = math.min(
     obs_ExpansionScore * 0.50 +
     (bullImpulse or bearImpulse ? 30.0 : 0.0) +
     (efficiency * 20.0), 100.0)

// Dissipated energy: accumulates through pre-conv → induction → liquidation
float ede_dissipatedEnergy = math.min(
     (ede_state >= 2 ? obs_DecayScore * 0.40 : 0.0) +
     (ede_state >= 3 ? obs_CurvatureScore * 0.30 : 0.0) +
     (ede_state >= 4 ? obs_LiquidityScore * 0.30 : 0.0), 100.0)

// Dissipation progress 0-100
float ede_dissipationProgress = math.min(
     (ede_state >= 2 ? 25.0 : 0.0) +
     (ede_state >= 3 ? 25.0 : 0.0) +
     (ede_state >= 4 ? 25.0 : 0.0) +
     (ede_state >= 5 ? 25.0 : 0.0), 100.0)

// Delivery state: is the liquidation leg itself expanding (becoming a delivery wave)?
bool ede_liquidationBecomingDirectional =
     ede_state == 4 and (bullImpulse or bearImpulse) and efficiency > effThresh * 0.8

// Delivery space score: how much room remains before the objective?
// Uses convexityMaturity as inverse proxy — higher maturity = less space remaining
float ede_deliverySpaceScore = math.min(
     math.max(0.0, 100.0 - convexityMaturity) * 1.0, 100.0)

// Messy price action recognition — a core principle of EDE
// Messy ≠ Randomness; Messy = Energy Dissipation
bool ede_messyPriceIsDissipation =
     (ede_state >= 2 and ede_state <= 4) and
     obs_DecayScore > 30.0 and
     efficiency < effThresh * 0.9 and
     not (bullImpulse or bearImpulse)

// ──────────────────────
// RE — RESOLUTION ENGINE
// Answers: Did the process actually finish?
// Tracks:  Resolution State | Recursive Completion | Residual Energy
// Key axiom: Objective Hit ≠ Process Complete
// ──────────────────────

// Resolution states: RESOLVED | PARTIALLY_RESOLVED | UNRESOLVED
// Logic: reaching New High/Low (state 5) is objective delivery, but resolution
// requires the full absorption + retracement + demand return cycle.

// Expected recursive cycles based on wave generation depth
int re_expectedCycles = math.max(1, math.min(waveDepth + 2, 4))

// Completed cycles = entryCycle (each recursive wave = one completed dissipation cycle)
int re_completedCycles = math.max(0, math.min(entryCycle, re_expectedCycles))

// Recursive completion score 0-100
float re_recursiveCompletionScore =
     re_expectedCycles > 0 ?
     math.min(float(re_completedCycles) / float(re_expectedCycles) * 100.0, 100.0) : 0.0

// Residual energy = expansion energy minus what has been dissipated
float re_residualEnergy = math.max(0.0,
     ede_expansionEnergy - ede_dissipatedEnergy)

// Resolution state determination
// RESOLVED: delivery + full absorption + retracement + demand return completed
bool re_objectiveReached = ede_state >= 5
bool re_fullDissipation  = ede_dissipationProgress >= 75.0
float re_dissipationProgress = ede_dissipationProgress

bool re_absorbedAndReturned =
     (ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return") and
     recursiveComplete

string re_resolutionState =
     re_absorbedAndReturned and re_fullDissipation and re_recursiveCompletionScore >= 75.0 ?
          "RESOLVED" :
     re_objectiveReached and re_dissipationProgress >= 50.0 ?
          "PARTIALLY RESOLVED" : "UNRESOLVED"

// alias for local use in RE

// Residual energy score 0-100 (higher = more uncleaned energy remaining)
float re_residualEnergyScore = math.min(re_residualEnergy, 100.0)

// Node open/closed determination
bool re_nodeOpen   = re_resolutionState == "UNRESOLVED" or re_resolutionState == "PARTIALLY RESOLVED"
bool re_nodeClosed = re_resolutionState == "RESOLVED"

// Revisit probability (higher when open/unresolved)
float re_revisitProbability =
     re_resolutionState == "UNRESOLVED"         ? math.min(re_residualEnergyScore * 0.90, 95.0) :
     re_resolutionState == "PARTIALLY RESOLVED" ? math.min(re_residualEnergyScore * 0.60, 75.0) :
                                                   math.min(re_residualEnergyScore * 0.20, 25.0)

// ──────────────────────
// EAE — ENERGY ATTRACTOR ENGINE
// Answers: Where is unresolved energy pulling price?
// New magnetism principle: Price attracted to unresolved energy (not just liquidity)
// ──────────────────────

// Primary attractor: the most significant unresolved energy node
// Logic: if wave is unresolved, the current flipzone IS the primary attractor;
// if partially resolved, the demand/supply zone is the secondary attractor.
// Distance to attractor uses existing geometric calculations.

float eae_primaryAttractorPrice =
     re_resolutionState == "UNRESOLVED" ?
          (direction == 1 ? nz(flipBot, close - atr * 2.0) : nz(flipTop, close + atr * 2.0)) :
     re_resolutionState == "PARTIALLY RESOLVED" ?
          (direction == 1 ? nz(point4OriginLow, close - atr) : nz(point4OriginHigh, close + atr)) :
          na

float eae_secondaryAttractorPrice =
     re_resolutionState == "UNRESOLVED" and not na(inducZoneLow) and not na(inducZoneHigh) ?
          (direction == 1 ? nz(inducZoneLow, na) : nz(inducZoneHigh, na)) : na

// Attractor scoring — weighted by residual energy, timeframe weight, termination strength
float eae_primaryAttractorScore = math.min(
     re_residualEnergyScore * 0.40 +
     (re_resolutionState == "UNRESOLVED" ? 30.0 :
      re_resolutionState == "PARTIALLY RESOLVED" ? 20.0 : 5.0) +
     (not na(eae_primaryAttractorPrice) ?
          math.max(0.0, 30.0 - math.abs(close - eae_primaryAttractorPrice) / math.max(atr, 1e-10) * 5.0)
          : 0.0),
     100.0)

float eae_secondaryAttractorScore = math.min(
     re_residualEnergyScore * 0.25 +
     (re_resolutionState == "PARTIALLY RESOLVED" ? 20.0 : 10.0) +
     (not na(eae_secondaryAttractorPrice) ?
          math.max(0.0, 20.0 - math.abs(close - eae_secondaryAttractorPrice) / math.max(atr, 1e-10) * 4.0)
          : 0.0),
     100.0)

// Primary attractor label for display
string eae_primaryAttractorLabel =
     re_resolutionState == "UNRESOLVED" ? "Flip Zone (High Residual)" :
     re_resolutionState == "PARTIALLY RESOLVED" ? "Origin Zone (Partial)" : "No Active Attractor"

// Energy state summary (for Intelligence Engine output)
string eae_energyState =
     ede_state == 1 ? "Accumulating" :
     ede_state >= 2 and ede_state <= 4 ? "Cleaning"     :
     ede_state == 5 ? "Delivering"                       :
     re_resolutionState == "RESOLVED"  ? "Exhausted"    : "Resolving"

// ── ERF: ROTATION ENGINE MODIFICATION ────────────────────────────────────────
// Old logic: Messy Structure = Rotation Risk
// New logic: Before rotation scoring, ask: Is active dissipation occurring?
//            If yes → suppress rotation because Cleaning ≠ Rotation

bool erf_activeDissipation = ede_messyPriceIsDissipation
bool erf_suppressRotation  = erf_activeDissipation and ede_state >= 2 and ede_state <= 4

// ERF Confidence: how well do EDE, RE, and EAE agree on market state?
float erf_confidence = math.min(
     (eae_energyState != "Accumulating" ? ie1a_phaseConfidence * 0.40 : 20.0) +
     (re_resolutionState == "RESOLVED"  ? 30.0 :
      re_resolutionState == "PARTIALLY RESOLVED" ? 20.0 : 10.0) +
     (eae_primaryAttractorScore * 0.30),
     100.0)

// ERF Dissipation Confidence (does the observed complexity match cleaning expectations?)
float erf_dissipationConfidence = math.min(
     (ede_messyPriceIsDissipation ? 50.0 : 0.0) +
     (ede_dissipationProgress * 0.50),
     100.0)

// END ENERGY RESOLUTION FRAMEWORK
// ═══════════════

// ═══════════════
// V72 — ERF TRADE READINESS + ENTRY GATE
// Elevates ERF from Advisory to Decision-Influencing (Level 5)
// ═══════════════

float erf_tradeReadiness = math.min(
     (re_resolutionState == "RESOLVED" ? 40.0 :
      re_resolutionState == "PARTIALLY RESOLVED" ? 25.0 : 10.0) +
     re_recursiveCompletionScore * 0.25 +
     (100.0 - re_residualEnergyScore) * 0.20 +
     erf_confidence * 0.15,
     100.0)

bool erf_entryGate = erf_tradeReadiness >= erfEntryThreshold

// ═══════════════
// V72 — ROTATION INTELLIGENCE ENGINE (RIE / Engine 2)
// Detects probability of control transfer between wave participants.
// Authority: rot_pressure, rot_controlStability, rot_transferProbability, rot_state
// DOES NOT assign lifecycle phases. IE1A remains sole lifecycle authority.
// ═══════════════

// rot_pressure: opposing force magnitude (0–100)
float rot_pressure = math.min(
     obs_DecayScore * rie_w_decay +
     obs_AbsorptionScore * rie_w_absorption +
     (convexityScore > 40 ? convexityScore * rie_w_convexity : 0.0) +
     (obs_LiquidityScore > 50 ? 15.0 : 0.0),
     100.0)

// rot_controlStability: how stable is current direction (0–100)
float rot_controlStability = math.min(
     obs_ExpansionScore * 0.40 +
     (efficiency > effThresh ? 30.0 : efficiency > effThresh * 0.7 ? 15.0 : 0.0) +
     (ede_state <= 2 ? 30.0 : ede_state <= 3 ? 15.0 : 0.0),
     100.0)

// rot_transferProbability: synthesis (0–100)
float rot_transferProbability = math.min(
     rot_pressure * 0.50 +
     (100.0 - rot_controlStability) * 0.30 +
     (re_resolutionState == "UNRESOLVED" ? 20.0 :
      re_resolutionState == "PARTIALLY RESOLVED" ? 10.0 : 0.0),
     100.0)

// rot_state: categorical classification
string rot_state =
     rot_transferProbability >= 75 ? "TRANSFER_IMMINENT" :
     rot_transferProbability >= 50 ? "CONTESTED" :
     rot_transferProbability >= 25 ? "SOFTENING" : "STABLE"

// ═══════════════
// SECTION 9 — PHYSICS OBSERVATION LAYER (declared before Engine 1A above)
// ═══════════════
// obs_ExpansionScore, obs_DecayScore, obs_CurvatureScore, obs_AbsorptionScore,
// obs_LiquidityScore, physicsMax, physicsDiff, physicsConsensus,
// velocityScore, accelerationScore, convexityScore, expansionScore
// — all declared in the moved block above. No re-declaration needed here.

// ═══════════════
// SECTION 10 — LIQUIDITY HEATMAP ENGINE
// ═══════════════

float _swH = ta.highest(high, liqSweepLookback)
float _swL = ta.lowest (low,  liqSweepLookback)

bool liqSweepBull = not na(flipTop) and _swH > flipTop
bool liqSweepBear = not na(flipBot) and _swL < flipBot

var array<float> liqLevels  = array.new_float()
var array<float> liqWeights = array.new_float()
var array<int>   liqAges    = array.new_int()
var array<int>   liqTypes   = array.new_int()

float volAvg  = ta.sma(volume, 20)
float normVol = volAvg > 0 ? volume[pivotLen] / volAvg : 1.0

if not na(pivH) or not na(pivL)
    float lvl   = not na(pivH) ? pivH : pivL
    int   lType = not na(pivH) ? 1 : -1
    float swRng = (high[pivotLen] - low[pivotLen]) / math.max(atr, 1e-10)
    float wt    = normVol * swRng
    array.push(liqLevels,  lvl)
    array.push(liqWeights, wt)
    array.push(liqAges,    bar_index - pivotLen)
    array.push(liqTypes,   lType)

if array.size(liqLevels) > 150
    array.shift(liqLevels)
    array.shift(liqWeights)
    array.shift(liqAges)
    array.shift(liqTypes)

float wDensity      = 0.0
float wDensityAbove = 0.0
float wDensityBelow = 0.0
float liqRadiusP    = atr * liqRadius
float liqRadiusWide = atr * liqRadius * 3.0

if array.size(liqLevels) > 0
    for i = 0 to array.size(liqLevels) - 1
        float lvl  = array.get(liqLevels,  i)
        float wt   = array.get(liqWeights, i)
        int   age  = bar_index - array.get(liqAges, i)
        float dcy  = math.pow(liqAgDecay, age)
        float dist = math.abs(close - lvl)
        if dist < liqRadiusP
            wDensity += wt * dcy
        if dist < liqRadiusWide
            if lvl > close
                wDensityAbove += wt * dcy * (1.0 - dist / liqRadiusWide)
            else
                wDensityBelow += wt * dcy * (1.0 - dist / liqRadiusWide)

float liqHeatRaw = math.min((wDensityAbove + wDensityBelow) / 2.0, 5.0) / 5.0 * 100.0
liqHeat         := math.min(math.max(liqHeatRaw, 0.0), 100.0)
string liqZone   = liqHeat < 30 ? "Open space" : liqHeat < 70 ? "Active" : "Congested"
bool liqVacuum   = wDensity < 0.5

bool liqSweepOK = not requireLiqSweep or
     (direction ==  1 and (liqSweepBull or liqVacuum)) or
     (direction == -1 and (liqSweepBear or liqVacuum))

plotshape(showLiq and not na(pivH), "Pivot High", shape.circle,
     location.abovebar, color.new(color.orange, 50), size=size.tiny)
plotshape(showLiq and not na(pivL), "Pivot Low",  shape.circle,
     location.belowbar, color.new(color.blue,   50), size=size.tiny)

// ═══════════════
// SECTION 11 — GEOMETRY ENGINE
// ═══════════════

int   obAge       = not na(obBirthBar) ? bar_index - obBirthBar : 0
bool  obFresh     = obAge <= obMaxBars
float obFreshness = not na(obBirthBar) ? math.max(0.0, 1.0 - obAge / float(obMaxBars)) : 0.0

float originToExtreme = na
if not na(point4OriginHigh) and not na(point4OriginLow)
    float orig = direction == 1 ? point4OriginLow : point4OriginHigh
    float extr = direction == 1 ? nz(cycleHigh, orig) : nz(cycleLow, orig)
    originToExtreme := math.abs(extr - orig)

float extremeToFlipzone = na
if not na(flipTop) and not na(flipBot) and not na(cycleHigh) and not na(cycleLow)
    float fzMid = (flipTop + flipBot) / 2.0
    float extr  = direction == 1 ? cycleHigh : cycleLow
    extremeToFlipzone := math.abs(extr - fzMid)

float flipzoneWidth = not na(flipTop) and not na(flipBot) ? flipTop - flipBot : na

float remainingRoom = na
if not na(flipTop) and not na(flipBot)
    float fzMid = (flipTop + flipBot) / 2.0
    remainingRoom := math.min(math.abs(close - fzMid) / math.max(atr * 4.0, 1e-10) * 100.0, 100.0)
float availableSpace = remainingRoom

string cycleCapacity = na(availableSpace)     ? "–"              :
                       availableSpace >= 60   ? "ROOM: HIGH"     :
                       availableSpace >= 30   ? "ROOM: MID"      : "ROOM: LOW"

bool geoFullConvexityPossible    = not na(originToExtreme) and not na(flipzoneWidth) and
     originToExtreme > atr * 6.0 and flipzoneWidth < atr * 3.0
bool geoPartialConvexityPossible = not na(originToExtreme) and
     originToExtreme > atr * 3.0 and originToExtreme <= atr * 6.0
bool geoAbsorptionOnly           = not na(originToExtreme) and originToExtreme <= atr * 3.0

float zonePrecision = not na(flipzoneWidth) ?
     math.max(100.0 - math.min((flipzoneWidth / math.max(atr * 0.5, 1e-10)) * 50.0, 100.0), 0.0) : 0.0

// ═══════════════
// SECTION 12 — WAVE INTELLIGENCE SYSTEM
// ═══════════════

float ref_effNorm     = math.min(efficiency,                                         1.0)
float ref_dispNorm    = math.min(displacement / math.max(dispThresh * 2.0, 1e-10),   1.0)
float ref_velNorm     = math.min(math.abs(velocity) / math.max(atr * 0.15, 1e-10),   1.0)
float ref_curvNorm    = math.min(math.abs(convSmooth) / math.max(atr * convMult * 2.0, 1e-10), 1.0)
float ref_absNorm     = math.min(obs_AbsorptionScore / 100.0,                        1.0)
float ref_decayNorm   = math.min(obs_DecayScore / 100.0,                             1.0)
float ref_liqNorm     = math.min(obs_LiquidityScore / 100.0,                         1.0)

f_idealSim(float _eObs, float _dObs, float _vObs, float _cObs,
           float _eIdeal, float _dIdeal, float _vIdeal, float _cIdeal) =>
    float _diff = math.pow(_eObs - _eIdeal, 2) +
                  math.pow(_dObs - _dIdeal, 2) +
                  math.pow(_vObs - _vIdeal, 2) +
                  math.pow(_cObs - _cIdeal, 2)
    math.max(0.0, 100.0 * (1.0 - _diff / 4.0))

float sim_Expansion    = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.85, 0.80, 0.80, 0.10)
float sim_PreConv      = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.60, 0.55, 0.40, 0.50)
float sim_Induction    = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.65, 0.60, 0.30, 0.60)
float sim_Liquidity    = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.45, 0.85, 0.15, 0.80)
float sim_Creation     = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.30, 0.70, 0.05, 0.90)
float sim_Absorption   = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.20, 0.25, 0.10, 0.40)
float sim_Retracement  = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.70, 0.65, 0.65, 0.25)
float sim_DemandReturn = f_idealSim(ref_effNorm, ref_dispNorm, ref_velNorm, ref_curvNorm, 0.50, 0.40, 0.35, 0.20)

// ── 12-POS: GEOMETRIC WAVE POSITION ENGINE ────────────────────────────────────

float waveTotalRange   = not na(originToExtreme) ? originToExtreme : atr * 5.0
float currentToFlipMid = not na(flipTop) and not na(flipBot) ?
     math.abs(close - (flipTop + flipBot) / 2.0) : atr * 4.0
float currentToExtreme = direction == 1 ?
     math.abs(nz(cycleHigh, close + atr) - close) :
     math.abs(close - nz(cycleLow, close - atr))

float distToCreation_atr    = currentToExtreme / math.max(atr, 1e-10)
float distToAbsorption_atr  = (currentToExtreme + atr * 0.5) / math.max(atr, 1e-10)
float distToRetracement_atr = (currentToExtreme + atr * 1.5) / math.max(atr, 1e-10)
float distToDemand_atr      = currentToFlipMid  / math.max(atr, 1e-10)
float distToOrigin_atr      = not na(point4OriginHigh) and not na(point4OriginLow) ?
     math.abs(close - (direction == 1 ? point4OriginLow : point4OriginHigh)) / math.max(atr, 1e-10) :
     waveTotalRange / math.max(atr, 1e-10)

float _posNormDen = math.max(waveTotalRange, atr * 0.5)
float posDistToCreation    = math.min(currentToExtreme / _posNormDen * 100.0, 100.0)
float posDistToAbsorption  = math.min((currentToExtreme + atr * 0.5) / _posNormDen * 100.0, 100.0)
float posDistToRetracement = math.min((currentToExtreme + atr * 1.5) / _posNormDen * 100.0, 100.0)
float posDistToDemand      = math.min(currentToFlipMid / _posNormDen * 100.0, 100.0)
float posDistToOrigin      = math.min(distToOrigin_atr * atr / _posNormDen * 100.0, 100.0)

// ── 12-CM: CONVEXITY MATURITY ENGINE ─────────────────────────────────────────

float expWeaknessScore = math.min(
     ((efficiency < effThresh ? (1.0 - efficiency / math.max(effThresh, 1e-10)) * 40.0 : 0.0) +
     (obs_DecayScore * 0.30) +
     (math.abs(velocity) < math.abs(velocity[2]) * 0.6 ? 20.0 : 0.0)) * (100.0 / 90.0),
     100.0)

float inductionMatScore = math.min(
     (inductionEvidence ? 35.0 : 0.0) +
     (obs_CurvatureScore * 0.35) +
     (preConvEvidence ? 20.0 : 0.0) +
     (displacement > dispThresh * 1.2 and (bullMomDecay or bearMomDecay) ? 10.0 : 0.0),
     100.0)

float liqMatScore = math.min(
     (obs_LiquidityScore * 0.50) +
     (liqSweepBull or liqSweepBear ? 30.0 : 0.0) +
     (liqHeat > 60 ? 20.0 : liqHeat > 30 ? 10.0 : 0.0),
     100.0)

float rawConvexityMaturity = math.min(
     expWeaknessScore   * 0.35 +
     inductionMatScore  * 0.35 +
     liqMatScore        * 0.30,
     100.0)

// convexityMaturity is declared as var before Engine 1A; update it here with the computed raw value.
convexityMaturity := convexityMaturity + (2.0 / (beliefSmooth + 1)) * (rawConvexityMaturity - convexityMaturity)

string convMatStage =
     convexityMaturity >= 80 ? "Terminal Convexity" :
     convexityMaturity >= 50 ? "Mature Convexity"   :
     convexityMaturity >= 20 ? "Developing Conv"    : "Early Convexity"

// ── 12-WP: WAVE PROGRESS ESTIMATION ──────────────────────────────────────────

float _progressFromGeom = na
if not na(point4OriginHigh) and not na(flipTop) and not na(flipBot)
    float _origin  = direction == 1 ? point4OriginLow  : point4OriginHigh
    float _extreme = direction == 1 ? nz(cycleHigh, close + atr) : nz(cycleLow, close - atr)
    float _fzMid   = (flipTop + flipBot) / 2.0
    float _totalMove = math.abs(_extreme - _origin)
    float _toFzMid   = math.abs(_extreme - _fzMid)
    float _traveled  = math.abs(close - _origin)
    float _expProg   = _totalMove > 1e-10 ? math.min(_traveled / _totalMove * 60.0, 60.0) : 30.0
    float _retrMove  = math.abs(close - _extreme)
    float _retrProg  = _toFzMid > 1e-10 ? math.min(_retrMove / math.max(_toFzMid, 1e-10) * 40.0, 40.0) : 0.0
    float _retrWeight = math.min(obs_AbsorptionScore / 40.0, 1.0)
    _progressFromGeom := _expProg + _retrProg * _retrWeight

float _geomProgress = nz(_progressFromGeom, 30.0)

float _simAnchor =
     sim_DemandReturn >= sim_Retracement and sim_DemandReturn >= sim_Absorption and
     sim_DemandReturn >= sim_Creation    and sim_DemandReturn >= sim_Expansion   ? 95.0 :
     sim_Retracement  >= sim_Absorption and sim_Retracement  >= sim_Creation    and
     sim_Retracement  >= sim_Expansion                                           ? 87.0 :
     sim_Absorption   >= sim_Creation   and sim_Absorption   >= sim_Expansion   ? 75.0 :
     sim_Creation     >= sim_Liquidity  and sim_Creation     >= sim_Expansion   ? 62.0 :
     sim_Liquidity    >= sim_Induction  and sim_Liquidity    >= sim_Expansion   ? 52.0 :
     sim_Induction    >= sim_PreConv    and sim_Induction    >= sim_Expansion   ? 43.0 :
     sim_PreConv      >= sim_Expansion                                           ? 33.0 : 22.0

float _convBandCenter   = 47.5
float _convBandHalfW    = 14.5
float _convWeight = math.max(0.0, 1.0 - math.abs(_simAnchor - _convBandCenter) / _convBandHalfW)
float _convAdjust = (convexityMaturity / 100.0) * (_simAnchor - 33.0) * 0.50 * _convWeight

float _physProgress = _simAnchor + _convAdjust

float rawWaveProgress = _geomProgress * 0.60 + _physProgress * 0.40

var float waveProgress = 30.0
waveProgress := waveProgress + (2.0 / (beliefSmooth + 1)) * (rawWaveProgress - waveProgress)
waveProgress := math.max(0.0, math.min(100.0, waveProgress))

// NOTE: waveProgressLabel is now a display-only relay of ENGINE 1A's canonical phase.
// The numeric waveProgress score remains available as a confidence/proximity signal
// for downstream engines but DOES NOT determine canonical lifecycle phase.
// All phase assignment authority belongs exclusively to ie1a_currentPhase.
string waveProgressLabel = ie1a_currentPhase

// ── 12-FIT: WAVE MODEL FIT ────────────────────────────────────────────────────

float _bestSim = math.max(sim_Expansion, sim_PreConv, sim_Induction, sim_Liquidity,
                           sim_Creation, sim_Absorption, sim_Retracement, sim_DemandReturn)

float _geomConsistency = math.min(
     (not na(originToExtreme) and originToExtreme > atr * 2.0 ? 30.0 : 0.0) +
     (not na(flipzoneWidth)   and flipzoneWidth < atr * 4.0    ? 25.0 : 0.0) +
     (not na(cycleHigh) or not na(cycleLow)                    ? 20.0 : 0.0) +
     (direction != 0                                           ? 25.0 : 0.0),
     100.0)

float rawWaveModelFit = _bestSim * 0.55 + _geomConsistency * 0.45
var float waveModelFit = 50.0
waveModelFit := waveModelFit + (2.0 / (beliefSmooth + 1)) * (rawWaveModelFit - waveModelFit)
waveModelFit := math.max(0.0, math.min(100.0, waveModelFit))

// ── 12A: BELIEF ENGINE ────────────────────────────────────────────────────────

preConvEvidence    := bullMomDecay or bearMomDecay
inductionEvidence  := (direction == 1  and bearImpulse and structBias ==  1) or
                          (direction == -1 and bullImpulse and structBias == -1)
bool liquidityEvidence  = obs_LiquidityScore > 50.0 and obs_DecayScore > 40.0

float _expPosMult = waveProgress < 40.0 ? 1.20 : waveProgress < 60.0 ? 0.80 : 0.50
float rawExpansionBelief = math.min(
     (obs_ExpansionScore * 0.45 +
     (bullImpulse or bearImpulse ? 30.0 : 0.0) +
     (efficiency > effThresh * 1.1 ? 15.0 : 0.0) +
     sim_Expansion * 0.10) * _expPosMult,
     100.0)

float _convPosMult = (waveProgress >= 30.0 and waveProgress <= 65.0) ? 1.30 : 0.70
float rawConvexityBelief = math.min(
     (obs_DecayScore * 0.30 +
     obs_CurvatureScore * 0.25 +
     (preConvEvidence   ? 15.0 : 0.0) +
     (inductionEvidence ? 10.0 : 0.0) +
     (liquidityEvidence ?  5.0 : 0.0) +
     convexityMaturity  * 0.08) * _convPosMult,
     100.0)

float _creatPosMult = (waveProgress >= 45.0 and waveProgress <= 68.0) ? 1.40 : 0.60
float rawCreationBelief = math.min(
     ((convexityMaturity > 50 ? convexityMaturity * 0.12 : 0.0) +
     (obs_DecayScore > 60 ? obs_DecayScore * 0.20 : 0.0) +
     (obs_LiquidityScore > 50 ? obs_LiquidityScore * 0.20 : 0.0) +
     (obs_AbsorptionScore > 20 ? obs_AbsorptionScore * 0.15 : 0.0) +
     (not na(cycleHigh) and not na(cycleLow) and
      ((direction == 1 and high >= nz(cycleHigh, high) * 0.998) or
       (direction == -1 and low <= nz(cycleLow, low) * 1.002)) ? 20.0 : 0.0) +
     sim_Creation * 0.10 +
     (posDistToCreation < 15.0 ? (15.0 - posDistToCreation) * 1.0 : 0.0)) * _creatPosMult,
     100.0)

float rawAbsorptionBelief = math.min(
     obs_AbsorptionScore * 0.50 +
     (efficiency < effThresh * 0.6 ? 25.0 : 0.0) +
     (displacement < dispThresh * 0.5 ? 15.0 : 0.0) +
     sim_Absorption * 0.10,
     100.0)

float rawRetracementBelief = math.min(
     ((direction == 1  and bearImpulse) or (direction == -1 and bullImpulse) ? 45.0 : 0.0) +
     (rawAbsorptionBelief > 50 ? rawAbsorptionBelief * 0.30 : 0.0) +
     (obs_CurvatureScore > 40 ? 15.0 : 0.0) +
     sim_Retracement * 0.10,
     100.0)

float rawDemandReturnBelief = math.min(
     (not na(flipTop) and not na(flipBot) and
      close <= flipTop and close >= flipBot ? 35.0 : 0.0) +
     (rawRetracementBelief > 60 ? rawRetracementBelief * 0.30 : 0.0) +
     (liqHeat > 50 ? liqHeat * 0.15 : 0.0) +
     (liqSweepBull or liqSweepBear ? 20.0 : 0.0) +
     sim_DemandReturn * 0.10,
     100.0)

// ── FIX: guard against NaN before EMA smoothing ───────────────────────────────
float safeRawExpBelief   = nz(rawExpansionBelief,    0.0)
float safeRawConvBelief  = nz(rawConvexityBelief,    0.0)
float safeRawCreatBelief = nz(rawCreationBelief,     0.0)
float safeRawAbsBelief   = nz(rawAbsorptionBelief,   0.0)
float safeRawRetrBelief  = nz(rawRetracementBelief,  0.0)
float safeRawDRBelief    = nz(rawDemandReturnBelief, 0.0)

var float expansionBelief    = 0.0
var float convexityBelief    = 0.0
var float creationBelief     = 0.0
var float absorptionBelief   = 0.0
var float retracementBelief  = 0.0
var float demandReturnBelief = 0.0

float bSmAlpha = 2.0 / (beliefSmooth + 1)
expansionBelief    := expansionBelief    + bSmAlpha * (safeRawExpBelief   - expansionBelief)
convexityBelief    := convexityBelief    + bSmAlpha * (safeRawConvBelief  - convexityBelief)
creationBelief     := creationBelief     + bSmAlpha * (safeRawCreatBelief - creationBelief)
absorptionBelief   := absorptionBelief   + bSmAlpha * (safeRawAbsBelief   - absorptionBelief)
retracementBelief  := retracementBelief  + bSmAlpha * (safeRawRetrBelief  - retracementBelief)
demandReturnBelief := demandReturnBelief + bSmAlpha * (safeRawDRBelief    - demandReturnBelief)

// Final display-safe values (clamp 0–100 and strip any residual NaN)
float d_expansionBelief    = math.max(0.0, math.min(100.0, nz(expansionBelief,    0.0)))
float d_convexityBelief    = math.max(0.0, math.min(100.0, nz(convexityBelief,    0.0)))
float d_creationBelief     = math.max(0.0, math.min(100.0, nz(creationBelief,     0.0)))
float d_absorptionBelief   = math.max(0.0, math.min(100.0, nz(absorptionBelief,   0.0)))
float d_retracementBelief  = math.max(0.0, math.min(100.0, nz(retracementBelief,  0.0)))
float d_demandReturnBelief = math.max(0.0, math.min(100.0, nz(demandReturnBelief, 0.0)))

// ── 12B: PHASE PROXIMITY ENGINE ──────────────────────────────────────────────

float expansionProximity = math.min(
     sim_Expansion * 0.50 +
     (bullImpulse or bearImpulse ? 25.0 : 0.0) +
     (waveProgress < 35.0 ? (35.0 - waveProgress) * 0.50 : 0.0) +
     (obs_ExpansionScore * 0.25), 100.0)

float convexityProximity = math.min(
     sim_PreConv * 0.25 + sim_Induction * 0.25 + sim_Liquidity * 0.20 +
     (preConvEvidence ? 15.0 : 0.0) +
     (waveProgress >= 30.0 and waveProgress <= 65.0 ? 15.0 : 0.0), 100.0)

float creationProximity = math.min(
     sim_Creation * 0.50 +
     (not na(cycleHigh) and direction == 1  and high >= nz(cycleHigh, high)  * 0.995 ? 25.0 : 0.0) +
     (not na(cycleLow)  and direction == -1 and low  <= nz(cycleLow,  low)   * 1.005 ? 25.0 : 0.0) +
     (convexityMaturity > 60 ? convexityMaturity * 0.25 : 0.0), 100.0)

float absorptionProximity = math.min(
     sim_Absorption * 0.50 +
     (obs_AbsorptionScore * 0.35) +
     (waveProgress >= 68.0 and waveProgress <= 80.0 ? 15.0 : 0.0), 100.0)

float retracementProximity = math.min(
     sim_Retracement * 0.50 +
     ((direction == 1  and bearImpulse) or (direction == -1 and bullImpulse) ? 30.0 : 0.0) +
     (waveProgress >= 78.0 and waveProgress <= 93.0 ? 20.0 : 0.0), 100.0)

float demandReturnProximity = math.min(
     sim_DemandReturn * 0.50 +
     (not na(flipTop) and not na(flipBot) and close <= flipTop and close >= flipBot ? 30.0 : 0.0) +
     (waveProgress >= 90.0 ? 20.0 : 0.0), 100.0)

// ── 12D: HYPOTHESIS ENGINE ────────────────────────────────────────────────────

float _fitMult = math.max(0.60, waveModelFit / 100.0)

float hyp_LateExpansion = (
     expansionBelief * 0.35 +
     (waveProgress < 38.0 ? (38.0 - waveProgress) * 0.80 : 0.0) +
     (convexityMaturity < 30 ? (30.0 - convexityMaturity) * 0.30 : 0.0) +
     sim_Expansion * 0.20 +
     (expansionBelief > 55 and convexityBelief > 30 ? 10.0 : 0.0)
     ) * _fitMult

float hyp_TerminalConvexity = (
     convexityBelief * 0.30 +
     (convexityMaturity > 50 ? convexityMaturity * 0.25 : 0.0) +
     (waveProgress >= 38.0 and waveProgress <= 62.0 ? 20.0 : 0.0) +
     (sim_Induction + sim_Liquidity) * 0.10 +
     (posDistToCreation < 25.0 ? (25.0 - posDistToCreation) * 0.50 : 0.0)
     ) * _fitMult

float hyp_CreationForming = (
     creationBelief * 0.40 +
     (convexityMaturity > 65 ? (convexityMaturity - 65.0) * 0.40 : 0.0) +
     (posDistToCreation < 15.0 ? (15.0 - posDistToCreation) * 1.50 : 0.0) +
     sim_Creation * 0.20
     ) * _fitMult

float hyp_AbsorptionActive = (
     absorptionBelief * 0.45 +
     (waveProgress >= 68.0 and waveProgress <= 80.0 ? 20.0 : 0.0) +
     sim_Absorption * 0.25 +
     (m1AbsorptionEmer ? 10.0 : 0.0)
     ) * _fitMult

float hyp_RetracementActive = (
     retracementBelief * 0.45 +
     (waveProgress >= 78.0 and waveProgress <= 92.0 ? 20.0 : 0.0) +
     sim_Retracement * 0.25 +
     ((direction == 1 and bearImpulse) or (direction == -1 and bullImpulse) ? 10.0 : 0.0)
     ) * _fitMult

float hyp_DemandReturn = (
     demandReturnBelief * 0.45 +
     (waveProgress >= 88.0 ? (waveProgress - 88.0) * 1.20 : 0.0) +
     sim_DemandReturn * 0.25 +
     (closeInside ? 15.0 : 0.0)
     ) * _fitMult

// Fixed theoretical maxima (with _fitMult <= 1.0) replace the old "rescale-to-100"
// normalization, which always forced the leading hypothesis to ~100% regardless
// of how weak its raw score was.
float HYP_MAX_LATEEXP   = 105.0
float HYP_MAX_TERMCONV  = 108.0
float HYP_MAX_CREATFORM = 97.0
float HYP_MAX_ABS       = 100.0
float HYP_MAX_RETR      = 100.0
float HYP_MAX_DR        = 100.0

float hyp_LateExpansion_N     = math.max(0.0, math.min(hyp_LateExpansion     / HYP_MAX_LATEEXP   * 100.0, 100.0))
float hyp_EarlyConvexity_N    = math.max(0.0, math.min(hyp_TerminalConvexity / HYP_MAX_TERMCONV  * 100.0, 100.0))
float hyp_CreationForming_N   = math.max(0.0, math.min(hyp_CreationForming   / HYP_MAX_CREATFORM * 100.0, 100.0))
float hyp_AbsorptionActive_N  = math.max(0.0, math.min(hyp_AbsorptionActive  / HYP_MAX_ABS        * 100.0, 100.0))
float hyp_RetracementActive_N = math.max(0.0, math.min(hyp_RetracementActive / HYP_MAX_RETR       * 100.0, 100.0))
float hyp_DemandReturn_N      = math.max(0.0, math.min(hyp_DemandReturn      / HYP_MAX_DR         * 100.0, 100.0))

float hypMax = math.max(hyp_LateExpansion_N, hyp_EarlyConvexity_N, hyp_CreationForming_N,
                         hyp_AbsorptionActive_N, hyp_RetracementActive_N, hyp_DemandReturn_N)

// primaryHypothesis — DISPLAY ONLY, sourced exclusively from ENGINE 1A.
// Maps ie1a_hypFamily to the hypothesis vocabulary for dashboard display and
// belief-score confidence rendering. Does NOT independently assign lifecycle phase.
// Belief scores (hyp_LateExpansion_N etc.) remain as confidence metrics only.
string primaryHypothesis = ie1a_hypFamily

// primaryHypothesisConf — confidence level for the current IE1A phase family,
// sourced from the belief score corresponding to ie1a_hypFamily.
float primaryHypothesisConf =
     primaryHypothesis == "EXPANSION"           ? hyp_LateExpansion_N     :
     primaryHypothesis == "CONVEXITY FORMING"   ? hyp_EarlyConvexity_N    :
     primaryHypothesis == "CREATION FORMING"    ? hyp_CreationForming_N   :
     primaryHypothesis == "ABSORPTION"          ? hyp_AbsorptionActive_N  :
     primaryHypothesis == "RETRACEMENT"         ? hyp_RetracementActive_N : hyp_DemandReturn_N

// ────────────────────
// CANONICAL PHASE CLASSIFIER
// ENGINE 1A is the sole lifecycle authority.  l0_targetWave / l0_currentPhase
// are assigned directly from ie1a_waveDirection / ie1a_currentPhase.
//
// f_toCanonicalPhase and f_classifyWave are retained as utility functions for
// L1 / L2 / L3 HTF layers which translate HTF belief-score vocabulary into
// canonical lifecycle phases.  They do NOT assign current-TF lifecycle state.
// Only ENGINE 1A may do that.
// ────────────────────

f_toCanonicalPhase(string rawPhase, bool isExpansionSide, bool isBull) =>
    string _out = "Point 4 Origin"
    if rawPhase == "EXPANSION"
        _out := "Expansion"
    else if rawPhase == "CONVEXITY FORMING"
        _out := isExpansionSide ? "Expansion Pre-Convexity" : "Retracement Pre-Convexity"
    else if rawPhase == "CREATION FORMING"
        _out := isBull ? "New High" : "New Low"
    else if rawPhase == "ABSORPTION"
        _out := "Absorption"
    else if rawPhase == "RETRACEMENT"
        _out := "Retracement"
    else if rawPhase == "DEMAND/SUPPLY RETURN"
        _out := isBull ? "Demand Return" : "Supply Return"
    else if rawPhase == "Expansion"
        _out := "Expansion"
    else if rawPhase == "Pre-Convexity"
        _out := isExpansionSide ? "Expansion Pre-Convexity" : "Retracement Pre-Convexity"
    else if rawPhase == "Liquidity"
        _out := isExpansionSide ? "Expansion Liquidity" : "Retracement Liquidity"
    else if rawPhase == "Absorption"
        _out := "Absorption"
    else if rawPhase == "M1 Expansion"
        _out := "Expansion"
    else if rawPhase == "M1 Exp Weak"
        _out := "Expansion Pre-Convexity"
    else if rawPhase == "M1 Convexity"
        _out := isExpansionSide ? "Expansion Induction" : "Retracement Induction"
    else if rawPhase == "M1 Liquidity"
        _out := isExpansionSide ? "Expansion Liquidity" : "Retracement Liquidity"
    else if rawPhase == "M1 Absorption"
        _out := "Absorption"
    _out

f_classifyWave(string _rawPhase, int _dir, bool _expSide) =>
    string _targetWave   = _dir >= 0 ? "Bullish Wave" : "Bearish Wave"
    bool   _isBull       = _dir >= 0
    string _currentPhase = f_toCanonicalPhase(_rawPhase, _expSide, _isBull)
    [_targetWave, _currentPhase]

// ── L0 PRIMARY: assigned exclusively from ENGINE 1A ──────────────────────────
// ENGINE 1A is the sole lifecycle authority — l0_targetWave and l0_currentPhase
// must not be derived from primaryHypothesis, waveProgress, or any score.
string l0_targetWave   = ie1a_waveDirection   // "Bullish Wave" | "Bearish Wave"
string l0_currentPhase = ie1a_currentPhase    // canonical lifecycle phase from IE1A

// ── 12E: PREDICTION ENGINE ────────────────────────────────────────────────────

float predScore_Expansion =
     (waveProgress < 35.0 ? (35.0 - waveProgress) * 1.00 : 0.0) +
     (expansionBelief > 55 ? expansionBelief * 0.30 : 0.0) +
     (convexityMaturity < 25 ? 20.0 : 0.0) +
     (posDistToCreation > 30 ? 15.0 : 0.0) +
     (htfAlign == direction and direction != 0 ? 15.0 : 0.0)

float predScore_Convexity =
     (waveProgress >= 25.0 and waveProgress <= 60.0 ? 30.0 : 0.0) +
     (convexityMaturity > 20 ? convexityMaturity * 0.30 : 0.0) +
     (obs_DecayScore > 40 ? 20.0 : 0.0) +
     (m1ConvexityEmer ? 15.0 : 0.0) +
     (preConvEvidence ? 15.0 : 0.0)

float predScore_Creation =
     (convexityMaturity > 55 ? (convexityMaturity - 55.0) * 1.20 : 0.0) +
     (posDistToCreation < 20.0 ? (20.0 - posDistToCreation) * 2.00 : 0.0) +
     (obs_LiquidityScore > 55 ? 20.0 : 0.0) +
     (liqSweepBull or liqSweepBear ? 15.0 : 0.0) +
     (m1LiquidityEmer ? 10.0 : 0.0)

float predScore_Absorption =
     (predScore_Creation > 50 ? predScore_Creation * 0.40 : 0.0) +
     (obs_AbsorptionScore > 35 ? obs_AbsorptionScore * 0.30 : 0.0) +
     (m1AbsorptionEmer ? 20.0 : 0.0) +
     (waveProgress >= 60.0 and waveProgress <= 78.0 ? 15.0 : 0.0)

float predScore_Retracement =
     (absorptionBelief > 45 ? absorptionBelief * 0.35 : 0.0) +
     ((direction == 1 and bearMicroImpulse) or (direction == -1 and bullMicroImpulse) ? 25.0 : 0.0) +
     (waveProgress >= 72.0 and waveProgress <= 90.0 ? 20.0 : 0.0) +
     (physicsConsensus < 40 ? 10.0 : 0.0)

float predScore_DemandReturn =
     (retracementBelief > 45 ? retracementBelief * 0.35 : 0.0) +
     (posDistToDemand < 20.0 ? (20.0 - posDistToDemand) * 1.50 : 0.0) +
     (liqSweepBull or liqSweepBear ? 20.0 : 0.0) +
     (waveProgress >= 88.0 ? (waveProgress - 88.0) * 1.20 : 0.0)

float _maxPredScore = math.max(predScore_Expansion, predScore_Convexity, predScore_Creation,
                                predScore_Absorption, predScore_Retracement, predScore_DemandReturn)

string expectedNextPhase =
     predScore_DemandReturn >= predScore_Retracement and predScore_DemandReturn >= predScore_Absorption and
     predScore_DemandReturn >= predScore_Creation    and predScore_DemandReturn >= predScore_Convexity   and
     predScore_DemandReturn >= predScore_Expansion   ? (direction == -1 ? "Supply Return" : "Demand Return") :
     predScore_Retracement  >= predScore_Absorption  and predScore_Retracement >= predScore_Creation    and
     predScore_Retracement  >= predScore_Convexity   and predScore_Retracement >= predScore_Expansion   ? "Retracement"             :
     predScore_Absorption   >= predScore_Creation    and predScore_Absorption  >= predScore_Convexity   and
     predScore_Absorption   >= predScore_Expansion                                                       ? "Absorption"              :
     predScore_Creation     >= predScore_Convexity   and predScore_Creation    >= predScore_Expansion   ? (direction == -1 ? "New Low" : "New High") :
     predScore_Convexity    >= predScore_Expansion                                                       ? "Expansion Pre-Convexity" : "Expansion"

float expectedNextProb = _maxPredScore > 0 ? math.min(_maxPredScore / math.max(_maxPredScore + 30.0, 1.0) * 100.0, 95.0) : 50.0

// ── 12F: VALIDATION ENGINE ────────────────────────────────────────────────────
// Tracks ENGINE 1A canonical phase transition accuracy.
// predTransition fires when IE1A transitions to a new canonical phase.
// predSucceeded when the new IE1A phase matches the previously predicted next phase.

var array<int> predOutcomes = array.new_int(100, 0)
var int        predTotalIdx = 0

var string lastExpectedPhase    = "Point 4 Origin"
var string lastIE1APhase        = "Point 4 Origin"

// Track IE1A phase transitions (not primaryHypothesis)
bool predTransition = ie1a_currentPhase != lastIE1APhase
bool predSucceeded  = predTransition and ie1a_currentPhase == lastExpectedPhase

if predTransition
    array.set(predOutcomes, predTotalIdx % 100, predSucceeded ? 1 : 0)
    predTotalIdx := predTotalIdx + 1

lastExpectedPhase := expectedNextPhase
lastIE1APhase     := ie1a_currentPhase

f_predAcc(int _n) =>
    int   _cnt = math.min(_n, predTotalIdx)
    int   _sum = 0
    int   _start = math.max(0, predTotalIdx - _cnt)
    if _cnt > 0
        for i = _start to predTotalIdx - 1
            _sum := _sum + array.get(predOutcomes, i % 100)
    _cnt > 0 ? _sum / float(_cnt) * 100.0 : 50.0

float predAcc10  = f_predAcc(10)
float predAcc25  = f_predAcc(25)
float predAcc50  = f_predAcc(50)
float predAcc100 = f_predAcc(100)
float predReliability = (predAcc10 * 0.4 + predAcc25 * 0.3 + predAcc50 * 0.2 + predAcc100 * 0.1)

// ── 12G: ADAPTIVE CONFIDENCE ENGINE ──────────────────────────────────────────

var float modelConfidence = 50.0

float confIncrease =
     (predSucceeded                                    ? 3.0  : 0.0) +
     (physicsConsensus > 70                            ? 2.0  : 0.0) +
     (htfAlign == direction and direction != 0         ? 1.5  : 0.0) +
     (dir_tf1 == dir_tf2 and dir_tf1 != 0             ? 1.0  : 0.0)

float confDecrease =
     (predTransition and not predSucceeded             ? 2.0  : 0.0) +
     (physicsDiff > 60                                 ? 2.0  : 0.0) +
     (htfAlign != direction and direction != 0         ? 1.5  : 0.0) +
     (dir_tf1 != dir_tf2 and dir_tf1 != 0 and dir_tf2 != 0 ? 1.0 : 0.0)

modelConfidence := math.max(10.0, math.min(100.0,
     modelConfidence + confIncrease - confDecrease - confDecayRate * (modelConfidence - 50.0)))

// ── 12H: WAVE DEVIATION ENGINE ────────────────────────────────────────────────

float idealExpansionSig  = efficiency
float idealConvSig       = obs_DecayScore / 100.0
float idealAbsSig        = obs_AbsorptionScore / 100.0

float waveDeviationRaw =
     math.abs(idealExpansionSig - (ie1a_hypFamily == "EXPANSION" ? 0.85 : 0.30)) * 40.0 +
     math.abs(idealConvSig      - (ie1a_hypFamily == "CONVEXITY FORMING" ? 0.70 : 0.20)) * 30.0 +
     math.abs(idealAbsSig       - (ie1a_hypFamily == "ABSORPTION" ? 0.70 : 0.15)) * 30.0

float waveDeviation = math.min(waveDeviationRaw * 100.0, 100.0)
bool deviationAlert = waveDeviation > devReinterpThresh

// ── 12I: M1 EARLY WARNING ENGINE ─────────────────────────────────────────────

f_m1Physics(float _c, float _h, float _l) =>
    float _v  = ta.ema(_c - _c[1], 3)
    float _a  = _v - _v[1]
    float _cv = _a - _a[1]
    float _m  = math.abs(_c - _c[effLen])
    float _ps = math.sum(math.abs(_c - _c[1]), effLen)
    float _e  = _ps > 0 ? _m / _ps : 0.0
    float _d  = (_h - _l) / math.max(ta.atr(atrLen), 1e-10)
    bool _mD  = math.abs(_a) < math.abs(_a[1]) * 0.8
    bool _expWeak  = _e < effThresh * 0.7 and _mD
    bool _convEmer = math.abs(_cv) > ta.atr(atrLen) * convMult * 1.5 and _mD
    bool _indEmer  = _e > effThresh and _a < 0 and _v > 0
    bool _liqEmer  = _d > dispThresh * 1.2 and _mD
    bool _absEmer  = _e < effThresh * 0.5 and _d < dispThresh * 0.6
    [_expWeak, _convEmer, _indEmer, _liqEmer, _absEmer]

[m1_expWeak, m1_convEmer, m1_indEmer, m1_liqEmer, m1_absEmer] = request.security(syminfo.tickerid, "1",
    f_m1Physics(close, high, low), lookahead=barmerge.lookahead_off)

bool m1ExpansionWeak   = int(nz(int(m1_expWeak  ? 1 : 0), 0)) != 0
m1ConvexityEmer       := int(nz(int(m1_convEmer ? 1 : 0), 0)) != 0
bool m1InductionEmer   = int(nz(int(m1_indEmer  ? 1 : 0), 0)) != 0
m1LiquidityEmer       := int(nz(int(m1_liqEmer  ? 1 : 0), 0)) != 0
m1AbsorptionEmer      := int(nz(int(m1_absEmer  ? 1 : 0), 0)) != 0

int m1WarningScore =
     (m1ExpansionWeak  ? 1 : 0) +
     (m1ConvexityEmer  ? 1 : 0) +
     (m1InductionEmer  ? 1 : 0) +
     (m1LiquidityEmer  ? 1 : 0) +
     (m1AbsorptionEmer ? 1 : 0)

string m1Warning =
     m1WarningScore >= 4 ? "CRITICAL" :
     m1WarningScore >= 3 ? "HIGH"     :
     m1WarningScore >= 2 ? "MODERATE" :
     m1WarningScore >= 1 ? "LOW"      : "CLEAR"

// ── 12J: MULTI-TIMEFRAME BELIEF STACK ────────────────────────────────────────

float htf_ExpBelief  = math.min((expScr_tf2 * 0.5 + expScr_tf1 * 0.5), 100.0)
float htf_ConvBelief = math.min((decScr_tf2 * 0.4 + curvScr_tf2 * 0.3 + decScr_tf1 * 0.3), 100.0)
float htf_AbsBelief  = math.min((abScr_tf2  * 0.5 + abScr_tf1  * 0.5), 100.0)
float htf_LiqBelief  = math.min((liqScr_tf2 * 0.5 + liqScr_tf1 * 0.5), 100.0)

// htf_PrimaryInterp — DISPLAY ONLY: relays IE1A canonical phase for HTF context row.
// HTF belief scores (htf_ExpBelief etc.) remain available as confidence context metrics
// but do NOT independently assign a lifecycle phase.
string htf_PrimaryInterp = ie1a_currentPhase

// ═══════════════
// SECTION 13 — WAVE SPAWN ENGINE
// ═══════════════

f_spawnWave(int _newDir) =>
    float _obTop    = _newDir == 1 ? lastPivotPrice  : prevPivotPrice
    float _obBot    = _newDir == 1 ? prevPivotPrice  : lastPivotPrice
    int   _anchBar  = prevPivotBar
    float _fzIP     = f_findInducPrice(_anchBar, _obTop, _obBot, inducLookback)
    float _fzL      = not na(_fzIP) ? _fzIP - atr * inducZoneWidth : na
    float _fzH      = not na(_fzIP) ? _fzIP + atr * inducZoneWidth : na
    [_obTop, _obBot, _anchBar, _fzIP, _fzL, _fzH]

bool _hasActiveContext = direction != 0 and not na(flipTop)
bool _isReversal       = (eliteLongImpulse  and direction == -1) or (eliteShortImpulse and direction == 1)
bool _allowSpawn       = (eliteLongImpulse or eliteShortImpulse) and (not _hasActiveContext or _isReversal)

if _allowSpawn
    int _newDir = eliteLongImpulse ? 1 : -1
    [_obTop, _obBot, _anchBar, _fzIP, _fzL, _fzH] = f_spawnWave(_newDir)

    lastSpawnDir       := _newDir
    direction          := _newDir
    flipTop            := _obTop
    flipBot            := _obBot
    barsInZone         := 0
    obBirthBar         := bar_index
    contBar            := na

    point4OriginHigh   := _obTop
    point4OriginLow    := _obBot
    point4OriginBar    := bar_index

    flipzoneInducPrice := _fzIP
    flipzoneInducLow   := _fzL
    flipzoneInducHigh  := _fzH

    inducExpOriginHigh       := na
    inducExpExtremeLow       := na
    inducExpOriginLow        := na
    inducExpExtremeHigh      := na
    inducRetrOriginHigh      := na
    inducRetrExtremeLow      := na
    inducRetrOriginLow       := na
    inducRetrExtremeHigh     := na
    inducZoneLow             := na
    inducZoneHigh            := na
    cycleHigh                := high
    cycleLow                 := low
    isRecursiveWave          := false
    entryCycle               := 0
    waveDepth                := 0

    // ── V72 WAVE REGISTRY: SPAWN HOOK ─────────────────────────────────────────
    int _wr_newId = wr_nextId
    wr_nextId := wr_nextId + 1
    array.push(wr_waveId,       _wr_newId)
    array.push(wr_parentWaveId, wr_activeWaveId)
    array.push(wr_rootWaveId,   _wr_newId)   // root wave (not recursive at spawn)
    array.push(wr_birthBar,     bar_index)
    array.push(wr_deathBar,     -1)
    array.push(wr_spawnPhase,   ie1a_currentPhase)
    array.push(wr_deathPhase,   "")
    array.push(wr_depth,        0)
    wr_activeWaveId  := _wr_newId
    wr_activeParentId := 0
    wr_activeRootId  := _wr_newId
    // Rolling eviction: keep max 50 entries
    if array.size(wr_waveId) > 50
        f_wrEvict()

    if not na(p4Box)
        box.delete(p4Box)
    if showP4Box
        p4Box := box.new(left=_anchBar, top=_obTop, right=bar_index + 300, bottom=_obBot,
             bgcolor=color.new(color.orange, 92),
             border_color=color.new(color.orange, 40),
             border_style=line.style_dotted, border_width=2)
    if not na(p4LineTop)
        line.delete(p4LineTop)
    if not na(p4LineBot)
        line.delete(p4LineBot)
    if showP4Box
        p4LineTop := line.new(x1=_anchBar, y1=_obTop, x2=bar_index + 300, y2=_obTop,
             color=color.new(color.orange, 20), style=line.style_dotted, width=1)
        p4LineBot := line.new(x1=_anchBar, y1=_obBot, x2=bar_index + 300, y2=_obBot,
             color=color.new(color.orange, 20), style=line.style_dotted, width=1)

    if not na(demandBox)
        box.delete(demandBox)
    if not na(supplyBox)
        box.delete(supplyBox)
    if showSDZones
        if _newDir == 1 and (ecvAllLocations or ecvDemand)
            demandBox := box.new(left=_anchBar, top=_obTop, right=bar_index + 300, bottom=_obBot,
                 bgcolor=_cT92,
                 border_color=color.new(color.teal, 30), border_width=1)
        else if _newDir == -1 and (ecvAllLocations or ecvSupply)
            supplyBox := box.new(left=_anchBar, top=_obTop, right=bar_index + 300, bottom=_obBot,
                 bgcolor=_cR92,
                 border_color=color.new(color.red, 30), border_width=1)

    // DIE: POINT 4 ORIGIN label — only render at Priority 90 (not in High density execution mode)
    // In High density Execution mode this is suppressed; medium/low density shows it.
    bool _die_p4_show = displayMode == "Research" or displayMode == "Context"
    if showLabels and entryCycle == 0 and _die_p4_show and (ecvAllLocations or ecvOrigin)
        label.new(bar_index, _newDir == 1 ? low - atr * 0.5 : high + atr * 0.5,
             "POINT 4 ORIGIN",
             style=_newDir == 1 ? label.style_label_up : label.style_label_down,
             textcolor=color.black, color=color.new(color.orange, 30), size=size.tiny)

    bool _originLabelOK = displayMode == "Research" or displayMode == "Context"
    if showOriginShort and _newDir == -1 and _originLabelOK and (ecvAllLocations or ecvOrigin)
        label.new(_anchBar, _obTop + atr * 0.1, "Origin S",
             style=label.style_label_down, textcolor=color.new(color.red, 0),
             color=color.new(color.red, 85), size=size.tiny)
    if showOriginLong and _newDir == 1 and _originLabelOK and (ecvAllLocations or ecvOrigin)
        label.new(_anchBar, _obBot - atr * 0.1, "Origin L",
             style=label.style_label_up, textcolor=color.new(color.teal, 0),
             color=color.new(color.teal, 85), size=size.tiny)

    if not na(flipBox)
        box.delete(flipBox)
    // Section 9: "Imbalance" / "Liquidation" categories gate the flip-zone
    // box visibility (the flip zone represents the liquidation/imbalance
    // retest region). The box object is always created for downstream
    // structure logic; only its visual opacity is affected.
    bool _flipVisible = (ecvAllLocations or ecvImbalance) or (ecvAllLocations or ecvLiquidation)
    flipBox := box.new(left=_anchBar, top=flipTop, right=bar_index + 300, bottom=flipBot,
         bgcolor=_flipVisible ? (_newDir == 1 ? _cT92 : _cR92) : color.new(color.black, 100),
         border_color=_flipVisible ? (_newDir == 1 ? color.teal : color.red) : color.new(color.black, 100), border_width=1)

if direction == 1 and high > nz(cycleHigh, high)
    cycleHigh := high
if direction == -1 and low < nz(cycleLow, low)
    cycleLow := low

bool expInducBuyEv  = direction == 1  and bearImpulse and structBias ==  1
bool expInducSellEv = direction == -1 and bullImpulse and structBias == -1

if expInducBuyEv and na(inducExpOriginHigh)
    inducExpOriginHigh := nz(point4OriginHigh, nz(cycleHigh, high))
    inducExpExtremeLow := low
    inducZoneLow       := nz(point4OriginHigh, low) - atr * inducZoneWidth
    inducZoneHigh      := nz(point4OriginHigh, low) + atr * inducZoneWidth

if expInducSellEv and na(inducExpOriginLow)
    inducExpOriginLow    := nz(point4OriginLow, nz(cycleLow, low))
    inducExpExtremeHigh  := high
    inducZoneLow         := nz(point4OriginLow, high) - atr * inducZoneWidth
    inducZoneHigh        := nz(point4OriginLow, high) + atr * inducZoneWidth

if not na(inducExpExtremeLow) and direction == 1 and low < inducExpExtremeLow
    inducExpExtremeLow := low
    inducZoneLow       := low - atr * inducZoneWidth
    inducZoneHigh      := low + atr * inducZoneWidth

if not na(inducExpExtremeHigh) and direction == -1 and high > inducExpExtremeHigh
    inducExpExtremeHigh := high
    inducZoneLow        := high - atr * inducZoneWidth
    inducZoneHigh       := high + atr * inducZoneWidth

nearFlipzone := not na(flipTop) and not na(flipBot) and
     close <= flipTop * 1.02 and close >= flipBot * 0.98

bool retrInducBuyEv  = direction == 1  and bullImpulse and structBias == -1 and nearFlipzone
bool retrInducSellEv = direction == -1 and bearImpulse and structBias ==  1 and nearFlipzone

if retrInducBuyEv and na(inducRetrOriginLow)
    inducRetrOriginLow   := nz(cycleLow, low)
    inducRetrExtremeHigh := high
    inducZoneLow         := high - atr * inducZoneWidth
    inducZoneHigh        := high + atr * inducZoneWidth

if retrInducSellEv and na(inducRetrOriginHigh)
    inducRetrOriginHigh := nz(cycleHigh, high)
    inducRetrExtremeLow := low
    inducZoneLow        := low - atr * inducZoneWidth
    inducZoneHigh       := low + atr * inducZoneWidth

if not na(inducRetrExtremeHigh) and direction == 1 and high > inducRetrExtremeHigh
    inducRetrExtremeHigh := high
    inducZoneLow         := high - atr * inducZoneWidth
    inducZoneHigh        := high + atr * inducZoneWidth

if not na(inducRetrExtremeLow) and direction == -1 and low < inducRetrExtremeLow
    inducRetrExtremeLow  := low
    inducZoneLow         := low - atr * inducZoneWidth
    inducZoneHigh        := low + atr * inducZoneWidth

closeInside          := not na(flipTop) and close <= flipTop and close >= flipBot
bool priceInDemand   = not na(flipBot) and low < flipBot and
     (not na(point4OriginHigh) and low <= point4OriginHigh)
bool priceInSupply   = not na(flipTop) and high > flipTop and
     (not na(point4OriginLow)  and high >= point4OriginLow)

bool trueCHoCH_bull  = direction ==  1 and priceInDemand and bullImpulse and liqSweepOK
bool trueCHoCH_bear  = direction == -1 and priceInSupply and bearImpulse and liqSweepOK
bool structFlipBull  = direction ==  1 and bullConvShift and structBias == -1
bool structFlipBear  = direction == -1 and bearConvShift and structBias ==  1

bool recursiveTrigger = (trueCHoCH_bull or trueCHoCH_bear or structFlipBull or structFlipBear) and
     (ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return") and
     demandReturnBelief > 40 and direction != 0 and not na(flipTop)

var bool recursiveJustFired = false
var int  recursiveFiredBar  = na

if recursiveTrigger and (na(recursiveFiredBar) or (bar_index - recursiveFiredBar) > resetBars)
    recursiveJustFired := true
    recursiveFiredBar  := bar_index
    recursiveComplete  := true
else
    recursiveJustFired := false

if recursiveJustFired
    f_storeCycleState(math.max(entryCycle, 1), flipTop, flipBot, flipTop, flipBot,
         point4OriginHigh, point4OriginLow, point4OriginBar, direction)

    waveGeneration  := waveGeneration + 1
    entryCycle      := math.min(entryCycle + 1, 4)
    isRecursiveWave := true
    waveDepth       := entryCycle

    int _nextDir = (bullImpulse or bullConvShift) ? 1 : -1
    [_obTop2, _obBot2, _anchBar2, _fzIP2, _fzL2, _fzH2] = f_spawnWave(_nextDir)

    lastSpawnDir       := _nextDir
    direction          := _nextDir
    flipTop            := _obTop2
    flipBot            := _obBot2
    barsInZone         := 0
    obBirthBar         := bar_index

    point4OriginHigh   := _obTop2
    point4OriginLow    := _obBot2
    point4OriginBar    := bar_index

    flipzoneInducPrice := _fzIP2
    flipzoneInducLow   := _fzL2
    flipzoneInducHigh  := _fzH2

    inducExpOriginHigh     := na
    inducExpExtremeLow     := na
    inducExpOriginLow      := na
    inducExpExtremeHigh    := na
    inducRetrOriginHigh    := na
    inducRetrExtremeLow    := na
    inducRetrOriginLow     := na
    inducRetrExtremeHigh   := na
    inducZoneLow           := na
    inducZoneHigh          := na
    cycleHigh              := high
    cycleLow               := low
    contBar                := bar_index

    // ── V72 WAVE REGISTRY: RECURSIVE SPAWN HOOK ──────────────────────────────
    int _wr_recId = wr_nextId
    wr_nextId := wr_nextId + 1
    array.push(wr_waveId,       _wr_recId)
    array.push(wr_parentWaveId, wr_activeWaveId)
    array.push(wr_rootWaveId,   wr_activeRootId)
    array.push(wr_birthBar,     bar_index)
    array.push(wr_deathBar,     -1)
    array.push(wr_spawnPhase,   ie1a_currentPhase)
    array.push(wr_deathPhase,   "")
    array.push(wr_depth,        entryCycle)
    wr_activeParentId := wr_activeWaveId
    wr_activeWaveId   := _wr_recId
    if array.size(wr_waveId) > 50
        array.shift(wr_waveId)
        array.shift(wr_parentWaveId)
        array.shift(wr_rootWaveId)
        array.shift(wr_birthBar)
        array.shift(wr_deathBar)
        array.shift(wr_spawnPhase)
        array.shift(wr_deathPhase)
        array.shift(wr_depth)

    if not na(p4Box)
        box.delete(p4Box)
    if showP4Box
        p4Box := box.new(left=_anchBar2, top=_obTop2, right=bar_index + 300, bottom=_obBot2,
             bgcolor=color.new(color.orange, 92),
             border_color=color.new(color.orange, 40),
             border_style=line.style_dotted, border_width=2)
    if not na(p4LineTop)
        line.delete(p4LineTop)
    if not na(p4LineBot)
        line.delete(p4LineBot)
    if showP4Box
        p4LineTop := line.new(x1=_anchBar2, y1=_obTop2, x2=bar_index + 300, y2=_obTop2,
             color=color.new(color.orange, 20), style=line.style_dotted, width=1)
        p4LineBot := line.new(x1=_anchBar2, y1=_obBot2, x2=bar_index + 300, y2=_obBot2,
             color=color.new(color.orange, 20), style=line.style_dotted, width=1)

    if not na(demandBox)
        box.delete(demandBox)
    if not na(supplyBox)
        box.delete(supplyBox)
    if showSDZones
        if _nextDir == 1 and (ecvAllLocations or ecvDemand)
            demandBox := box.new(left=_anchBar2, top=_obTop2, right=bar_index + 300, bottom=_obBot2,
                 bgcolor=_cT92,
                 border_color=color.new(color.teal, 30), border_width=1)
        else if _nextDir == -1 and (ecvAllLocations or ecvSupply)
            supplyBox := box.new(left=_anchBar2, top=_obTop2, right=bar_index + 300, bottom=_obBot2,
                 bgcolor=_cR92,
                 border_color=color.new(color.red, 30), border_width=1)

    // DIE: Entry Cycle label now rendered by Display Intelligence Engine (DIE-8)
    // Original label suppressed here — size-scaled, quality-scored label fires in DIE-8
    // if showLabels
    //     label.new(bar_index, _nextDir == 1 ? low - atr * 0.5 : high + atr * 0.5,
    //          "ENTRY CYCLE " + str.tostring(entryCycle),
    //          style=_nextDir == 1 ? label.style_label_up : label.style_label_down,
    //          textcolor=color.black, color=color.new(#00ff88, 30), size=size.tiny)

    if not na(flipBox)
        box.delete(flipBox)
    bool _flipVisible2 = (ecvAllLocations or ecvImbalance) or (ecvAllLocations or ecvLiquidation)
    flipBox := box.new(left=_anchBar2, top=flipTop, right=bar_index + 300, bottom=flipBot,
         bgcolor=_flipVisible2 ? (_nextDir == 1 ? _cT92 : _cR92) : color.new(color.black, 100),
         border_color=_flipVisible2 ? (_nextDir == 1 ? color.teal : color.red) : color.new(color.black, 100), border_width=1)

var float retestHigh = na
var float retestLow  = na

// IE1A authority: gate on canonical Demand Return / Supply Return phases
if ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return"
    barsInZone := closeInside ? barsInZone + 1 : 0
    if barsInZone >= acceptBars
        retestHigh := _g_highestAB
        retestLow  := _g_lowestAB

int  barsSinceCont = not na(contBar) ? bar_index - contBar : (not na(obBirthBar) ? bar_index - obBirthBar : 0)
bool bullInvalid   = direction ==  1 and close < flipBot - atr * 0.5
bool bearInvalid   = direction == -1 and close > flipTop + atr * 0.5
bool opposingMove  = (direction ==  1 and bearImpulse) or (direction == -1 and bullImpulse)
bool safeToReset   = barsSinceCont > resetBars and (opposingMove or bullInvalid or bearInvalid) and
     (ie1a_currentPhase != "Demand Return" and ie1a_currentPhase != "Supply Return") and
     demandReturnBelief < 30 and expansionBelief < 30 and
     not erf_suppressRotation   // ERF: suppress reset when active dissipation is occurring

// ── V72 WAVE REGISTRY: DEATH HOOK (must fire BEFORE safeToReset clears state) ──
if direction != 0 and safeToReset and wr_activeWaveId > 0
    int _wr_dyingIdx = array.indexof(wr_waveId, wr_activeWaveId)
    if _wr_dyingIdx >= 0
        array.set(wr_deathBar,   _wr_dyingIdx, bar_index)
        array.set(wr_deathPhase, _wr_dyingIdx, ie1a_currentPhase)

if direction != 0 and safeToReset
    direction              := 0
    lastSpawnDir           := 0
    flipTop                := na
    flipBot                := na
    contBar                := na
    obBirthBar             := na
    barsInZone             := 0
    isRecursiveWave        := false
    entryCycle             := 0
    waveDepth              := 0
    recursiveComplete      := false
    if not na(flipBox)
        box.delete(flipBox)
        flipBox := na
    if not na(p4Box)
        box.delete(p4Box)
        p4Box := na
    if not na(p4LineTop)
        line.delete(p4LineTop)
        p4LineTop := na
    if not na(p4LineBot)
        line.delete(p4LineBot)
        p4LineBot := na
    if not na(demandBox)
        box.delete(demandBox)
        demandBox := na
    if not na(supplyBox)
        box.delete(supplyBox)
        supplyBox := na

// ═══════════════
// SECTION 14 — INDUCTION ZONE CLASSIFICATION
// ═══════════════

bool inRetracementInducZone = not na(pivL) and not na(inducZoneLow) and not na(inducZoneHigh) and
     direction ==  1 and pivL >= inducZoneLow and pivL <= inducZoneHigh and retrInducBuyEv

bool inShortRetrInducZone = not na(pivH) and not na(inducZoneLow) and not na(inducZoneHigh) and
     direction == -1 and pivH >= inducZoneLow and pivH <= inducZoneHigh and retrInducSellEv

bool inExpansionInducZone = not na(pivH) and not na(inducZoneLow) and not na(inducZoneHigh) and
     direction ==  1 and pivH >= inducZoneLow and pivH <= inducZoneHigh and expInducBuyEv

bool inShortExpInducZone = not na(pivL) and not na(inducZoneLow) and not na(inducZoneHigh) and
     direction == -1 and pivL >= inducZoneLow and pivL <= inducZoneHigh and expInducSellEv

float inducConfidence = 0.0
if direction ==  1 and inRetracementInducZone
    inducConfidence := 1.0
else if direction ==  1 and not na(pivL) and not na(flipTop) and not na(flipBot) and
     pivL < flipTop and pivL > flipBot and not inRetracementInducZone
    inducConfidence := -0.5
else if direction == -1 and inShortRetrInducZone
    inducConfidence := 1.0
else if direction == -1 and not na(pivH) and not na(flipTop) and not na(flipBot) and
     pivH > flipBot and pivH < flipTop and not inShortRetrInducZone
    inducConfidence := -0.5

if showInducLabels and (ecvAllLocations or ecvInduction) and not na(pivH) and not na(flipTop) and not na(flipBot) and
     pivH > flipBot and pivH < flipTop and direction == -1 and
     (retrInducSellEv or nearFlipzone)
    label.new(bar_index, high + atr * 0.25,
         inShortRetrInducZone ? "Retracement Induction ✓" : "False CHoCH",
         style=label.style_label_down,
         textcolor=inShortRetrInducZone ? color.lime : color.red,
         color=color.new(color.white, 92), size=size.tiny)

if showInducLabels and (ecvAllLocations or ecvInduction) and not na(pivL) and not na(flipTop) and not na(flipBot) and
     pivL < flipTop and pivL > flipBot and direction == 1 and
     (retrInducBuyEv or nearFlipzone)
    label.new(bar_index, low - atr * 0.25,
         inRetracementInducZone ? "Retracement Induction ✓" : "False CHoCH",
         style=label.style_label_up,
         textcolor=inRetracementInducZone ? color.lime : color.red,
         color=color.new(color.white, 92), size=size.tiny)

bool expansionPreConvSeen     = preConvEvidence and obs_DecayScore > 30
bool expansionInductionConf   = inductionEvidence
bool retracementPreConvSeen   = nearFlipzone and (bullMomDecay or bearMomDecay)
bool retracementInductionConf = inRetracementInducZone or inShortRetrInducZone
bool expConvFormationActive   = convexityBelief > 40 and expansionBelief > 30
bool retrConvFormationActive  = convexityBelief > 40 and retracementBelief > 40
bool convexityComplete        = creationBelief > 50 or absorptionBelief > 40

int flipzoneStagesComplete =
     demandReturnBelief > 75 and recursiveComplete ? 5 :
     demandReturnBelief > 60 ? 4 :
     retracementBelief  > 55 ? 3 :
     retracementInductionConf ? 2 :
     retracementPreConvSeen   ? 1 : 0

float flipzoneScore = flipzoneStagesComplete / 5.0 * 100.0

// ═══════════════
// V72 — INVALIDATION ENGINE (IE2)
// Pre-calculates stop-loss price levels for each trade thesis.
// Authority: inv_* variables. Does NOT assign lifecycle phases.
// Reads existing bullInvalid/bearInvalid + flipBot/flipTop/point4Origin*.
// ═══════════════

float inv_bullOriginPrice = not na(point4OriginLow)  ? point4OriginLow  - atr * invOriginBuffer : na
float inv_bearOriginPrice = not na(point4OriginHigh) ? point4OriginHigh + atr * invOriginBuffer : na
float inv_demandFailPrice = direction == 1  and not na(flipBot) ? flipBot - atr * invZoneBuffer : na
float inv_supplyFailPrice = direction == -1 and not na(flipTop) ? flipTop + atr * invZoneBuffer : na

float inv_activeStop = direction == 1 ?
     nz(inv_demandFailPrice, inv_bullOriginPrice) :
     direction == -1 ?
     nz(inv_supplyFailPrice, inv_bearOriginPrice) : na

bool  inv_invalidated = not na(inv_activeStop) and
     (direction == 1 ? close < inv_activeStop : close > inv_activeStop)

float inv_riskInPts = not na(inv_activeStop) ? math.abs(close - inv_activeStop) : na
float inv_riskInATR = not na(inv_riskInPts) and atr > 0 ? inv_riskInPts / atr : na

// ═══════════════
// V72 — TARGET ENGINE (TE) — Forward Declarations
// FRZ-based computation moved to post-FRZ section (line 5926+).
// Var declarations persist across bars; entry signals use previous bar's values.
// ═══════════════

var float te_tp1 = na
var float te_tp2 = na
var float te_tp3 = na
var float te_rr_tp1 = na
var float te_rr_tp2 = na
var float te_rr_tp3 = na
var bool  te_rrGate = true   // defaults true — does not block when no TP computed yet

// ═══════════════
// SECTION 15 — SCORING ENGINE
// ═══════════════

float poiMid   = not na(flipTop) and not na(flipBot) ? (flipTop + flipBot) / 2.0 : na
float energy   = not na(poiMid) ? math.abs(close - poiMid) / math.max(atr, 1e-10) : 0.0

float sStruct  = flipzoneScore * 0.30
float sConv    = math.min(math.abs(convSmooth) / math.max(atr * convMult, 1e-10) * 25.0, 25.0)
float sEnergy  = math.min(energy * 10.0, 20.0)
float sEff     = efficiency * 15.0
float sVol     = math.min((atr / math.max(close, 1e-10)) * 1000.0, 10.0)
float contProb = math.min(sStruct + sConv + sEnergy + sEff + sVol, 100.0)

string grade    = contProb > 90 ? "A+" : contProb > 80 ? "A" : contProb > 70 ? "B" : contProb > 60 ? "C" : "D"
color  gradeCol = grade == "A+" ? #00ff88 : grade == "A" ? color.lime : grade == "B" ? color.yellow : grade == "C" ? color.orange : color.red

// ═══════════════
// SECTION 16 — BAYESIAN PROBABILISTIC MODEL
// ═══════════════

float bayesStruct   = structBias == direction ? 0.90 : structBias == 0 ? 0.50 : 0.15
float bayesMomentum = (direction ==  1 and velocity > 0 and acceleration > 0) ? 0.85 :
                      (direction == -1 and velocity < 0 and acceleration < 0) ? 0.85 :
                      (direction ==  1 and velocity > 0) or
                      (direction == -1 and velocity < 0) ? 0.60 : 0.30
float bayesLiq      = liqHeat > 70 ? 0.80 : liqHeat > 30 ? 0.55 : 0.35
float bayesHTF      = htfAlign == direction ? 0.90 : htfAlign == 0 ? 0.55 : 0.20
float bayesDisp     = displacement > dispThresh * 1.5 ? 0.85 : displacement > dispThresh ? 0.65 : 0.35
float bayesOB       = obFreshness > 0.7 ? 0.80 : obFreshness > 0.4 ? 0.60 : 0.35
float bayesInduc    = inducConfidence > 0 ? 0.90 : inducConfidence < 0 ? 0.20 : 0.50
float bayesFlipzone = flipzoneStagesComplete >= 4 ? 0.92 :
                      flipzoneStagesComplete >= 3 ? 0.75 :
                      flipzoneStagesComplete >= 2 ? 0.58 :
                      flipzoneStagesComplete >= 1 ? 0.42 : 0.25

float w1 = 0.15
float w2 = 0.14
float w3 = 0.10
float w4 = 0.14
float w5 = 0.11
float w6 = 0.07
float w7 = 0.12
float w8 = 0.17

float logOdds =
     w1 * math.log(math.max(bayesStruct,   1e-10) / math.max(1.0 - bayesStruct,   1e-10)) +
     w2 * math.log(math.max(bayesMomentum, 1e-10) / math.max(1.0 - bayesMomentum, 1e-10)) +
     w3 * math.log(math.max(bayesLiq,      1e-10) / math.max(1.0 - bayesLiq,      1e-10)) +
     w4 * math.log(math.max(bayesHTF,      1e-10) / math.max(1.0 - bayesHTF,      1e-10)) +
     w5 * math.log(math.max(bayesDisp,     1e-10) / math.max(1.0 - bayesDisp,     1e-10)) +
     w6 * math.log(math.max(bayesOB,       1e-10) / math.max(1.0 - bayesOB,       1e-10)) +
     w7 * math.log(math.max(bayesInduc,    1e-10) / math.max(1.0 - bayesInduc,    1e-10)) +
     w8 * math.log(math.max(bayesFlipzone, 1e-10) / math.max(1.0 - bayesFlipzone, 1e-10))

float finalProb = 1.0 / (1.0 + math.exp(-logOdds)) * 100.0

// ═══════════════
// SECTION 17 — PROBABILITY PANELS
// ═══════════════

float velDecay = math.abs(velocity) < math.abs(velocity[1]) * 0.7 ? 1.0 : 0.0

float expansionProbability = math.min(
     (not bullInvalid and not bearInvalid ? 20.0 : 0.0) +
     (convexityComplete                  ? 20.0 : convexityScore * 0.4) +
     (recursiveComplete                  ? 15.0 : flipzoneStagesComplete * 3.0) +
     (htfAlign == direction              ? 25.0 : htfAlign == 0 ? 12.5 : 0.0) +
     (liqHeat > 50                       ? 20.0 : liqHeat * 0.4),
     100.0)

float reversalProbability = math.min(
     (convexityScore > 70             ? 25.0 : convexityScore * 0.35) +
     (retracementInductionConf        ? 20.0 : 0.0) +
     (liqHeat > 70                    ? 20.0 : 0.0) +
     (velDecay * 20.0) +
     (htfAlign != direction and htfAlign != 0 ? 15.0 : 0.0),
     100.0)

float tradeReadiness = math.min(
     (direction != 0                     ? 10.0 : 0.0) +
     (flipzoneStagesComplete >= 3        ? 15.0 : flipzoneStagesComplete * 5.0) +
     (velocityScore * 0.10) +
     (expansionScore * 0.10) +
     (liqHeat < 50                       ? 10.0 : liqHeat > 70 ? -5.0 : 0.0) +
     (htfAlign == direction              ? 15.0 : 0.0) +
     (expansionProbability * 0.20) +
     (bayesFlipzone * 3.0),
     100.0)


// ─── SECTION 6 / 15 — DIRECTION OWNERSHIP HELPERS ─────────────────────────────
// Every wave-state display must explicitly identify Buyers (Bull) or Sellers
// (Bear). Uses ONLY the existing `direction`, `dir_tf1`, `dir_tf2` bias
// variables — no new directional calculations are introduced.
//
// Mapping (per spec Section 6):
//   Expansion       -> Bull/Bear Expansion
//   Absorption      -> Bull/Bear Absorption
//   Pre-Convexity   -> Bull/Bear Pre-Convexity
//   Convexity       -> Bull/Bear Convexity
//   Demand Return   -> Bull Demand Return
//   Supply Return   -> Bear Supply Return
//   (all other state names pass through unchanged)
f_dirOwner(int dir) =>
    dir == 1 ? "Bull" : dir == -1 ? "Bear" : "Neutral"

f_applyDirection(string phase, int dir) =>
    string _own = f_dirOwner(dir)
    string _out = phase
    if phase == "Expansion" or phase == "EXPANSION"
        _out := _own + " Expansion"
    else if phase == "Absorption" or phase == "ABSORPTION"
        _out := _own + " Absorption"
    else if phase == "Pre-Convexity"
        _out := _own + " Pre-Convexity"
    else if phase == "Demand Return" or phase == "DEMAND/SUPPLY RETURN"
        _out := dir == -1 ? "Bear Supply Return" : "Bull Demand Return"
    else if phase == "Supply Return"
        _out := "Bear Supply Return"
    else if phase == "Convexity" or phase == "CONVEXITY FORMING"
        _out := _own + " Convexity"
    _out

// ═══════════════
// SECTION 18 — SLIPPAGE & TRADE OPPORTUNITY ENGINE
// ═══════════════

float spreadEstimate   = atr * 0.05
float volatilityFactor = volRatio * 0.10
float slippageCost     = atr * volatilityFactor + spreadEstimate
float liqDepthPenalty  = liqHeat > 70 ? atr * 0.05 : 0.0
float totalSlippage    = slippageCost + liqDepthPenalty

float baseTrend     = efficiency * 30
float impulseScore  = displacement > dispThresh ? 20 : 0
float momentum      = velocity - velocity[1]
float momentumScore = momentum > 0 ? 10 : -10
float accelScore    = acceleration > 0 ? 10 : -10
float structScore   = structBias == 1 ? 20 : structBias == -1 ? -20 : 0
float htfScore      = htfAlign == 1 ? 20 : htfAlign == -1 ? -20 : 0
float liqScore      = wDensity < 0.5 ? 10 : -5
float zoneScore     = closeInside ? 15 : 0
float inducScore    = inducConfidence > 0 ? 10 : inducConfidence < 0 ? -10 : 0
float fzStageScore  = flipzoneStagesComplete * 6.0
float beliefBonus   = (direction == 1  and demandReturnBelief > 60) ? demandReturnBelief * 0.10 :
                      (direction == -1 and demandReturnBelief > 60) ? demandReturnBelief * 0.10 : 0.0
float confMult      = math.max(0.7, math.min(modelConfidence / 100.0 * 1.3, 1.3))

float buyScore =
     (baseTrend + impulseScore +
     math.max(momentumScore, 0) + math.max(accelScore, 0) +
     math.max(structScore, 0)   + math.max(htfScore, 0) +
     liqScore + zoneScore + math.max(inducScore, 0) + fzStageScore + beliefBonus) * confMult

float sellScore =
     (baseTrend + impulseScore +
     math.max(-momentumScore, 0) + math.max(-accelScore, 0) +
     math.max(-structScore, 0)   + math.max(-htfScore, 0) +
     liqScore + zoneScore + math.max(-inducScore, 0) + fzStageScore + beliefBonus) * confMult

float netEdge         = buyScore - sellScore
float netEdgeAdjusted = netEdge - (totalSlippage / math.max(atr, 1e-10) * 10.0)
bool  edgePassesFilter = math.abs(netEdgeAdjusted) > execThreshold

float BUY_SELL_SCORE_MAX = 240.5  // true theoretical max of buyScore/sellScore incl. confMult<=1.3
float buyProb  = math.min(math.max(buyScore  / BUY_SELL_SCORE_MAX * 100.0, 0.0), 100.0)
float sellProb = math.min(math.max(sellScore / BUY_SELL_SCORE_MAX * 100.0, 0.0), 100.0)

string liveDirective =
     netEdgeAdjusted > 25  ? "BUY PRESSURE"   :
     netEdgeAdjusted > 10  ? "BULLISH BIAS"   :
     netEdgeAdjusted < -25 ? "SELL PRESSURE"  :
     netEdgeAdjusted < -10 ? "BEARISH BIAS"   : "NEUTRAL / WAIT"

// ═══════════════
// SECTION 19 — HTF ALIGNMENT GATE
// ═══════════════

bool htfAligned = direction != 0 and (htfAlign == direction or htfAlign == 0)
int resonance = htfAligned ? 2 : 1

// ═══════════════
// SECTION 20 — ADAPTIVE EXECUTION LOCK
// ═══════════════

var int  lastSignalBar = na
var int  lastLongBar   = na
var int  lastShortBar  = na
var bool engineArmed   = true

int dynamicLockBars = math.round(baseLockBars * volMult)

bool inducRearmLong  = direction ==  1 and inRetracementInducZone
bool inducRearmShort = direction == -1 and inShortRetrInducZone

if recursiveJustFired
    engineArmed := true
if inducRearmLong or inducRearmShort
    engineArmed := true

bool withinGlobalLock = not na(lastSignalBar) and (bar_index - lastSignalBar) < dynamicLockBars
bool withinLongLock   = not na(lastLongBar)   and (bar_index - lastLongBar)   < dynamicLockBars
bool withinShortLock  = not na(lastShortBar)  and (bar_index - lastShortBar)  < dynamicLockBars
bool signalLocked     = withinGlobalLock and not engineArmed

bool htfLongOK  = not requireHTFAlign or (htfBias1 >= 0 and htfBias2 >= 0)
bool htfShortOK = not requireHTFAlign or (htfBias1 <= 0 and htfBias2 <= 0)

bool preConvOK_long  = not requirePreConv   or retracementPreConvSeen
bool preConvOK_short = not requirePreConv   or retracementPreConvSeen
bool inducOK_long    = not requireInduction or retracementInductionConf
bool inducOK_short   = not requireInduction or retracementInductionConf

// ═══════════════
// SECTION 21 — ENTRY SIGNALS
// ═══════════════

bool gradeOK = useStrictStructure ?
     (grade == "A+" or grade == "A" or grade == "B") :
     (grade == "A+" or grade == "A" or grade == "B" or grade == "C")

// Entry signals gate on IE1A canonical phase (Engine 1A is sole lifecycle authority).
// beliefEntryLong/Short additionally require the IE1A Demand Return / Supply Return phase
// to be confirmed, ensuring belief scores serve as confidence context only.
bool beliefEntryLong  = direction == 1  and
     (ie1a_currentPhase == "Demand Return") and
     demandReturnBelief > 50 and
     expansionBelief < 60 and absorptionBelief > 25
bool beliefEntryShort = direction == -1 and
     (ie1a_currentPhase == "Supply Return") and
     demandReturnBelief > 50 and
     expansionBelief < 60 and absorptionBelief > 25

bool longSignal = showSignals and beliefEntryLong and
     htfAligned and gradeOK and
     not signalLocked and not withinLongLock and
     edgePassesFilter and
     preConvOK_long and inducOK_long and
     structLongOK and liqSweepOK and obFresh and htfLongOK and
     erf_entryGate and te_rrGate and not inv_invalidated

bool shortSignal = showSignals and beliefEntryShort and
     htfAligned and gradeOK and
     not signalLocked and not withinShortLock and
     edgePassesFilter and
     preConvOK_short and inducOK_short and
     structShortOK and liqSweepOK and obFresh and htfShortOK and
     erf_entryGate and te_rrGate and not inv_invalidated

if longSignal
    lastSignalBar := bar_index
    lastLongBar   := bar_index
    engineArmed   := false

if shortSignal
    lastSignalBar := bar_index
    lastShortBar  := bar_index
    engineArmed   := false

plotshape(longSignal,  "Long Entry",  shape.triangleup,   location.belowbar, color.teal, size=size.normal)
plotshape(shortSignal, "Short Entry", shape.triangledown, location.abovebar, color.red,  size=size.normal)

if longSignal or shortSignal
    label.new(
         bar_index,
         longSignal ? low - atr * 0.7 : high + atr * 0.7,
         grade + " | " + str.tostring(math.round(finalProb)) + "%",
         style     = longSignal ? label.style_label_up : label.style_label_down,
         color     = gradeCol,
         textcolor = color.black,
         size      = size.small)

// ═══════════════
// SECTION 22 — WAVE INTELLIGENCE LABELS ON CHART
// Priority 80 — Market Context. Gated by DIE density. Narrative Engine (DIE-6)
// renders the single active narrative instead of stacking these.
// ═══════════════

// Track IE1A canonical phase changes (sole lifecycle authority).
// hypothesisChanged: true when ENGINE 1A transitions to a new canonical phase.
var string prevHypothesis = "Point 4 Origin"
bool hypothesisChanged = ie1a_currentPhase != prevHypothesis
prevHypothesis := ie1a_currentPhase

// In Execution mode these are suppressed entirely (Narrative Engine handles it).
// In Context/Research mode we show them compressed.
bool _die_showHypLabel = displayMode == "Research" or
     (displayMode == "Context" and hypothesisChanged and direction != 0)

if _die_showHypLabel
    color phLabelCol =
         ie1a_currentPhase == "Expansion"                  ? color.lime    :
         ie1a_currentPhase == "Expansion Pre-Convexity" or ie1a_currentPhase == "Expansion Induction" or ie1a_currentPhase == "Expansion Liquidity" ? #c084fc :
         ie1a_currentPhase == "New High" or ie1a_currentPhase == "New Low"    ? #00ff88       :
         ie1a_currentPhase == "Absorption"                ? color.aqua    :
         ie1a_currentPhase == "Retracement" or ie1a_currentPhase == "Retracement Pre-Convexity" or ie1a_currentPhase == "Retracement Induction" or ie1a_currentPhase == "Retracement Liquidity" ? color.silver :
         color.orange

    bool isUp = direction == 1
    label.new(bar_index,
         isUp ? low - atr * 0.3 : high + atr * 0.3,
         l0_currentPhase + " " + str.tostring(math.round(primaryHypothesisConf)) + "%",
         style      = isUp ? label.style_label_up : label.style_label_down,
         textcolor  = color.black,
         color      = color.new(phLabelCol, 25),
         size       = size.tiny)

// ═══════════════
// SECTION 23 — INDUCEMENT ZONE BANDS
// ═══════════════

float shortBandLow  = direction == -1 ? inducZoneLow  : na
float shortBandHigh = direction == -1 ? inducZoneHigh : na
float longBandLow   = direction ==  1 ? inducZoneLow  : na
float longBandHigh  = direction ==  1 ? inducZoneHigh : na

sIndL = plot(showInducZone ? shortBandLow  : na, "Short Induc Low",  color=color.new(color.red,  75), linewidth=1)
sIndH = plot(showInducZone ? shortBandHigh : na, "Short Induc High", color=color.new(color.red,  75), linewidth=1)
lIndL = plot(showInducZone ? longBandLow   : na, "Long Induc Low",   color=color.new(color.teal, 75), linewidth=1)
lIndH = plot(showInducZone ? longBandHigh  : na, "Long Induc High",  color=color.new(color.teal, 75), linewidth=1)

fill(sIndL, sIndH, color=color.new(color.red,  88))
fill(lIndL, lIndH, color=color.new(color.teal, 88))

float fzInducPlotLow  = not na(flipzoneInducLow)  ? flipzoneInducLow  : na
float fzInducPlotHigh = not na(flipzoneInducHigh) ? flipzoneInducHigh : na

fzL = plot(showInducZone ? fzInducPlotLow  : na, "FZ Trap Low",  color=color.new(color.purple, 65), linewidth=1, style=plot.style_circles)
fzH = plot(showInducZone ? fzInducPlotHigh : na, "FZ Trap High", color=color.new(color.purple, 65), linewidth=1, style=plot.style_circles)
fill(fzL, fzH, color=color.new(color.purple, 92))

// ═══════════════
// SECTION 24 — TRADE STATE ENGINE
// ═══════════════

var int tradeDir = 0
var int exitFiredBar = na

bool exitCondition =
     (tradeDir ==  1 and bearBOS) or
     (tradeDir == -1 and bullBOS) or
     (tradeDir ==  1 and bearConvShift and energy < energy[1]) or
     (tradeDir == -1 and bullConvShift and energy < energy[1]) or
     (tradeDir ==  1 and htfAlign == -1) or
     (tradeDir == -1 and htfAlign ==  1) or
     (tradeDir != 0  and not obFresh) or
     (tradeDir != 0  and safeToReset) or
     (tradeDir ==  1 and bullInvalid) or
     (tradeDir == -1 and bearInvalid) or
     // IE1A phase gate: exit when IE1A transitions to Absorption or Retracement
     (tradeDir ==  1 and (ie1a_currentPhase == "Absorption" or ie1a_currentPhase == "Retracement")) or
     (tradeDir == -1 and (ie1a_currentPhase == "Absorption" or ie1a_currentPhase == "Retracement"))

if longSignal
    tradeDir     := 1
    exitFiredBar := na
else if shortSignal
    tradeDir     := -1
    exitFiredBar := na
else if exitCondition and tradeDir != 0
    exitFiredBar := bar_index
    tradeDir     := 0

bool exitLatchActive = not na(exitFiredBar) and (bar_index - exitFiredBar) < 3

string directiveStr =
     longSignal                        ? "BUY  (ENTER LONG)"    :
     shortSignal                       ? "SELL  (ENTER SHORT)"  :
     exitLatchActive                   ? "EXIT NOW"             :
     tradeDir ==  1                    ? "HOLD LONG"            :
     tradeDir == -1                    ? "HOLD SHORT"           : "NO TRADE / STAND DOWN"

color directiveCol =
     longSignal                        ? #00ff88      :
     shortSignal                       ? #ff1744      :
     exitLatchActive                   ? color.orange :
     tradeDir ==  1                    ? color.lime   :
     tradeDir == -1                    ? color.red    : color.gray

color directiveBg =
     longSignal                        ? color.new(#00ff88,     75) :
     shortSignal                       ? color.new(#ff1744,     75) :
     exitLatchActive                   ? color.new(color.orange,75) :
     tradeDir ==  1                    ? color.new(color.lime,  85) :
     tradeDir == -1                    ? color.new(color.red,   85) : color.new(color.gray, 88)

// ═══════════════
// SECTION 26 — DISPLAY INTELLIGENCE ENGINE (DIE)
// Visual-layer only. Zero changes to any detection, logic, or calculation above.
// ═══════════════

// ── DIE-1: DISPLAY DENSITY ENGINE ────────────────────────────────────────────
// Count labels placed in the last 100 bars as a proxy for density.
// We use a running var counter that increments when we place a label this bar
// and we sample a look-back sum periodically.

var int  die_labelCount   = 0        // labels placed this bar (reset each bar)
var int  die_totalLabels  = 0        // rolling total
var array<int> die_barCounts = array.new_int(100, 0)

// Rotate the ring-buffer
array.set(die_barCounts, bar_index % 100, die_labelCount)
int die_density100 = array.sum(die_barCounts)    // labels per 100 bars

string die_densityLevel =
     die_density100 < 30  ? "Low"    :
     die_density100 < 80  ? "Medium" : "High"

// Helper: should we show objects at a given priority given current density?
f_die_show(int _priority) =>
    bool _ok = false
    if displayMode == "Research"
        _ok := true
    else if displayMode == "Context"
        _ok := _priority >= 60
    else
        // Execution mode — only highest-priority objects render
        if die_densityLevel == "Low"
            _ok := _priority >= 80
        else
            _ok := _priority >= 100
    _ok


// Reset label counter each bar (approximate — we track at render time)
die_labelCount := 0

// ── DIE-2: FU ORDER BLOCK ENGINE ─────────────────────────────────────────────
// Detects Bull and Bear FU candles, tracks lifecycle, renders zones + labels.
// NO changes to any detection variables used elsewhere (fuBoostBelief etc).

var array<float>  fu_top        = array.new_float ()
var array<float>  fu_bot        = array.new_float ()
var array<int>    fu_birthBar   = array.new_int   ()
var array<int>    fu_dir        = array.new_int   ()   // 1=bull, -1=bear
var array<string> fu_state      = array.new_string()   // Fresh/Active/Interacting/Exhausted/Invalidated
var array<box>    fu_boxes      = array.new<box>  ()
var array<label>  fu_labels     = array.new<label>()

// FU candle detection (display-only — detection mirrors existing fuDetect logic pattern)
// BEAR FU supply zone characteristics (from screenshot analysis):
//   1. Large bearish body (fuMinBodyRatio of range)
//   2. Upper wick present (liquidity grab above)
//   3. Gap leaving the candle at the top — close[0] has a gap below it relative to open[1]
//      i.e. the NEXT bar's open is below this bar's body close = price doesn't return
//   4. Liquidity left to the left — a prior high that was swept
// BULL FU demand zone characteristics (mirror):
//   1. Large bullish body
//   2. Lower wick (liquidity grab below)
//   3. Gap leaving upward — next bar opens above close or body
//   4. Liquidity left below (prior low swept)
//
// fuRequireInZone is used as a BOOST filter, not a hard gate, so zones form
// at genuine structural supply/demand regardless of whether price is in the flipzone.

float fuRange     = high - low
float fuBody      = math.abs(close - open)
float fuUpperWick = high - math.max(open, close)
float fuLowerWick = math.min(open, close) - low

// Gap-leave detection: the bar AFTER the FU candle opens with a gap
// (checked on the PREVIOUS bar since current bar is the one after the FU)
float prevBody      = math.abs(close[1] - open[1])
float prevRange     = high[1] - low[1]
float prevUpperWick = high[1] - math.max(open[1], close[1])
float prevLowerWick = math.min(open[1], close[1]) - low[1]
float prevBodyRatio = prevRange > 1e-10 ? prevBody / prevRange : 0.0
float prevUpperWickRatio = prevRange > 1e-10 ? prevUpperWick / prevRange : 0.0
float prevLowerWickRatio = prevRange > 1e-10 ? prevLowerWick / prevRange : 0.0

// Gap: current open is BELOW previous candle's close (bearish gap leave after bear FU)
// or current open is ABOVE previous candle's close (bullish gap leave after bull FU)
bool bearGapLeave = open < close[1] - atr * 0.05   // gap down from prior close = supply zone left behind
bool bullGapLeave = open > close[1] + atr * 0.05   // gap up from prior close = demand zone left behind

// Liquidity left: a swing high (for bear FU) to the left was swept by the wick
// Uses existing pivH/pivL variables — no new detection
bool liqLeftBear = not na(pivH) or (high[1] > nz(currSwingHigh[1], high[1]) * 0.998)
bool liqLeftBull = not na(pivL) or (low[1]  < nz(currSwingLow[1],  low[1])  * 1.002)

// BEAR FU: detected on current bar if PREVIOUS bar was the FU candle
// (so we can check whether THIS bar gapped away from it)
bool isBearFU_prev = prevRange > atr * 0.5 and
     prevBodyRatio      >= fuMinBodyRatio and
     close[1]           < open[1] and
     prevUpperWickRatio >= fuMinWickRatio and
     liqLeftBear and
     bearGapLeave

// BULL FU: detected on current bar if PREVIOUS bar was the FU candle
bool isBullFU_prev = prevRange > atr * 0.5 and
     prevBodyRatio      >= fuMinBodyRatio and
     close[1]           > open[1] and
     prevLowerWickRatio >= fuMinWickRatio and
     liqLeftBull and
     bullGapLeave

// Legacy same-bar detection (kept for compatibility — zone requirement relaxed)
bool isBullFU = fuRange > atr * 0.5 and
     fuBody / math.max(fuRange, 1e-10) >= fuMinBodyRatio and
     close > open and
     fuLowerWick / math.max(fuRange, 1e-10) >= fuMinWickRatio and
     (not fuRequireInZone or (not na(flipTop) and not na(flipBot) and
     close >= flipBot * 0.98 and close <= flipTop * 1.02))

bool isBearFU = fuRange > atr * 0.5 and
     fuBody / math.max(fuRange, 1e-10) >= fuMinBodyRatio and
     close < open and
     fuUpperWick / math.max(fuRange, 1e-10) >= fuMinWickRatio and
     (not fuRequireInZone or (not na(flipTop) and not na(flipBot) and
     close >= flipBot * 0.98 and close <= flipTop * 1.02))

// Spawn new FU block — gap-confirmed (prev-bar FU + current gap leave)
// These are high-conviction zones: liquidity was left + price gapped away
if isBearFU_prev and showFUBlocks
    // Zone = body of the FU candle (previous bar)
    float _fuPrevTop = math.max(open[1], close[1])
    float _fuPrevBot = low[1]
    array.push(fu_top,      _fuPrevTop)
    array.push(fu_bot,      _fuPrevBot)
    array.push(fu_birthBar, bar_index - 1)
    array.push(fu_dir,      -1)
    array.push(fu_state,    "Fresh")
    box _fuBoxGC = box.new(left=bar_index - 1, top=_fuPrevTop,
         bottom=_fuPrevBot, right=bar_index - 1 + fuMaxBarsActive,
         bgcolor=_cR92,
         border_color=color.new(#ff6600, 50), border_width=2)
    array.push(fu_boxes, _fuBoxGC)
    if showFULabels and (ecvAllLocations or ecvFUImbalance)
        label _fuLblGC = label.new(bar_index - 1, high[1] + atr * 0.5,
             "BEAR FU ⚡",
             style=label.style_label_down,
             color=color.new(#ff6600, 15),
             textcolor=color.white, size=size.small)
        array.push(fu_labels, _fuLblGC)
        die_labelCount := die_labelCount + 1
    else
        array.push(fu_labels, na)

if isBullFU_prev and showFUBlocks
    float _fuPrevTop2 = high[1]
    float _fuPrevBot2 = math.min(open[1], close[1])
    array.push(fu_top,      _fuPrevTop2)
    array.push(fu_bot,      _fuPrevBot2)
    array.push(fu_birthBar, bar_index - 1)
    array.push(fu_dir,      1)
    array.push(fu_state,    "Fresh")
    box _fuBoxGC2 = box.new(left=bar_index - 1, top=_fuPrevTop2,
         bottom=_fuPrevBot2, right=bar_index - 1 + fuMaxBarsActive,
         bgcolor=color.new(color.lime, 92),
         border_color=color.new(#00ffaa, 50), border_width=2)
    array.push(fu_boxes, _fuBoxGC2)
    if showFULabels and (ecvAllLocations or ecvFUImbalance)
        label _fuLblGC2 = label.new(bar_index - 1, low[1] - atr * 0.5,
             "BULL FU ⚡",
             style=label.style_label_up,
             color=color.new(#00ffaa, 15),
             textcolor=color.black, size=size.small)
        array.push(fu_labels, _fuLblGC2)
        die_labelCount := die_labelCount + 1
    else
        array.push(fu_labels, na)

// Spawn new FU block — legacy same-bar detection
if isBullFU and showFUBlocks
    array.push(fu_top,      high)
    array.push(fu_bot,      math.min(open, close))
    array.push(fu_birthBar, bar_index)
    array.push(fu_dir,      1)
    array.push(fu_state,    "Fresh")
    box _fuBox = box.new(left=bar_index, top=high,
         bottom=math.min(open, close), right=bar_index + fuMaxBarsActive,
         bgcolor=color.new(color.lime, 92),
         border_color=color.new(color.lime, 40), border_width=1)
    array.push(fu_boxes, _fuBox)
    if showFULabels and (ecvAllLocations or ecvFUCandle)
        label _fuLbl = label.new(bar_index, low - atr * 0.4, "BULL FU",
             style=label.style_label_up, color=color.new(color.lime, 25),
             textcolor=color.black, size=size.small)
        array.push(fu_labels, _fuLbl)
        die_labelCount := die_labelCount + 1
    else
        array.push(fu_labels, na)

if isBearFU and showFUBlocks
    array.push(fu_top,      math.max(open, close))
    array.push(fu_bot,      low)
    array.push(fu_birthBar, bar_index)
    array.push(fu_dir,      -1)
    array.push(fu_state,    "Fresh")
    box _fuBox2 = box.new(left=bar_index, top=math.max(open, close),
         bottom=low, right=bar_index + fuMaxBarsActive,
         bgcolor=_cR92,
         border_color=color.new(color.red, 40), border_width=1)
    array.push(fu_boxes, _fuBox2)
    if showFULabels and (ecvAllLocations or ecvFUCandle)
        label _fuLbl2 = label.new(bar_index, high + atr * 0.4, "BEAR FU",
             style=label.style_label_down, color=color.new(color.red, 25),
             textcolor=color.white, size=size.small)
        array.push(fu_labels, _fuLbl2)
        die_labelCount := die_labelCount + 1
    else
        array.push(fu_labels, na)

// Update FU block lifecycle states + trim expired
int _fuN = array.size(fu_top)

// ── Pass 1: Update lifecycle states and box visuals ──────────────────────
if _fuN > 0
    for _fi = 0 to _fuN - 1
        if _fi < array.size(fu_top)
            float  _fTop = array.get(fu_top,      _fi)
            float  _fBot = array.get(fu_bot,      _fi)
            int    _fBB  = array.get(fu_birthBar, _fi)
            int    _fDir = array.get(fu_dir,      _fi)
            string _fSt  = array.get(fu_state,    _fi)
            int    _fAge = bar_index - _fBB

            string _newState = _fSt
            if _fAge <= 3
                _newState := "Fresh"
            else if close > _fTop and _fDir == 1
                _newState := "Exhausted"
            else if close < _fBot and _fDir == -1
                _newState := "Exhausted"
            else if (close <= _fTop and close >= _fBot)
                _newState := "Interacting"
            else if (_fDir == 1 and close < _fBot - atr * 0.5) or (_fDir == -1 and close > _fTop + atr * 0.5)
                _newState := "Invalidated"
            else if _fAge > 3
                _newState := "Active"

            box _bx = array.get(fu_boxes, _fi)
            if not na(_bx)
                if _fAge < fuMaxBarsActive and _newState != "Invalidated"
                    box.set_right(_bx, bar_index + 10)
                    color _fc =
                         _newState == "Interacting" ? color.new(_fDir == 1 ? color.lime : color.red, 70) :
                         _newState == "Exhausted"   ? color.new(color.gray, 85)                          :
                         _newState == "Invalidated" ? color.new(color.gray, 90)                          :
                         _newState == "Fresh"       ? color.new(_fDir == 1 ? color.lime : color.red, 80) :
                                                      color.new(_fDir == 1 ? color.lime : color.red, 88)
                    box.set_bgcolor(_bx, _fc)
                else
                    box.delete(_bx)
                    array.set(fu_boxes, _fi, na)

            array.set(fu_state, _fi, _newState)

// ── Pass 2: Remove expired/invalidated (iterate backwards to avoid index shift)
int _fuN2 = array.size(fu_top)
if _fuN2 > 0
    for _fi2 = _fuN2 - 1 to 0
        if _fi2 < array.size(fu_top)
            int    _fAge2 = bar_index - array.get(fu_birthBar, _fi2)
            string _fSt2  = array.get(fu_state, _fi2)
            if _fAge2 >= fuMaxBarsActive or _fSt2 == "Invalidated"
                box   _bx2 = array.get(fu_boxes,  _fi2)
                label _lb2 = array.get(fu_labels, _fi2)
                if not na(_bx2)
                    box.delete(_bx2)
                if not na(_lb2)
                    label.delete(_lb2)
                array.remove(fu_top,      _fi2)
                array.remove(fu_bot,      _fi2)
                array.remove(fu_birthBar, _fi2)
                array.remove(fu_dir,      _fi2)
                array.remove(fu_state,    _fi2)
                array.remove(fu_boxes,    _fi2)
                array.remove(fu_labels,   _fi2)

// Track active FU state for confluence
bool die_anyBullFUActive = false
bool die_anyBearFUActive = false
int  die_activeFUCount   = 0
int  _fuN3 = array.size(fu_state)
if _fuN3 > 0
    for _fj = 0 to _fuN3 - 1
        string _st = array.get(fu_state, _fj)
        int    _fd = array.get(fu_dir,   _fj)
        if _st == "Active" or _st == "Fresh" or _st == "Interacting"
            die_activeFUCount := die_activeFUCount + 1
            if _fd == 1
                die_anyBullFUActive := true
            else
                die_anyBearFUActive := true

// ── DIE-3: ENTRY CYCLE QUALITY SCORING ───────────────────────────────────────
// Display-only score 0-100. Uses existing intelligence outputs. No logic changes.

float die_entryScore = math.min(
     (nz(waveModelFit,    50.0) * 0.20) +
     (nz(modelConfidence, 50.0) * 0.20) +
     (htfAlign == direction and direction != 0 ? 20.0 : htfAlign == 0 ? 10.0 : 0.0) +
     (nz(liqHeat, 0.0) > 50 ? 15.0 : nz(liqHeat, 0.0) * 0.30) +
     ((die_anyBullFUActive and direction == 1) or
      (die_anyBearFUActive and direction == -1) ? 15.0 : 0.0) +
     (flipzoneStagesComplete >= 3 ? 10.0 : flipzoneStagesComplete * 3.3),
     100.0)
float die_entryScore_safe = nz(die_entryScore, 0.0)

// ── DIE-4: ENTRY + FU CONFLUENCE DETECTION ───────────────────────────────────
// Highest-confidence execution object.

bool die_entryFUConfluence =
     ((longSignal  and die_anyBullFUActive) or
      (shortSignal and die_anyBearFUActive))

// FU contribution descriptor for entry cycle labels
string die_fuContrib =
     die_entryFUConfluence                                   ? "FU CONFIRMED" :
     ((direction == 1  and die_anyBullFUActive and not longSignal) or
      (direction == -1 and die_anyBearFUActive and not shortSignal)) ? "FU ASSISTED" : "FU NOT PRESENT"

// ── DIE-5: POINT 4 ORIGIN REWORK (rendering logic)  ──────────────────────────
// Active origin = full label. Old origins suppressed to marker "○".
// Age tracking: anything older than 100 bars from origin spawn → marker only.
int die_originAge = not na(point4OriginBar) ? bar_index - point4OriginBar : 9999
bool die_originRecent  = die_originAge < 50
bool die_originOld     = die_originAge >= 100

// ── DIE-6: NARRATIVE ENGINE ───────────────────────────────────────────────────
// Single dominant narrative label. Never stack historical narratives.
// Uses canonical Unified Wave Lifecycle phase names.

// die_narrative: sourced from ENGINE 1A canonical phase (sole lifecycle authority).
// The ie1a_hypFamily string maps canonical phases back to the old vocabulary so
// downstream colour logic (which expects these strings) continues to work.
string die_narrative    = ie1a_hypFamily    // belief-family string from IE1A
string die_narrativeDir = ie1a_currentPhase // canonical IE1A lifecycle phase

var string die_lastNarrative = ""
bool die_narrativeChanged = die_narrative != die_lastNarrative
die_lastNarrative := die_narrative

color die_narrCol =
     die_narrative == "EXPANSION"         ? color.lime   :
     die_narrative == "CONVEXITY FORMING" ? #c084fc      :
     die_narrative == "CREATION FORMING"  ? #00ff88      :
     die_narrative == "ABSORPTION"        ? color.aqua   :
     die_narrative == "RETRACEMENT"       ? color.silver : color.orange

// Section 9 — Entry Cycle Visibility gating for the active narrative label.
// Each narrative state maps to its corresponding visibility category.
bool die_narrativeVisible =
     die_narrative == "EXPANSION"         ? (ecvAllLocations or ecvExpansion)     :
     die_narrative == "CONVEXITY FORMING" ? (ecvAllLocations or ecvConvexity)     :
     die_narrative == "CREATION FORMING"  ? (ecvAllLocations or ecvPreConvexity)  :
     die_narrative == "ABSORPTION"        ? (ecvAllLocations or ecvAbsorption)    :
     die_narrative == "RETRACEMENT"       ? (ecvAllLocations or ecvRetracement)   : true

if showNarrative and die_narrativeChanged and direction != 0 and f_die_show(80) and die_narrativeVisible
    label.new(bar_index,
         direction == 1 ? high + atr * 1.2 : low - atr * 1.2,
         die_narrativeDir,
         style=direction == 1 ? label.style_label_down : label.style_label_up,
         color=color.new(die_narrCol, 40), textcolor=color.black, size=size.small)
    die_labelCount := die_labelCount + 1

// ── DIE-7: ENTRY CYCLE CLUSTER TRACKING ──────────────────────────────────────
var int   die_clusterCount     = 0
var int   die_clusterStartBar  = na
var float die_clusterBestScore = 0.0
var bool  die_inCluster        = false

// On a fresh entry cycle label, check if another fired recently
bool die_entryCycleFired = recursiveJustFired

if die_entryCycleFired
    if not die_inCluster or (not na(die_clusterStartBar) and (bar_index - die_clusterStartBar) > clusterWindow)
        // Start a new cluster
        die_clusterCount     := 1
        die_clusterStartBar  := bar_index
        die_clusterBestScore := die_entryScore
        die_inCluster        := true
    else
        // Extend existing cluster
        die_clusterCount     := die_clusterCount + 1
        if die_entryScore > die_clusterBestScore
            die_clusterBestScore := die_entryScore

// Close cluster if window expired
if die_inCluster and not na(die_clusterStartBar) and (bar_index - die_clusterStartBar) > clusterWindow
    die_inCluster := false

// ── DIE-8: PRIMARY RENDERING — Entry Cycles, FU Confluence, Origins ──────────

// ─ Entry Cycle Label Rendering (replaces old simple green label in Section 13)
// This fires on recursiveJustFired (same condition as original label)
// We scale size by die_entryScore_safe and add FU contribution text.

if die_entryCycleFired and showLabels
    bool _isLong2 = (bullImpulse or bullConvShift)
    int  _eNum    = math.min(entryCycle + 1, 4)

    // Determine label size by score (string used, resolved at label.new call)
    string _eSizeStr =
         die_entryScore_safe >= 90 ? "large"  :
         die_entryScore_safe >= 75 ? "normal" :
         die_entryScore_safe >= 60 ? "small"  : "tiny"

    // Cluster vs individual display
    string _eTxt = na
    if enableClustering and die_clusterCount > 1
        _eTxt := "ENTRY CLUSTER ×" + str.tostring(die_clusterCount) +
                 " | Score:" + str.tostring(math.round(nz(die_clusterBestScore, 0.0)))
    else
        _eTxt := "ENTRY CYCLE " + str.tostring(_eNum) +
                 " | " + str.tostring(math.round(die_entryScore_safe)) + "%"

    // Add FU contribution sub-line
    if showFULifecycle
        _eTxt := _eTxt + "\n" + die_fuContrib

    color _eCol =
         die_entryScore_safe >= 90 ? color.new(#00ff88, 10) :
         die_entryScore_safe >= 75 ? color.new(#00ff88, 25) :
         die_entryScore_safe >= 60 ? color.new(#00ff88, 45) : color.new(#00ff88, 65)

    label.new(bar_index,
         _isLong2 ? low - atr * 0.5 : high + atr * 0.5,
         _eTxt,
         style=_isLong2 ? label.style_label_up : label.style_label_down,
         color=_eCol, textcolor=color.black,
         size=_eSizeStr == "large" ? size.large : _eSizeStr == "normal" ? size.normal : _eSizeStr == "small" ? size.small : size.tiny)
    die_labelCount := die_labelCount + 1

// ─ ENTRY + FU Confluence Label (Priority 100 — highest visibility)
if die_entryFUConfluence and showFUConflLabel and (ecvAllLocations or ecvFUImbalance)
    bool _cfLong = longSignal
    label.new(bar_index,
         _cfLong ? low - atr * 1.0 : high + atr * 1.0,
         "⚡ ENTRY + FU ⚡\n" + str.tostring(math.round(die_entryScore_safe)) + "%",
         style=_cfLong ? label.style_label_up : label.style_label_down,
         color=color.new(#ffdd00, 10), textcolor=color.black, size=size.large)
    die_labelCount := die_labelCount + 1

// ─ Point 4 Origin Labels — rework: suppress old, compress recent
// The origin labels in Sections 13 (spawn) are already created there.
// We add the ACTIVE marker as a right-edge annotation if in execution/context mode.
// Old origins get a small "○" plotshape style marker instead of full labels.
// (The heavy orange labels from section 13 are controlled by showLabels and entryCycle==0
//  which already fires only on spawn. The DIE simply controls their size via density gating.)

// For currently active origin — annotate with priority marker if density is high
// (origin marker suppressed — spawned once at origin bar only)
// Marker only for old origins (visual downgrade)
if die_originOld and showLabels
    label.new(bar_index, direction == 1 ? point4OriginLow - atr * 0.2 : point4OriginHigh + atr * 0.2,
             "○",
             style=direction == 1 ? label.style_label_up : label.style_label_down,
             color=color.new(color.orange, 80), textcolor=color.orange, size=size.tiny)

// ── DIE-9: DISPLAY INTELLIGENCE DASHBOARD SECTION ───────────────────────────
// Added to Panel A as an extra section below existing content.

// SECTION 25 — DASHBOARD (3 panels with full section toggles)
// ═══════════════

// Text size string → Pine size constant
string _ts = dashTextSize
string _szA = _ts == "tiny" ? size.tiny : size.small

// Common colors
color _cW30 = color.new(color.white, 30)
color _cW20 = color.new(color.white, 20)
color _cW80 = color.new(color.white, 80)
color _cR92 = color.new(color.red, 92)
color _cT92 = color.new(color.teal, 92)

// Helper: write a separator row spanning both columns (returns next row index)
f_sep(table t, int r, string lbl, string tsz) =>
    table.cell(t, 0, r, lbl, text_color=_cW20, bgcolor=_cW80,
         text_size=tsz == "tiny" ? size.tiny : tsz == "normal" ? size.normal : size.small)
    table.cell(t, 1, r, "", bgcolor=_cW80)
    r + 1

// Helper: write a separator row spanning the right column pair (cols 2-3)
f_sep2(table t, int r, string lbl, string tsz) =>
    table.cell(t, 2, r, lbl, text_color=_cW20, bgcolor=_cW80,
         text_size=tsz == "tiny" ? size.tiny : tsz == "normal" ? size.normal : size.small)
    table.cell(t, 3, r, "", bgcolor=_cW80)
    r + 1

// Shared colour helpers (re-declared as functions to avoid forward-ref issues)
f_sc(float v) =>
    v >= 85 ? #00ff88 : v >= 70 ? color.lime : v >= 40 ? color.yellow : color.red

f_sl(float v) =>
    v >= 85 ? "Exceptional" : v >= 70 ? "Strong" : v >= 40 ? "Neutral" : "Weak"

// Helper: dashboard row writer (label+value pair, returns next row index)
f_r(table t, int r, string lbl, string val, color c) =>
    table.cell(t, 0, r, lbl, text_color=color.silver, text_size=_szA)
    table.cell(t, 1, r, val, text_color=c, text_size=_szA)
    r + 1

// Helper: dashboard row writer with normal-sized value cell (returns next row)
f_rb(table t, int r, string lbl, string val, color c) =>
    table.cell(t, 0, r, lbl, text_color=color.silver, text_size=_szA)
    table.cell(t, 1, r, val, text_color=c, text_size=_ts == "tiny" ? size.tiny : size.normal)
    r + 1

// Helper: dashboard row writer for the right column pair (cols 2-3)
f_r2(table t, int r, string lbl, string val, color c) =>
    table.cell(t, 2, r, lbl, text_color=color.silver, text_size=_szA)
    table.cell(t, 3, r, val, text_color=c, text_size=_szA)
    r + 1

// Helper: compact command-dashboard row (gray label). _szA === local _z by value.
f_cd(table t, int r, string lbl, string val, color c) =>
    table.cell(t, 0, r, lbl, text_color=color.gray, text_size=_szA)
    table.cell(t, 1, r, val, text_color=c, text_size=_szA)
    r + 1

// ────────────────────
// DASHBOARD PANELS A/B/C/FU — wrapped in function to satisfy body-length limit
// ────────────────────
f_renderDashABC() =>
    if showTable
        // ── PANEL A: Command Center (top_right) ──────────────────────────────────
        var table dashA = table.new(position.top_right, 2, 26,
             bgcolor=color.new(#0a0a12, 5),
             border_color=_cW30, border_width=1,
             frame_color=_cW20, frame_width=1)

        // ── PANEL B: Belief Distributions (bottom_right) ─────────────────────────
        var table dashB = table.new(position.bottom_right, 2, 30,
             bgcolor=color.new(#0a0a12, 5),
             border_color=_cW30, border_width=1,
             frame_color=_cW20, frame_width=1)

        // ── PANEL C: Intelligence Engine (top_left) ───────────────────────────────
        var table dashC = table.new(position.middle_left, 2, 80,
             bgcolor=color.new(#0a0a12, 5),
             border_color=_cW30, border_width=1,
             frame_color=_cW20, frame_width=1)

        // phCol: sourced from ENGINE 1A canonical phase (sole lifecycle authority)
        color phCol =
             ie1a_currentPhase == "Expansion"                   ? color.lime   :
             ie1a_currentPhase == "Expansion Pre-Convexity"     ? #c084fc      :
             ie1a_currentPhase == "Expansion Induction"         ? #c084fc      :
             ie1a_currentPhase == "Expansion Liquidity"         ? #c084fc      :
             ie1a_currentPhase == "New High" or ie1a_currentPhase == "New Low" ? #00ff88 :
             ie1a_currentPhase == "Absorption"                  ? color.aqua   :
             ie1a_currentPhase == "Retracement"                 ? color.silver :
             ie1a_currentPhase == "Retracement Pre-Convexity"   ? color.silver :
             ie1a_currentPhase == "Retracement Induction"       ? color.silver :
             ie1a_currentPhase == "Retracement Liquidity"       ? color.silver :
             ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return" ? color.orange :
             color.gray

        string stStr    = structBias ==  1 ? "Bull ▲" : structBias == -1 ? "Bear ▼" : "Neutral"
        bool isDecaying = math.abs(acceleration) < math.abs(acceleration[1])
        string accState = isDecaying ? "Easing" : "Building"

        // ════ PANEL A ═════════════════════════════════════════════════════════════
        int _ra = 0

        if true
            table.cell(dashA, 0, _ra, "SYMPHONY WAVE INTEL v72 ERF",
                 text_color=color.white, bgcolor=color.new(#0a0a30, 0),
                 text_size=_szA)
            // Header shows IE1A canonical phase + IE1A dimension-confidence
            table.cell(dashA, 1, _ra, ie1a_currentPhase + " [IE1A " + str.tostring(math.round(ie1a_phaseConfidence)) + "%]",
                 text_color=color.black, bgcolor=phCol,
                 text_size=_szA)
            _ra := _ra + 1

        if true
            _ra := f_sep(dashA, _ra, "TRADE DIRECTIVE", _ts)
            table.cell(dashA, 0, _ra, "ACTION",
                 text_color=color.white, bgcolor=directiveBg,
                 text_size=_szA)
            table.cell(dashA, 1, _ra, directiveStr,
                 text_color=directiveCol, bgcolor=directiveBg,
                 text_size=_szA)
            _ra := _ra + 1
            _ra := f_r(dashA, _ra, "Engine", engineArmed ? "Armed" : "Locked", engineArmed ? color.lime : color.orange)

        if true
            _ra := f_sep(dashA, _ra, "WAVE CONTEXT", _ts)
            // ── L0: What Wave Price Is Trying To Make ─────────────────────────
            _ra := f_r(dashA, _ra, "L0 Target", l0_targetWave, direction >= 0 ? color.teal : color.red)
            // ── L0: Current Phase Within Curve Cycle ──────────────────────────
            _ra := f_r(dashA, _ra, "L0 Phase [IE1A]", ie1a_currentPhase, phCol)
            _ra := f_r(dashA, _ra, "IE1A BOS", not ie1a_bos1Active ? "No BOS" : ie1a_bos2Active ? "BOS-2 ✓" : "BOS-1 ✓", ie1a_bos2Active ? #00ff88 : ie1a_bos1Active ? color.yellow : color.gray)
            _ra := f_r(dashA, _ra, "IE1A Induction", ie1a_inductionOriginBroken ? "Origin Broken ✓" : not na(ie1a_inductionExtreme) ? "Extreme Set" : not na(ie1a_inductionOrigin) ? "Origin Set" : "–", ie1a_inductionOriginBroken ? #00ff88 : not na(ie1a_inductionExtreme) ? color.yellow : color.gray)
            _ra := f_r(dashA, _ra, "Wave Type", isRecursiveWave ? "Entry #" + str.tostring(entryCycle) + " Recursive" : "Parent wave", isRecursiveWave ? #00ff88 : color.teal)
            _ra := f_r(dashA, _ra, "Next Expected", expectedNextPhase + " " + str.tostring(math.round(expectedNextProb)) + "%", color.yellow)

        if true
            _ra := f_sep(dashA, _ra, "MARKET STATE", _ts)
            _ra := f_r(dashA, _ra, "Direction", direction == 1 ? "Long ▲" : direction == -1 ? "Short ▼" : "None", direction == 1 ? color.teal : direction == -1 ? color.red : color.gray)
            _ra := f_r(dashA, _ra, "Structure", stStr, structBias == 1 ? color.lime : structBias == -1 ? color.red : color.gray)
            bool dirStructAlign = direction != 0 and direction == structBias
            _ra := f_r(dashA, _ra, "Alignment", direction == 0 ? "–" : dirStructAlign ? "✓ Aligned" : "✗ Diverged", direction == 0 ? color.gray : dirStructAlign ? color.lime : color.orange)
            _ra := f_r(dashA, _ra, "HTF Bias", htfAlign == 1 ? "Bull ▲▲" : htfAlign == -1 ? "Bear ▼▼" : "Mixed", htfAlign == 1 ? color.lime : htfAlign == -1 ? color.red : color.gray)
            // ERF: Energy State row in Market State
            _ra := f_r(dashA, _ra, "Energy State [ERF]", eae_energyState + " | " + re_resolutionState, re_resolutionState == "RESOLVED" ? #00ff88 : re_resolutionState == "PARTIALLY RESOLVED" ? color.yellow : color.orange)

        if true
            _ra := f_sep(dashA, _ra, "HTF BELIEF STACK", _ts)
            _ra := f_r(dashA, _ra, "TF1 (" + tf1 + ") Exp", str.tostring(math.round(expScr_tf1)) + " " + (dir_tf1 == 1 ? "▲" : dir_tf1 == -1 ? "▼" : "·"), dir_tf1 == 1 ? color.lime : dir_tf1 == -1 ? color.red : color.gray)
            _ra := f_r(dashA, _ra, "TF2 (" + tf2 + ") Exp", str.tostring(math.round(expScr_tf2)) + " " + (dir_tf2 == 1 ? "▲" : dir_tf2 == -1 ? "▼" : "·"), dir_tf2 == 1 ? color.lime : dir_tf2 == -1 ? color.red : color.gray)
            _ra := f_r(dashA, _ra, "HTF Interp", htf_PrimaryInterp, htfAlign == 1 ? color.lime : htfAlign == -1 ? color.red : color.gray)
            _ra := f_r(dashA, _ra, "Resonance", str.tostring(resonance) + " / 2", resonance == 2 ? #00ff88 : color.gray)

        if true
            _ra := f_sep(dashA, _ra, "PHYSICS", _ts)
            _ra := f_r(dashA, _ra, "Velocity", str.tostring(math.round(velocityScore)) + " " + f_sl(velocityScore), f_sc(velocityScore))

        // ════ PANEL B ═════════════════════════════════════════════════════════════
        // V72: Panel B is diagnostic — gated behind Advanced Mode
        int _rb = 0

        if dashAdvancedMode
            table.cell(dashB, 0, _rb, "WAVE BELIEF DISTRIBUTIONS",
                 text_color=color.white, bgcolor=color.new(#0a0a30, 0),
                 text_size=_szA)
            table.cell(dashB, 1, _rb, "Score / 100",
                 bgcolor=color.new(#0a0a30, 0), text_color=color.gray,
                 text_size=_szA)
            _rb := _rb + 1

        if dashAdvancedMode
            _rb := f_sep(dashB, _rb, "SIMULTANEOUS BELIEFS", _ts)

            // ── FIX: use display-safe d_* variables so NaN never reaches the table ──
            _rb := f_rb(dashB, _rb, "Expansion", str.tostring(math.round(d_expansionBelief)), f_sc(d_expansionBelief))
            _rb := f_rb(dashB, _rb, "Convexity (Pre-Conv)", str.tostring(math.round(d_convexityBelief)), f_sc(d_convexityBelief))
            _rb := f_rb(dashB, _rb, "New High / New Low", str.tostring(math.round(d_creationBelief)), f_sc(d_creationBelief))
            _rb := f_rb(dashB, _rb, "Absorption", str.tostring(math.round(d_absorptionBelief)), f_sc(d_absorptionBelief))
            _rb := f_rb(dashB, _rb, "Retracement", str.tostring(math.round(d_retracementBelief)), f_sc(d_retracementBelief))
            _rb := f_rb(dashB, _rb, "Demand Return", str.tostring(math.round(d_demandReturnBelief)), f_sc(d_demandReturnBelief))

        if dashAdvancedMode
            _rb := f_sep(dashB, _rb, "PHASE PROXIMITY", _ts)
            _rb := f_r(dashB, _rb, "Exp Proximity", str.tostring(math.round(expansionProximity)), f_sc(expansionProximity))
            _rb := f_r(dashB, _rb, "Conv Proximity", str.tostring(math.round(convexityProximity)), f_sc(convexityProximity))
            _rb := f_r(dashB, _rb, "Create Proximity", str.tostring(math.round(creationProximity)), f_sc(creationProximity))
            _rb := f_r(dashB, _rb, "Absorb Proximity", str.tostring(math.round(absorptionProximity)), f_sc(absorptionProximity))
            _rb := f_r(dashB, _rb, "Retr Proximity", str.tostring(math.round(retracementProximity)), f_sc(retracementProximity))

        if dashAdvancedMode
            _rb := f_sep(dashB, _rb, "CONVEXITY EVIDENCE", _ts)
            _rb := f_r(dashB, _rb, "Exp Pre-Conv", expansionPreConvSeen ? "Evidence" : "–", expansionPreConvSeen ? color.lime : color.orange)
            _rb := f_r(dashB, _rb, "Exp Induction", expansionInductionConf ? "Evidence" : "–", expansionInductionConf ? color.lime : color.orange)
            _rb := f_r(dashB, _rb, "Retr Pre-Conv", retracementPreConvSeen ? "Evidence" : "–", retracementPreConvSeen ? color.lime : color.orange)
            _rb := f_r(dashB, _rb, "Retr Induction", retracementInductionConf ? "Evidence" : "–", retracementInductionConf ? color.lime : color.orange)
            _rb := f_r(dashB, _rb, "Induc Type", inducConfidence > 0 ? "Retr induction" : inducConfidence < 0 ? "False CHoCH" : "–", inducConfidence > 0 ? color.lime : inducConfidence < 0 ? color.red : color.gray)

        if dashAdvancedMode
            _rb := f_sep(dashB, _rb, "PHYSICS OBSERVER", _ts)
            _rb := f_r(dashB, _rb, "Expansion", str.tostring(math.round(obs_ExpansionScore)), f_sc(obs_ExpansionScore))
            _rb := f_r(dashB, _rb, "Decay", str.tostring(math.round(obs_DecayScore)), f_sc(obs_DecayScore))
            _rb := f_r(dashB, _rb, "Curvature", str.tostring(math.round(obs_CurvatureScore)), f_sc(obs_CurvatureScore))
            _rb := f_r(dashB, _rb, "Absorption", str.tostring(math.round(obs_AbsorptionScore)), f_sc(obs_AbsorptionScore))
            _rb := f_r(dashB, _rb, "Liquidity", str.tostring(math.round(obs_LiquidityScore)), f_sc(obs_LiquidityScore))
            _rb := f_r(dashB, _rb, "Consensus", str.tostring(math.round(physicsConsensus)), f_sc(physicsConsensus))

        if dashAdvancedMode
            _rb := f_sep(dashB, _rb, "GEOMETRY", _ts)
            _rb := f_r(dashB, _rb, "Remaining Room", na(availableSpace) ? "–" : str.tostring(math.round(availableSpace)) + "% " + cycleCapacity, f_sc(nz(availableSpace, 0)))
            _rb := f_r(dashB, _rb, "Geo Capacity", geoFullConvexityPossible ? "Full Conv" : geoPartialConvexityPossible ? "Partial Conv" : "Absorption only", geoFullConvexityPossible ? color.lime : geoPartialConvexityPossible ? color.yellow : color.orange)

        // ════ PANEL C ═════════════════════════════════════════════════════════════
        int _rc = 0

        if true
            table.cell(dashC, 0, _rc, "WAVE INTELLIGENCE ENGINE",
                 text_color=color.white, bgcolor=color.new(#0a0a30, 0),
                 text_size=_szA)
            table.cell(dashC, 1, _rc, "", bgcolor=color.new(#0a0a30, 0))
            _rc := _rc + 1

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "HYPOTHESIS ENGINE", _ts)
            _rc := f_r(dashC, _rc, "Expansion", str.tostring(math.round(hyp_LateExpansion_N)) + "%", f_sc(hyp_LateExpansion_N))
            _rc := f_r(dashC, _rc, "Exp Pre-Convexity", str.tostring(math.round(hyp_EarlyConvexity_N)) + "%", f_sc(hyp_EarlyConvexity_N))
            _rc := f_r(dashC, _rc, "New High / New Low", str.tostring(math.round(hyp_CreationForming_N)) + "%", f_sc(hyp_CreationForming_N))
            _rc := f_r(dashC, _rc, "Absorption", str.tostring(math.round(hyp_AbsorptionActive_N)) + "%", f_sc(hyp_AbsorptionActive_N))
            _rc := f_r(dashC, _rc, "Retracement", str.tostring(math.round(hyp_RetracementActive_N)) + "%", f_sc(hyp_RetracementActive_N))
            _rc := f_r(dashC, _rc, "Demand Return", str.tostring(math.round(hyp_DemandReturn_N)) + "%", f_sc(hyp_DemandReturn_N))

        if true
            _rc := f_sep(dashC, _rc, "PREDICTION ENGINE", _ts)
            _rc := f_r(dashC, _rc, "Expected Next", expectedNextPhase, color.yellow)
            _rc := f_r(dashC, _rc, "Probability", str.tostring(math.round(expectedNextProb)) + "%", f_sc(expectedNextProb))

        if true
            _rc := f_sep(dashC, _rc, "VALIDATION ENGINE", _ts)
            _rc := f_r(dashC, _rc, "Accuracy 10", str.tostring(math.round(predAcc10)) + "%", f_sc(predAcc10))
            _rc := f_r(dashC, _rc, "Accuracy 25", str.tostring(math.round(predAcc25)) + "%", f_sc(predAcc25))
            _rc := f_r(dashC, _rc, "Accuracy 50", str.tostring(math.round(predAcc50)) + "%", f_sc(predAcc50))
            _rc := f_r(dashC, _rc, "Reliability", str.tostring(math.round(predReliability)) + "%", f_sc(predReliability))

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "ADAPTIVE CONFIDENCE", _ts)
            _rc := f_r(dashC, _rc, "Model Confidence", str.tostring(math.round(modelConfidence)) + "%", f_sc(modelConfidence))
            _rc := f_r(dashC, _rc, "Wave Deviation", str.tostring(math.round(waveDeviation)) + (deviationAlert ? " ⚠" : ""), deviationAlert ? color.orange : f_sc(100 - waveDeviation))
            _rc := f_r(dashC, _rc, "Physics Consensus", str.tostring(math.round(physicsConsensus)) + "%", f_sc(physicsConsensus))

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "M1 EARLY WARNING", _ts)
            _rc := f_r(dashC, _rc, "M1 Signal", m1Warning, m1Warning == "CRITICAL" ? color.red : m1Warning == "HIGH" ? color.orange : m1Warning == "MODERATE" ? color.yellow : color.gray)
            _rc := f_r(dashC, _rc, "Exp Weakening", m1ExpansionWeak ? "YES ⚠" : "–", m1ExpansionWeak ? color.orange : color.gray)
            _rc := f_r(dashC, _rc, "Conv Emerging", m1ConvexityEmer ? "YES" : "–", m1ConvexityEmer ? #c084fc : color.gray)
            _rc := f_r(dashC, _rc, "Abs Emerging", m1AbsorptionEmer ? "YES" : "–", m1AbsorptionEmer ? color.aqua : color.gray)

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "SETUP QUALITY", _ts)
            _rc := f_r(dashC, _rc, "Bayesian prob", str.tostring(math.round(finalProb)) + "%", finalProb > 70 ? color.lime : finalProb > 50 ? color.yellow : color.red)
            _rc := f_r(dashC, _rc, "Trade readiness", str.tostring(math.round(tradeReadiness)) + "%", f_sc(tradeReadiness))
            _rc := f_r(dashC, _rc, "Signal quality", grade, gradeCol)
            _rc := f_r(dashC, _rc, "Edge filter", edgePassesFilter ? "✓ Pass" : "Filtered", edgePassesFilter ? color.lime : color.red)

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "DIRECTION PROBABILITY", _ts)
            _rc := f_r(dashC, _rc, "Expansion", str.tostring(math.round(expansionProbability)) + " pts", f_sc(expansionProbability))
            _rc := f_r(dashC, _rc, "Reversal", str.tostring(math.round(reversalProbability)) + " pts", f_sc(reversalProbability))

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "LIVE OPPORTUNITY", _ts)
            table.cell(dashC, 0, _rc, "Buy score",
                 text_color=color.white, text_size=_szA)
            table.cell(dashC, 1, _rc, str.tostring(buyProb, "#.#") + "%",
                 text_color=color.lime, text_size=_szA)
            _rc := _rc + 1
            table.cell(dashC, 0, _rc, "Sell score",
                 text_color=color.white, text_size=_szA)
            table.cell(dashC, 1, _rc, str.tostring(sellProb, "#.#") + "%",
                 text_color=color.red, text_size=_szA)
            _rc := _rc + 1
            _rc := f_r(dashC, _rc, "Live edge", liveDirective, netEdgeAdjusted > 0 ? color.lime : color.red)
            _rc := f_r(dashC, _rc, "Net edge", str.tostring(netEdgeAdjusted, "#.#") + " " + (math.abs(netEdgeAdjusted) > 25 ? "Strong" : math.abs(netEdgeAdjusted) > 10 ? "Moderate" : "Weak"), netEdgeAdjusted > 0 ? color.lime : color.red)

        if dashAdvancedMode
            _rc := f_sep(dashC, _rc, "EXECUTION", _ts)
            _rc := f_r(dashC, _rc, "Wave Gen", str.tostring(waveGeneration), color.aqua)

        // ── DIE Dashboard additions (display-only fields) ──────────────────────
        if showDIE_Dashboard
            _rc := f_sep(dashC, _rc, "DISPLAY INTELLIGENCE", _ts)
            _rc := f_r(dashC, _rc, "Display Mode", displayMode, displayMode == "Execution" ? color.lime : displayMode == "Context" ? color.yellow : color.gray)
            _rc := f_r(dashC, _rc, "Density", die_densityLevel + " (" + str.tostring(die_density100) + "/100b)", die_densityLevel == "Low" ? color.lime : die_densityLevel == "Medium" ? color.yellow : color.orange)
            _rc := f_r(dashC, _rc, "Active FU Blocks", str.tostring(die_activeFUCount), die_activeFUCount > 0 ? color.lime : color.gray)
            _rc := f_r(dashC, _rc, "Entry Score", str.tostring(math.round(die_entryScore_safe)) + "%", f_sc(die_entryScore_safe))
            _rc := f_r(dashC, _rc, "Narrative", die_narrativeDir, die_narrCol)
            _rc := f_r(dashC, _rc, "FU Status", die_fuContrib, die_fuContrib == "FU CONFIRMED" ? #00ff88 : die_fuContrib == "FU ASSISTED" ? color.yellow : color.gray)

        // ── ENERGY RESOLUTION FRAMEWORK PANEL ────────────────────────────────
        if showERF_Dashboard
            _rc := f_sep(dashC, _rc, "ENERGY RESOLUTION FRAMEWORK", _ts)

            // Energy State
            _rc := f_r(dashC, _rc, "Energy State", eae_energyState, eae_energyState == "Accumulating" ? color.yellow : eae_energyState == "Cleaning" ? #c084fc : eae_energyState == "Delivering" ? color.lime : eae_energyState == "Resolving" ? color.aqua : color.gray)

            // Cleaning State (EDE)
            _rc := f_r(dashC, _rc, "Cleaning State", ede_cleaningState, ede_state >= 2 and ede_state <= 4 ? #c084fc : color.gray)

            // Dissipation Progress
            _rc := f_r(dashC, _rc, "Dissipation %", str.tostring(math.round(ede_dissipationProgress)) + "%", f_sc(ede_dissipationProgress))

            // Messy = Dissipation recognition
            _rc := f_r(dashC, _rc, "Messy = Dissipation", ede_messyPriceIsDissipation ? "✓ YES" : "–", ede_messyPriceIsDissipation ? color.lime : color.gray)

            // Resolution State (RE)
            _rc := f_r(dashC, _rc, "Resolution State", re_resolutionState, re_resolutionState == "RESOLVED" ? #00ff88 : re_resolutionState == "PARTIALLY RESOLVED" ? color.yellow : color.red)

            // Residual Energy
            _rc := f_r(dashC, _rc, "Residual Energy", str.tostring(math.round(re_residualEnergyScore)), re_residualEnergyScore > 60 ? color.red : re_residualEnergyScore > 30 ? color.yellow : color.lime)

            // Recursive Completion Score
            _rc := f_r(dashC, _rc, "Recursive Completion", str.tostring(re_completedCycles) + "/" + str.tostring(re_expectedCycles) + " " + str.tostring(math.round(re_recursiveCompletionScore)) + "%", f_sc(re_recursiveCompletionScore))

            // Revisit Probability
            _rc := f_r(dashC, _rc, "Revisit Probability", str.tostring(math.round(re_revisitProbability)) + "%", re_revisitProbability > 70 ? color.red : re_revisitProbability > 40 ? color.orange : color.lime)

            // Primary Attractor (EAE)
            _rc := f_r(dashC, _rc, "Primary Attractor", eae_primaryAttractorLabel, eae_primaryAttractorScore > 60 ? #00ffcc : eae_primaryAttractorScore > 30 ? color.yellow : color.gray)

            // Attractor Score
            _rc := f_r(dashC, _rc, "Attractor Score", str.tostring(math.round(eae_primaryAttractorScore)) + "%", f_sc(eae_primaryAttractorScore))

            // Rotation Suppression
            _rc := f_r(dashC, _rc, "Rotation Suppress", erf_suppressRotation ? "ACTIVE (Cleaning)" : "–", erf_suppressRotation ? color.orange : color.gray)

            // ERF Confidence
            _rc := f_r(dashC, _rc, "ERF Confidence", str.tostring(math.round(erf_confidence)) + "%", f_sc(erf_confidence))

            // Dissipation Confidence
            _rc := f_r(dashC, _rc, "Dissipation Conf", str.tostring(math.round(erf_dissipationConfidence)) + "%", f_sc(erf_dissipationConfidence))

        // ── FU Order Blocks Dashboard Panel ───────────────────────────────────
        if dashAdvancedMode
            var table dashFU = table.new(position.middle_right, 2, 12,
                 bgcolor=color.new(#0a0a12, 5),
                 border_color=_cW30, border_width=1,
                 frame_color=_cW20, frame_width=1)

            int _rf = 0
            if true
                table.cell(dashFU, 0, _rf, "FU ORDER BLOCKS",
                     text_color=color.white, bgcolor=color.new(#0a0a30, 0),
                     text_size=_szA)
                table.cell(dashFU, 1, _rf, "DIE Engine",
                     text_color=_cW30, bgcolor=color.new(#0a0a30, 0),
                     text_size=_szA)
                _rf := _rf + 1

            if true
                _rf := f_sep(dashFU, _rf, "FU STATISTICS", _ts)
                _rf := f_r(dashFU, _rf, "Active Blocks", str.tostring(die_activeFUCount), die_activeFUCount > 0 ? color.lime : color.gray)
                _rf := f_r(dashFU, _rf, "Bull FU Active", die_anyBullFUActive ? "YES ▲" : "–", die_anyBullFUActive ? color.lime : color.gray)
                _rf := f_r(dashFU, _rf, "Bear FU Active", die_anyBearFUActive ? "YES ▼" : "–", die_anyBearFUActive ? color.red : color.gray)
                _rf := f_r(dashFU, _rf, "Confluence", die_entryFUConfluence ? "⚡ ENTRY+FU" : "–", die_entryFUConfluence ? #ffdd00 : color.gray)

            if true
                _rf := f_sep(dashFU, _rf, "LAST FU BLOCK", _ts)
                int _fuSz = array.size(fu_dir)
                if _fuSz > 0
                    int _lastFuDir = array.get(fu_dir, _fuSz - 1)
                    string _lastFuSt = array.get(fu_state, _fuSz - 1)
                    int _lastFuAge  = bar_index - array.get(fu_birthBar, _fuSz - 1)
                    _rf := f_r(dashFU, _rf, "Direction", _lastFuDir == 1 ? "Bull ▲" : "Bear ▼", _lastFuDir == 1 ? color.lime : color.red)
                    _rf := f_r(dashFU, _rf, "State", _lastFuSt, _lastFuSt == "Interacting" ? color.yellow : _lastFuSt == "Fresh" ? color.lime : _lastFuSt == "Exhausted" ? color.gray : color.silver)
                    _rf := f_r(dashFU, _rf, "Age (bars)", str.tostring(_lastFuAge), _lastFuAge < 10 ? color.lime : color.gray)
                else
                    table.cell(dashFU, 0, _rf, "No FU blocks detected",
                         text_color=color.gray, text_size=_szA)
                    table.cell(dashFU, 1, _rf, "–",
                         text_color=color.gray, text_size=_szA)
                    _rf := _rf + 0


// ═══════════════
// PHASE 3 — RECURSIVE WAVE INTELLIGENCE ENGINE (v68)
// ═══════════════

// ── P3-1: RECURSIVE WAVE OBJECTS ─────────────────────────────────────────────

float  l0_waveProgress       = waveProgress
float  l0_convexityMaturity  = convexityMaturity
float  l0_modelFit           = waveModelFit
string l0_dominantPhase      = ie1a_hypFamily    // ENGINE 1A: sole source of L0 phase family
float  l0_confidence         = modelConfidence
string l0_prediction         = expectedNextPhase
float  l0_predProb           = expectedNextProb

float _l1_expStrength   = expScr_tf1
float _l1_decStrength   = decScr_tf1
float _l1_absStrength   = abScr_tf1
float _l1_liqStrength   = liqScr_tf1

float l1_waveProgress = math.min(
     (_l1_expStrength > 60  ? 20.0 : _l1_expStrength * 0.33) +
     (_l1_decStrength > 40  ? 20.0 : 0.0) +
     (_l1_liqStrength > 50  ? 20.0 : 0.0) +
     (_l1_absStrength > 35  ? 20.0 : 0.0), 100.0)

float l1_convexityMaturity = math.min(
     _l1_decStrength * 0.50 + _l1_liqStrength * 0.30 + _l1_absStrength * 0.20, 100.0)

float l1_modelFit = math.min(
     math.max(_l1_expStrength, _l1_decStrength, _l1_absStrength, _l1_liqStrength) * 0.70 +
     (dir_tf1 != 0 ? 30.0 : 0.0), 100.0)

string l1_dominantPhase =
     _l1_expStrength >= _l1_decStrength and _l1_expStrength >= _l1_absStrength ? "Expansion" :
     _l1_decStrength >= _l1_absStrength and _l1_decStrength >= _l1_liqStrength ? "Pre-Convexity" :
     _l1_liqStrength >= _l1_absStrength                                        ? "Liquidity"      : "Absorption"

var float l1_confidence = 50.0
float _l1_confRaw = l1_modelFit * 0.60 + (dir_tf1 == direction ? 40.0 : dir_tf1 == 0 ? 20.0 : 0.0)
l1_confidence := l1_confidence + 0.4 * (_l1_confRaw - l1_confidence)
l1_confidence := math.max(10.0, math.min(100.0, l1_confidence))

string l1_prediction =
     l1_dominantPhase == "Expansion"     ? "Pre-Convexity" :
     l1_dominantPhase == "Pre-Convexity" ? "Liquidity"     :
     l1_dominantPhase == "Liquidity"     ? "Absorption"    : "Expansion"

float _l2_expStrength   = expScr_tf2
float _l2_decStrength   = decScr_tf2
float _l2_absStrength   = abScr_tf2
float _l2_liqStrength   = liqScr_tf2

float l2_waveProgress = math.min(
     (_l2_expStrength > 60  ? 20.0 : _l2_expStrength * 0.33) +
     (_l2_decStrength > 40  ? 20.0 : 0.0) +
     (_l2_liqStrength > 50  ? 20.0 : 0.0) +
     (_l2_absStrength > 35  ? 20.0 : 0.0), 100.0)

float l2_convexityMaturity = math.min(
     _l2_decStrength * 0.50 + _l2_liqStrength * 0.30 + _l2_absStrength * 0.20, 100.0)

float l2_modelFit = math.min(
     math.max(_l2_expStrength, _l2_decStrength, _l2_absStrength, _l2_liqStrength) * 0.70 +
     (dir_tf2 != 0 ? 30.0 : 0.0), 100.0)

string l2_dominantPhase =
     _l2_expStrength >= _l2_decStrength and _l2_expStrength >= _l2_absStrength ? "Expansion" :
     _l2_decStrength >= _l2_absStrength and _l2_decStrength >= _l2_liqStrength ? "Pre-Convexity" :
     _l2_liqStrength >= _l2_absStrength                                        ? "Liquidity"      : "Absorption"

var float l2_confidence = 50.0
float _l2_confRaw = l2_modelFit * 0.60 + (dir_tf2 == direction ? 40.0 : dir_tf2 == 0 ? 20.0 : 0.0)
l2_confidence := l2_confidence + 0.4 * (_l2_confRaw - l2_confidence)
l2_confidence := math.max(10.0, math.min(100.0, l2_confidence))

string l2_prediction =
     l2_dominantPhase == "Expansion"     ? "Pre-Convexity" :
     l2_dominantPhase == "Pre-Convexity" ? "Liquidity"     :
     l2_dominantPhase == "Liquidity"     ? "Absorption"    : "Expansion"

int _l3_signals =
     (m1ExpansionWeak  ? 1 : 0) +
     (m1ConvexityEmer  ? 1 : 0) +
     (m1LiquidityEmer  ? 1 : 0) +
     (m1AbsorptionEmer ? 1 : 0)

float l3_waveProgress =
     m1AbsorptionEmer  ? 80.0 :
     m1LiquidityEmer   ? 60.0 :
     m1ConvexityEmer   ? 40.0 :
     m1ExpansionWeak   ? 25.0 : 10.0

float l3_convexityMaturity =
     m1LiquidityEmer or m1AbsorptionEmer ? 70.0 :
     m1ConvexityEmer                     ? 40.0 : 15.0

float l3_modelFit      = math.min(float(_l3_signals) / 4.0 * 100.0, 100.0)

string l3_dominantPhase =
     m1AbsorptionEmer ? "M1 Absorption" :
     m1LiquidityEmer  ? "M1 Liquidity"  :
     m1ConvexityEmer  ? "M1 Convexity"  :
     m1ExpansionWeak  ? "M1 Exp Weak"   : "M1 Expansion"

float l3_confidence    = l3_modelFit

string l3_prediction   =
     l3_dominantPhase == "M1 Exp Weak"   ? "M1 Convexity"  :
     l3_dominantPhase == "M1 Convexity"  ? "M1 Liquidity"  :
     l3_dominantPhase == "M1 Liquidity"  ? "M1 Absorption" : "M1 Expansion"

// ── P3-7: WAVE AGREEMENT ENGINE (f_phaseFamily moved here — used in P3-2 and P3-4) ──────────

// f_phaseFamily: maps both old hypothesis vocabulary AND canonical IE1A phases
// to lifecycle family integers (used by agreement / fractal confidence engines).
f_phaseFamily(string ph) =>
    int family = 0
    // Old hypothesis vocabulary (L1/L2/L3 belief layers)
    if ph == "EXPANSION" or ph == "Expansion"
        family := 1
    else if ph == "CONVEXITY FORMING" or ph == "Pre-Convexity" or ph == "Liquidity"
        family := 2
    else if ph == "CREATION FORMING"
        family := 3
    else if ph == "ABSORPTION" or ph == "Absorption"
        family := 4
    else if ph == "RETRACEMENT"
        family := 5
    else if ph == "DEMAND/SUPPLY RETURN"
        family := 6
    // Canonical IE1A lifecycle phases
    else if ph == "Point 4 Origin"
        family := 0
    else if ph == "Expansion"
        family := 1
    else if ph == "Expansion Pre-Convexity" or ph == "Expansion Induction" or ph == "Expansion Liquidity"
        family := 2
    else if ph == "New High" or ph == "New Low"
        family := 3
    else if ph == "Absorption"
        family := 4
    else if ph == "Retracement" or ph == "Retracement Pre-Convexity" or ph == "Retracement Induction" or ph == "Retracement Liquidity"
        family := 5
    else if ph == "Demand Return" or ph == "Supply Return"
        family := 6
    family

// L0 family uses IE1A canonical phase directly for accurate agreement scoring
int fam_l0 = f_phaseFamily(ie1a_currentPhase)
int fam_l1 = f_phaseFamily(l1_dominantPhase)
int fam_l2 = f_phaseFamily(l2_dominantPhase)

// ── P3-2: PARENT-CHILD RELATIONSHIP ENGINE ────────────────────────────────────

string parentState      = l2_dominantPhase
string childState       = l1_dominantPhase
string grandchildState  = l0_dominantPhase

bool parentChildHarmonic =
     (parentState == "Expansion" and childState == "Pre-Convexity") or
     (parentState == "Expansion" and childState == "Liquidity")      or
     (parentState == "Pre-Convexity" and childState == "Liquidity")  or
     (parentState == "Liquidity" and childState == "Absorption")     or
     (parentState == "Absorption" and childState == "Expansion")

// childGrandchildHarmonic: uses fam_l0 (IE1A family) for L0 comparisons,
// so both old hypothesis vocabulary and canonical IE1A phases are handled correctly.
bool childGrandchildHarmonic =
     (childState == "Expansion" and (fam_l0 == 1 or fam_l0 == 2)) or
     (childState == "Pre-Convexity" and (fam_l0 == 2 or fam_l0 == 3)) or
     (childState == "Liquidity" and (fam_l0 == 4 or fam_l0 == 5)) or
     (childState == "Absorption" and fam_l0 == 6)

string parentChildRelationship =
     parentChildHarmonic      ? "Harmonic"  :
     parentState == childState ? "Parallel"  : "Counter"

string childGrandchildRelationship =
     childGrandchildHarmonic              ? "Harmonic"  :
     childState == "Expansion" and
     childState == "Expansion" and fam_l0 == 6 ? "Counter-Within-Parent" : "Nested" 

// ── P3-3: WAVE DOMINANCE ENGINE ───────────────────────────────────────────────

float l0_dominance = math.min(
     (nz(displacement, 0.0) / math.max(dispThresh, 1e-10) * 30.0) +
     (nz(efficiency,   0.0) * 25.0) +
     (nz(liqHeat,      0.0) * 0.20) +
     (math.abs(nz(velocity, 0.0)) / math.max(nz(atr, 1.0) * 0.1, 1e-10) * 15.0) +
     (nz(waveModelFit, 0.0) * 0.10),
     100.0)

float l1_dominance = math.min(
     (_l1_expStrength * 0.35) +
     (expScr_tf1 > 60 ? 25.0 : expScr_tf1 * 0.40) +
     (liqScr_tf1 * 0.20) +
     (l1_modelFit * 0.20),
     100.0)

float l2_dominance = math.min(
     (_l2_expStrength * 0.35) +
     (expScr_tf2 > 60 ? 30.0 : expScr_tf2 * 0.50) +
     (liqScr_tf2 * 0.15) +
     (l2_modelFit * 0.20),
     100.0)

float l3_dominance = math.min(float(_l3_signals) / 4.0 * 60.0 + l3_modelFit * 0.40, 100.0)

string dominantWaveLevel =
     l2_dominance >= l1_dominance and l2_dominance >= l0_dominance and l2_dominance >= l3_dominance ? "L2 HTF"    :
     l1_dominance >= l0_dominance and l1_dominance >= l3_dominance                                  ? "L1 CHILD"  :
     l0_dominance >= l3_dominance                                                                    ? "L0 PRIMARY" : "L3 MICRO"

// ── P3-4: MULTI-TIMEFRAME WAVE FUSION LAYER ──────────────────────────────────

bool htfTrendIntact     = l2_dominantPhase == "Expansion" and l2_confidence > 45.0

// ltfReversalForming: uses fam_l0 for L0 so canonical IE1A phases are recognised.
bool ltfReversalForming =
     (fam_l0 == 4 or fam_l0 == 5) or
     (l3_dominantPhase == "M1 Absorption" or l3_dominantPhase == "M1 Liquidity")

string fusionInterpretation =
     htfTrendIntact and not ltfReversalForming  ? "HTF Intact — LTF Expansion Aligned"        :
     htfTrendIntact and ltfReversalForming       ? "HTF Intact — LTF Reversal Forming"          :
     not htfTrendIntact and ltfReversalForming   ? "HTF Weakening — LTF Reversal Confirming"    :
     l2_dominantPhase == "Absorption" and
     l1_dominantPhase == "Expansion"             ? "HTF Absorption — ITF Counter-Bounce"        :
     l2_dominantPhase == "Liquidity" and
     (l1_dominantPhase == "Absorption" or
      fam_l0 == 5)                               ? "HTF Liq Sweep — Entry Zone Forming"         :
                                                   "Mixed — Await Alignment"

float fusionConfidence = math.min(
     l2_confidence * 0.40 + l1_confidence * 0.30 +
     l0_confidence * 0.20 + l3_confidence * 0.10,
     100.0)

// ── P3-5: RECURSIVE ENTRY CYCLE ENGINE ───────────────────────────────────────

float _cycleBaseProg = nz(waveProgress, 0.0)

float cycle1_completion = math.min(
     (entryCycle >= 1 ? 60.0 : _cycleBaseProg * 0.60) +
     (recursiveComplete and entryCycle >= 1 ? 40.0 : 0.0), 100.0)

float cycle2_completion = math.min(
     (entryCycle >= 2 ? 60.0 : entryCycle >= 1 ? _cycleBaseProg * 0.40 : 0.0) +
     (recursiveComplete and entryCycle >= 2 ? 40.0 : 0.0), 100.0)

float cycle3_completion = math.min(
     (entryCycle >= 3 ? 60.0 : entryCycle >= 2 ? _cycleBaseProg * 0.40 : 0.0) +
     (recursiveComplete and entryCycle >= 3 ? 40.0 : 0.0), 100.0)

float cycle4_completion = math.min(
     (entryCycle >= 4 ? 60.0 : entryCycle >= 3 ? _cycleBaseProg * 0.40 : 0.0) +
     (recursiveComplete and entryCycle >= 4 ? 40.0 : 0.0), 100.0)

// activeCyclePhase — uses ENGINE 1A canonical phase (ie1a_currentPhase).
// grandchildState still carries the ie1a_hypFamily vocabulary for L0 agreement/fusion;
// the human-readable cycle label uses the canonical IE1A phase string.
string activeCyclePhase =
     entryCycle == 0 ?
          ("Cycle 1 — " + ie1a_currentPhase) :
     "Entry Cycle " + str.tostring(entryCycle) + " — " + ie1a_currentPhase

// ── P3-6: GEOMETRIC CAPACITY ENGINE ──────────────────────────────────────────

float geoCapacityScore = math.min(
     (geoFullConvexityPossible    ? 100.0 :
      geoPartialConvexityPossible ? 60.0  : 25.0) *
     (not na(flipzoneWidth) ? math.max(0.5, 1.0 - flipzoneWidth / math.max(atr * 4.0, 1e-10)) : 0.5),
     100.0)

string geoCapacityNarrative =
     geoFullConvexityPossible    ? "Full Conv — Complete wave expression" :
     geoPartialConvexityPossible ? "Partial Conv — Limited but tradeable" :
                                   "Absorption Only — Expect rapid absorption"

float geoRemainingFraction = not na(availableSpace) ? availableSpace / 100.0 : 0.5

// ── P3-7: WAVE AGREEMENT ENGINE ──────────────────────────────────────────────
// f_phaseFamily and fam_l0/fam_l1/fam_l2 are declared before P3-2 above.

// ─── UNIFIED WAVE CLASSIFIER (V71 REFACTOR) ───────────────────────────────────
// Single shared classifier used by L0 / L1 / L2 / L3 / Entry Cycles.
// Returns ONLY:
//   targetWave   = "Bullish Wave" | "Bearish Wave"
//   currentPhase = one canonical Unified Wave Lifecycle phase
//
// Canonical lifecycle phases (only these may appear in display):
//   Point 4 Origin | Expansion | Expansion Pre-Convexity | Expansion Induction
//   Expansion Liquidity | New High | New Low | Absorption | Retracement
//   Retracement Pre-Convexity | Retracement Induction | Retracement Liquidity
//   Demand Return | Supply Return
// ────────────────────

// f_toCanonicalPhase and f_classifyWave are defined earlier (after primaryHypothesisConf)
// so that l0_targetWave / l0_currentPhase are in scope for all sections that use them.
// L0 is already computed there. Only L1/L2/L3 are classified here where their inputs exist.

// ── Determine expansion-side for L1 / L2 / L3 ────────────────────────────────
bool _l1_expSide = l1_dominantPhase == "Expansion" or l1_dominantPhase == "Pre-Convexity" or l1_dominantPhase == "Liquidity"
bool _l2_expSide = l2_dominantPhase == "Expansion" or l2_dominantPhase == "Pre-Convexity" or l2_dominantPhase == "Liquidity"
bool _l3_expSide = l3_dominantPhase == "M1 Expansion" or l3_dominantPhase == "M1 Exp Weak" or l3_dominantPhase == "M1 Convexity" or l3_dominantPhase == "M1 Liquidity"

// ── Run classifier for L1 / L2 / L3 (L0 was run earlier) ─────────────────────
[l1_targetWave, l1_currentPhase] = f_classifyWave(l1_dominantPhase, dir_tf1 != 0 ? dir_tf1 : direction, _l1_expSide)
[l2_targetWave, l2_currentPhase] = f_classifyWave(l2_dominantPhase, dir_tf2 != 0 ? dir_tf2 : direction, _l2_expSide)
[l3_targetWave, l3_currentPhase] = f_classifyWave(l3_dominantPhase, direction, _l3_expSide)

// waveProgressCanonical — now sourced directly from ENGINE 1A.
// ENGINE 1A is the sole lifecycle authority; score-based thresholds are prohibited
// from assigning lifecycle phase.  waveProgress remains available as a confidence
// signal for downstream engines but does not determine canonical phase.
string waveProgressCanonical = ie1a_currentPhase   // ENGINE 1A authority

string waveProgressDirLabel = waveProgressCanonical

f_agreementScore(int a, int b) =>
    int diff = math.abs(a - b)
    if diff == 0
        100
    else if diff == 1
        65
    else if diff == 2
        35
    else
        10

float waveAgreement_l0l1 = f_agreementScore(fam_l0, fam_l1)
float waveAgreement_l1l2 = f_agreementScore(fam_l1, fam_l2)
float waveAgreement_l0l2 = f_agreementScore(fam_l0, fam_l2)

float waveAgreement =
     math.min(
         waveAgreement_l0l1 * 0.40 +
         waveAgreement_l1l2 * 0.35 +
         waveAgreement_l0l2 * 0.25,
         100.0)

string waveAgreementLabel =
     waveAgreement >= 85 ? "High Agreement" :
     waveAgreement >= 60 ? "Moderate Agreement" :
     waveAgreement >= 35 ? "Low Agreement" : "Counter Wave"

// ── P3-8: FRACTAL CONFIDENCE ENGINE ──────────────────────────────────────────

float _agreeBoost = (waveAgreement - 50.0) / 100.0

float fractalConfidence = math.max(10.0, math.min(100.0,
     l2_confidence * 0.35 +
     l1_confidence * 0.30 +
     l0_confidence * 0.25 +
     l3_confidence * 0.10 +
     _agreeBoost * 15.0))

string fractalConfLabel =
     fractalConfidence >= 80 ? "Exceptional" :
     fractalConfidence >= 65 ? "Strong"       :
     fractalConfidence >= 45 ? "Moderate"     : "Weak"

// ── P3-9: WAVE NARRATIVE ENGINE ───────────────────────────────────────────────
// Unified Wave Lifecycle — every row uses:
//   "What Wave Price Is Trying To Make: <targetWave>"
//   "Current Phase Within Curve Cycle: <currentPhase>"

string narr_primary   = l0_targetWave + " | " + l0_currentPhase
string narr_child     = l1_targetWave + " | " + l1_currentPhase
string narr_grandchild = l2_targetWave + " | " + l2_currentPhase
string narr_micro     = l3_targetWave + " | " + l3_currentPhase

string narr_outcome =
     fusionInterpretation == "HTF Intact — LTF Reversal Forming" ?
          "Likely: " + l0_prediction + " then continuation"  :
     fusionInterpretation == "HTF Weakening — LTF Reversal Confirming"  ?
          "Likely: Structural Reversal Forming"              :
     fusionInterpretation == "HTF Liq Sweep — Entry Zone Forming"  ?
          "Likely: Entry Cycle " + str.tostring(math.min(entryCycle + 1, 4)) :
          "Likely: " + l0_prediction

// ── P3-10: EXECUTION PROBABILITY ENGINE V2 ───────────────────────────────────

float execProb_Continuation = math.min(
     (l2_dominantPhase == "Expansion" ? 35.0 : 0.0) +
     (waveAgreement > 65 ? waveAgreement * 0.25 : 0.0) +
     (htfTrendIntact ? 20.0 : 0.0) +
     (fractalConfidence * 0.15),
     100.0)

float execProb_Reversal = math.min(
     (ie1a_currentPhase == "Absorption" or ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return" ? 30.0 : 0.0) +
     (ltfReversalForming ? 25.0 : 0.0) +
     (convexityMaturity > 65 ? convexityMaturity * 0.20 : 0.0) +
     (waveAgreement < 40 ? (40.0 - waveAgreement) * 0.30 : 0.0),
     100.0)

float execProb_Expansion = math.min(
     (ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return" ? 30.0 : 0.0) +
     (demandReturnBelief > 55 ? demandReturnBelief * 0.25 : 0.0) +
     (htfTrendIntact ? 20.0 : 0.0) +
     (liqSweepBull or liqSweepBear ? 15.0 : 0.0),
     100.0)

float execProb_Creation = math.min(
     (predScore_Creation * 0.50) +
     (geoCapacityScore * 0.20) +
     (m1LiquidityEmer ? 15.0 : 0.0) +
     (l3_dominantPhase == "M1 Liquidity" ? 15.0 : 0.0),
     100.0)

float execProb_Absorption = math.min(
     (predScore_Absorption * 0.50) +
     (m1AbsorptionEmer ? 20.0 : 0.0) +
     (l3_dominantPhase == "M1 Absorption" ? 20.0 : 0.0) +
     (ie1a_currentPhase == "New High" or ie1a_currentPhase == "New Low" ? 10.0 : 0.0),
     100.0)

float execProb_StandDown = math.min(
     (waveAgreement < 35 ? (35.0 - waveAgreement) * 1.50 : 0.0) +
     (fractalConfidence < 35 ? (35.0 - fractalConfidence) * 1.00 : 0.0) +
     (direction == 0 ? 40.0 : 0.0) +
     (physicsConsensus < 30 ? 20.0 : 0.0),
     100.0)

float execMaxProb = math.max(execProb_Continuation, execProb_Reversal,
     execProb_Expansion, execProb_Creation, execProb_Absorption, execProb_StandDown)

string execDirective =
     execProb_StandDown  >= 60                     ? "STAND DOWN"                           :
     execProb_Expansion  == execMaxProb             ? "EXPANSION ENTRY FORMING"              :
     execProb_Creation   == execMaxProb             ? "CREATION ZONE APPROACHING"            :
     execProb_Absorption == execMaxProb             ? "ABSORPTION — PREPARE REVERSAL"        :
     execProb_Reversal   == execMaxProb             ? "REVERSAL PROBABILITY DOMINANT"        :
     execProb_Continuation == execMaxProb           ? "CONTINUATION — HOLD / TRAIL"          : "AWAIT ALIGNMENT"

// ── P3-D: PHASE 3 DASHBOARD PANEL (bottom_left) ──────────────────────────────

// ────────────────────
// PHASE 3 DASHBOARD — wrapped in function to satisfy body-length limit
// ────────────────────
f_renderDashP3() =>
    if showTable
        // Compact "split" layout: 4 columns = two side-by-side label/value pairs.
        // Left pair = columns 0-1, Right pair = columns 2-3.
        // This roughly halves the panel height vs. the old single-pair layout
        // and the panel is anchored to the middle of the chart.
        var table dashP3 = table.new(position.bottom_center, 4, 32,
             bgcolor=color.new(#0a0a12, 5),
             border_color=_cW30, border_width=1,
             frame_color=_cW20, frame_width=1)

        if dashAdvancedMode
            table.cell(dashP3, 0, 0, "RECURSIVE WAVE INTEL v71",
                 text_color=color.white, bgcolor=color.new(#10103a, 0),
                 text_size=_szA)
            table.cell(dashP3, 1, 0, "Unified Wave Lifecycle",
                 text_color=_cW30, bgcolor=color.new(#10103a, 0),
                 text_size=_szA)
            table.cell(dashP3, 2, 0, "RECURSIVE WAVE INTEL v71",
                 text_color=color.white, bgcolor=color.new(#10103a, 0),
                 text_size=_szA)
            table.cell(dashP3, 3, 0, "Phase 3 Engine",
                 text_color=_cW30, bgcolor=color.new(#10103a, 0),
                 text_size=_szA)

        int _rpL = 1
        int _rpR = 1

        // ═══════════════ LEFT COLUMN GROUP (columns 0-1) ═══════════════

        if dashAdvancedMode
            _rpL := f_sep(dashP3, _rpL, "WAVE NARRATIVE", _ts)
            _rpL := f_r(dashP3, _rpL, "HTF Structure", narr_grandchild, color.yellow)
            _rpL := f_r(dashP3, _rpL, "Child Wave", narr_child, color.aqua)
            _rpL := f_r(dashP3, _rpL, "Primary Wave", narr_primary, color.lime)
            _rpL := f_r(dashP3, _rpL, "M1 Sensor", narr_micro, color.new(#c084fc, 0))
            _rpL := f_r(dashP3, _rpL, "Outcome", narr_outcome, color.white)
            _rpL := f_r(dashP3, _rpL, "Fractal Conf", str.tostring(math.round(fractalConfidence)) + "% " + fractalConfLabel, f_sc(fractalConfidence))

        if dashAdvancedMode
            _rpL := f_sep(dashP3, _rpL, "NESTED WAVE RELATIONSHIPS", _ts)
            _rpL := f_r(dashP3, _rpL, "Parent (HTF)", l2_targetWave + "\n" + l2_currentPhase, color.yellow)
            _rpL := f_r(dashP3, _rpL, "Child (ITF)", l1_targetWave + "\n" + l1_currentPhase, color.aqua)
            _rpL := f_r(dashP3, _rpL, "Grandchild (TF)", l0_targetWave + "\n" + l0_currentPhase, color.lime)
            _rpL := f_r(dashP3, _rpL, "P→C Relation", parentChildRelationship, parentChildHarmonic ? color.lime : parentState == childState ? color.yellow : color.orange)
            _rpL := f_r(dashP3, _rpL, "C→GC Relation", childGrandchildRelationship, childGrandchildHarmonic ? color.lime : color.orange)

        if dashAdvancedMode
            _rpL := f_sep(dashP3, _rpL, "WAVE DOMINANCE", _ts)
            _rpL := f_r(dashP3, _rpL, "L2 HTF Dom", str.tostring(math.round(l2_dominance)) + "%", f_sc(l2_dominance))
            _rpL := f_r(dashP3, _rpL, "L1 ITF Dom", str.tostring(math.round(l1_dominance)) + "%", f_sc(l1_dominance))
            _rpL := f_r(dashP3, _rpL, "L0 Primary Dom", str.tostring(math.round(nz(l0_dominance, 0.0))) + "%", f_sc(nz(l0_dominance, 0.0)))
            _rpL := f_r(dashP3, _rpL, "L3 Micro Dom", str.tostring(math.round(l3_dominance)) + "%", f_sc(l3_dominance))
            _rpL := f_r(dashP3, _rpL, "Dominant Level", dominantWaveLevel, color.white)

        if dashAdvancedMode
            _rpL := f_sep(dashP3, _rpL, "MTF FUSION LAYER", _ts)
            _rpL := f_r(dashP3, _rpL, "Fusion Interp", fusionInterpretation, htfTrendIntact ? color.lime : color.orange)
            _rpL := f_r(dashP3, _rpL, "Fusion Conf", str.tostring(math.round(fusionConfidence)) + "%", f_sc(fusionConfidence))
            _rpL := f_r(dashP3, _rpL, "HTF Trend", htfTrendIntact ? "Intact ✓" : "Weakening ⚠", htfTrendIntact ? color.lime : color.orange)
            _rpL := f_r(dashP3, _rpL, "LTF Reversal", ltfReversalForming ? "Forming ⚠" : "Not yet", ltfReversalForming ? color.orange : color.gray)

        if dashAdvancedMode
            _rpL := f_sep(dashP3, _rpL, "WAVE AGREEMENT", _ts)
            _rpL := f_r(dashP3, _rpL, "L0-L1 Agreement", str.tostring(math.round(waveAgreement_l0l1)) + "%", f_sc(waveAgreement_l0l1))
            _rpL := f_r(dashP3, _rpL, "L1-L2 Agreement", str.tostring(math.round(waveAgreement_l1l2)) + "%", f_sc(waveAgreement_l1l2))
            _rpL := f_r(dashP3, _rpL, "L0-L2 Agreement", str.tostring(math.round(waveAgreement_l0l2)) + "%", f_sc(waveAgreement_l0l2))
            _rpL := f_r(dashP3, _rpL, "Overall Agreement", str.tostring(math.round(waveAgreement)) + "% " + waveAgreementLabel, f_sc(waveAgreement))

        // ═══════════════ RIGHT COLUMN GROUP (columns 2-3) ═══════════════

        if dashAdvancedMode
            _rpR := f_sep2(dashP3, _rpR, "FRACTAL CONFIDENCE", _ts)
            _rpR := f_r2(dashP3, _rpR, "L2 HTF Conf", str.tostring(math.round(l2_confidence)) + "%", f_sc(l2_confidence))
            _rpR := f_r2(dashP3, _rpR, "L1 ITF Conf", str.tostring(math.round(l1_confidence)) + "%", f_sc(l1_confidence))
            _rpR := f_r2(dashP3, _rpR, "L0 Primary Conf", str.tostring(math.round(nz(l0_confidence, 0.0))) + "%", f_sc(nz(l0_confidence, 0.0)))
            _rpR := f_r2(dashP3, _rpR, "L3 Micro Conf", str.tostring(math.round(l3_confidence)) + "%", f_sc(l3_confidence))
            _rpR := f_r2(dashP3, _rpR, "Fractal Conf", str.tostring(math.round(fractalConfidence)) + "% " + fractalConfLabel, f_sc(fractalConfidence))

        if dashAdvancedMode
            _rpR := f_sep2(dashP3, _rpR, "RECURSIVE ENTRY CYCLES", _ts)
            _rpR := f_r2(dashP3, _rpR, "Cycle 1", str.tostring(math.round(nz(cycle1_completion, 0.0))) + "% complete", f_sc(nz(cycle1_completion, 0.0)))
            _rpR := f_r2(dashP3, _rpR, "Cycle 2", str.tostring(math.round(nz(cycle2_completion, 0.0))) + "% complete", f_sc(nz(cycle2_completion, 0.0)))
            _rpR := f_r2(dashP3, _rpR, "Cycle 3", str.tostring(math.round(nz(cycle3_completion, 0.0))) + "% complete", f_sc(nz(cycle3_completion, 0.0)))
            _rpR := f_r2(dashP3, _rpR, "Cycle 4", str.tostring(math.round(nz(cycle4_completion, 0.0))) + "% complete", f_sc(nz(cycle4_completion, 0.0)))
            _rpR := f_r2(dashP3, _rpR, "Active Phase", activeCyclePhase, color.white)

        if dashAdvancedMode
            _rpR := f_sep2(dashP3, _rpR, "GEOMETRIC CAPACITY", _ts)
            _rpR := f_r2(dashP3, _rpR, "Capacity", geoCapacityNarrative, geoFullConvexityPossible ? color.lime : geoPartialConvexityPossible ? color.yellow : color.orange)
            _rpR := f_r2(dashP3, _rpR, "Capacity Score", str.tostring(math.round(geoCapacityScore)) + "%", f_sc(geoCapacityScore))

        if dashAdvancedMode
            _rpR := f_sep2(dashP3, _rpR, "EXECUTION PROBABILITY V2", _ts)
            _rpR := f_r2(dashP3, _rpR, "Exec Directive", execDirective, execProb_StandDown >= 60 ? color.red : color.white)
            _rpR := f_r2(dashP3, _rpR, "Continuation", str.tostring(math.round(execProb_Continuation)) + "%", f_sc(execProb_Continuation))
            _rpR := f_r2(dashP3, _rpR, "Reversal", str.tostring(math.round(execProb_Reversal)) + "%", f_sc(execProb_Reversal))
            _rpR := f_r2(dashP3, _rpR, "Expansion", str.tostring(math.round(execProb_Expansion)) + "%", f_sc(execProb_Expansion))
            _rpR := f_r2(dashP3, _rpR, "New High / New Low", str.tostring(math.round(execProb_Creation)) + "%", f_sc(execProb_Creation))
            _rpR := f_r2(dashP3, _rpR, "Absorption", str.tostring(math.round(execProb_Absorption)) + "%", f_sc(execProb_Absorption))
            _rpR := f_r2(dashP3, _rpR, "Stand Down", str.tostring(math.round(execProb_StandDown)) + "%", execProb_StandDown >= 60 ? color.red : f_sc(100 - execProb_StandDown))

        if dashAdvancedMode
            _rpR := f_sep2(dashP3, _rpR, "MULTI-LEVEL WAVE PROGRESS", _ts)
            _rpR := f_r2(dashP3, _rpR, "L2 (HTF) Progress", l2_targetWave + "\n" + l2_currentPhase, color.yellow)
            _rpR := f_r2(dashP3, _rpR, "L1 (ITF) Progress", l1_targetWave + "\n" + l1_currentPhase, color.aqua)
            _rpR := f_r2(dashP3, _rpR, "L3 (Micro) Progress", l3_targetWave + "\n" + l3_currentPhase, color.new(#c084fc, 0))
            _rpR := f_r2(dashP3, _rpR, "L0 (Primary) Progress", l0_targetWave + "\n" + l0_currentPhase, color.lime)




// ═══════════════
// ── Phase 3 high-conviction alert ─────────────────────────────────────────────
// ── Dashboard & P3 render calls ─────────────────────────────────────────────
f_renderDashABC()
f_renderDashP3()

bool p3_highConvictionSetup =
     fractalConfidence > 68 and
     waveAgreement > 70 and
     execProb_StandDown < 35 and
     direction != 0 and
     (execProb_Expansion > 50 or execProb_Continuation > 50 or execProb_Creation > 50)

alertcondition(p3_highConvictionSetup,
     title="P3 — High-Conviction Recursive Setup",
     message="SYMPHONY v68 RWI: Fractal confluence detected.")


// ═══════════════
// PHASE 1 — WAVE TRACEABILITY v3
// DASHBOARD ↔ CHART LINKAGE — TRUE STRUCTURAL ANCHORING
//
// SPEC COMPLIANCE:
//   Every label attaches to the ACTUAL structure producing the calculation.
//   No future-space boxes. No synthetic structures. No new pivots.
//
// SOURCE MAPPING (audit result):
//   L2 HTF  → expScr_tf2/decScr_tf2/abScr_tf2/liqScr_tf2 via request.security(tf2)
//              Price range: l2_zoneHigh / l2_zoneLow  (highest/lowest 20 bars on tf2)
//              Origin: left edge = bar_index - 20 equivalent; no fixed origin bar exists.
//              Solution: box spans l2_zoneHigh/l2_zoneLow across the last 20 current-TF
//              bars that contain the tf2 20-bar range window, anchored left at the
//              bar where that range began.
//
//   L1 CHILD → expScr_tf1/decScr_tf1/abScr_tf1/liqScr_tf1 via request.security(tf1)
//              Price range: l1_zoneHigh / l1_zoneLow  (highest/lowest 20 bars on tf1)
//
//   L0 PRIMARY → waveProgress / convexityMaturity / primaryHypothesis (current TF)
//              Origin: point4OriginBar / point4OriginHigh / point4OriginLow (exact)
//              Zone: point4OriginBar → bar_index (the actual wave span)
//
//   L3 GRANDCHILD → m1AbsorptionEmer/m1LiquidityEmer/m1ConvexityEmer/m1ExpansionWeak
//              Price range: l3_zoneHigh / l3_zoneLow  (highest/lowest 20 bars on "1")
//
// HIERARCHY NESTING RULE (visual):
//   L2 HTF  → outermost zone (widest price range — drawn behind all others)
//   L0 Primary → spans from its origin bar to now (inside L2)
//   L1 Child   → tf1 range (inside L0 conceptually)
//   L3 Grandchild → narrowest / M1 range (innermost)
//
// ORIGIN LABELS:
//   L0: label at point4OriginBar (exact existing variable)
//   L2/L1/L3: label at bar_index (left/right edge of zone — no fake origin bars)
//
// DOMINANT WAVE: drawn ON the dominant structure's zone mid-price.
// ═══════════════

var string GRP_TRACE = "Wave Traceability (Phase 1)"
showTraceZones  = input.bool(true,  "Show Wave Traceability Zones (on-chart)", group=GRP_TRACE)
showL0Zone      = input.bool(true,  "Show L0 Primary Origin Zone",             group=GRP_TRACE)
showDominantTag = input.bool(true,  "Show Dominant Wave Tag",                  group=GRP_TRACE)
showOriginPins  = input.bool(true,  "Show Origin Anchor Pins",                 group=GRP_TRACE)

// ── Colour scheme: mirrors P3 dashboard colour-coding exactly ────────────────
//   narr_primary (L0)  = lime    ← matches "Primary Wave" rows
//   narr_child   (L1)  = aqua    ← matches "Child Wave" rows
//   narr_grandchild (L2) = yellow  ← matches "HTF Structure" rows
//   narr_micro   (L3)  = purple  ← matches "M1 Sensor" rows
color trace_L2_col = color.yellow             // L2 HTF
color trace_L0_col = color.lime               // L0 Primary
color trace_L1_col = color.aqua               // L1 Child
color trace_L3_col = color.new(#c084fc, 0)    // L3 Grandchild (M1)

// ── Persistent drawing objects ───────────────────────────────────────────────
var box   l2ZoneBox     = na  // L2 HTF zone (outermost — tf2 price range)
var box   l0ZoneBox     = na  // L0 Primary zone (origin → now)
var box   l1ZoneBox     = na  // L1 Child zone (tf1 price range)
var box   l3ZoneBox     = na  // L3 Grandchild zone (M1 price range)

var label l2ZoneLbl     = na  // L2 label at zone top-left
var label l0ZoneLbl     = na  // L0 label at origin bar
var label l1ZoneLbl     = na  // L1 label at zone bottom-left
var label l3ZoneLbl     = na  // L3 label at zone top-right
var label l0OriginPin   = na  // L0 origin anchor pin
var label dominantLabel = na  // Dominant wave tag on dominant structure

// ── Helper: midpoint of a price range ───────────────────────────────────────
f_mid(float h, float l) => (h + l) / 2.0

// ════════════════════════════════════════════════════════════════════════════
// ZONE SIZING — RIGHT-OF-PRICE BAND MARKERS
//
// L2/L1/L3 are HTF price ranges. Their VALUE is the price band (zoneHigh/zoneLow).
// Their TIME span on the current-TF chart is NOT meaningful — multiplying TF
// ratios by bar counts produces a span of hundreds of current-TF bars, which
// overlaps L0 and every other structure.  That was the root cause of the
// "L2 box looks like L0" problem seen in the screenshot.
//
// CORRECT APPROACH: draw each HTF zone as a narrow vertical BAND just to the
// right of the last bar, at the correct PRICE LEVEL (zoneHigh/zoneLow).
// Stacked by hierarchy width:
//   L2 HTF        → outermost  (bar_index+3 to bar_index+18)
//   L1 CHILD      → middle     (bar_index+3 to bar_index+12)
//   L3 GRANDCHILD → innermost  (bar_index+3 to bar_index+7)
//
// L0 PRIMARY continues to span from point4OriginBar → bar_index (unchanged).
// ════════════════════════════════════════════════════════════════════════════

int _l2R_far  = bar_index + 18   // L2 HTF  — rightmost, widest
int _l2R_near = bar_index + 3
int _l1R_far  = bar_index + 12   // L1 Child — middle
int _l1R_near = bar_index + 3
int _l3R_far  = bar_index + 7    // L3 Grandchild — narrowest
int _l3R_near = bar_index + 3

// ════════════════════════════════════════════════════════════════════════════
// PHASE 1-A  L2 HTF TRACEABILITY
// Structure: the 60-minute (tf2) wave being measured.
// Zone: the actual price range on tf2 that produced expScr_tf2/decScr_tf2 etc.
//       = l2_zoneHigh / l2_zoneLow, spanning the equivalent number of current
//         bars that represent 20 × tf2 bars.
// Label text mirrors the dashboard "L2 (HTF) Progress" row exactly.
// Origin pin: at the left edge of the zone (oldest bar in the 20-bar tf2 window)
// ════════════════════════════════════════════════════════════════════════════
// ── PHASE 1-A  L2 HTF TRACEABILITY ──────────────────────────────────────────
// Drawn as a narrow vertical band right of current bar at the REAL tf2 price level.
// Label text mirrors the dashboard "L2 (HTF) Progress" row exactly.
if showTraceZones and barstate.islast and not na(l2_zoneHigh) and not na(l2_zoneLow)

    string _l2txt = "L2 HTF ORIGIN (" + tf2 + "m)\n" +
         "What Wave Price Is Trying To Make:\n" + l2_targetWave + "\n" +
         "Current Phase Within Curve Cycle:\n" + l2_currentPhase +
         "\nDom: " + str.tostring(math.round(l2_dominance)) + "%"

    if na(l2ZoneBox)
        l2ZoneBox := box.new(_l2R_near, l2_zoneHigh, _l2R_far, l2_zoneLow,
             border_color=trace_L2_col, border_width=2,
             bgcolor=color.new(trace_L2_col, 92),
             border_style=line.style_solid)
        l2ZoneLbl := label.new(_l2R_near, l2_zoneHigh, _l2txt,
             style=label.style_label_right,
             color=color.new(#10103a, 10),
             textcolor=trace_L2_col, size=size.small, textalign=text.align_left)
    else
        box.set_lefttop    (l2ZoneBox, _l2R_near, l2_zoneHigh)
        box.set_rightbottom(l2ZoneBox, _l2R_far,  l2_zoneLow)
        label.set_xy  (l2ZoneLbl, _l2R_near, l2_zoneHigh)
        label.set_text(l2ZoneLbl, _l2txt)

// ════════════════════════════════════════════════════════════════════════════
// PHASE 1-B  L0 PRIMARY TRACEABILITY
// Structure: the actual primary wave span from point4OriginBar to current bar.
// These are the EXACT variables driving waveProgress, convexityMaturity,
// originToExtreme, distToOrigin, and the entire hypothesis engine.
// Zone: point4OriginBar → bar_index (the real wave extent on chart)
// Label: placed at the origin bar (the actual spawn point)
// ════════════════════════════════════════════════════════════════════════════
if showL0Zone and not na(point4OriginBar) and not na(point4OriginHigh) and not na(point4OriginLow)

    // _l0phase = waveProgressCanonical (used for label text below)
    string _l0txt = "L0 PRIMARY ORIGIN\n" +
         "What Wave Price Is Trying To Make:\n" + l0_targetWave + "\n" +
         "Current Phase Within Curve Cycle:\n" + l0_currentPhase +
         "\nDom: " + str.tostring(math.round(nz(l0_dominance, 0.0))) + "%"

    // Zone box: origin → now (the actual L0 wave span)
    if na(l0ZoneBox)
        l0ZoneBox := box.new(point4OriginBar, point4OriginHigh, bar_index, point4OriginLow,
             border_color=trace_L0_col, border_width=2,
             bgcolor=color.new(trace_L0_col, 94))
    else
        box.set_lefttop    (l0ZoneBox, point4OriginBar, point4OriginHigh)
        box.set_rightbottom(l0ZoneBox, bar_index,       point4OriginLow)

    // Label at the origin bar (top edge) — exactly where the wave was born
    if na(l0ZoneLbl)
        l0ZoneLbl := label.new(point4OriginBar, point4OriginHigh, _l0txt,
             style=label.style_label_right,
             color=color.new(#10103a, 10),
             textcolor=trace_L0_col, size=size.small, textalign=text.align_left)
    else
        label.set_xy  (l0ZoneLbl, point4OriginBar, point4OriginHigh)
        label.set_text(l0ZoneLbl, _l0txt)

    // Origin anchor pin — small triangle at the exact spawn pivot
    if showOriginPins and (ecvAllLocations or ecvOrigin)
        if na(l0OriginPin)
            l0OriginPin := label.new(point4OriginBar,
                 direction == 1 ? point4OriginLow : point4OriginHigh,
                 "L0 PRIMARY\nORIGIN",
                 style=direction == 1 ? label.style_label_up : label.style_label_down,
                 color=color.new(trace_L0_col, 15),
                 textcolor=color.black, size=size.tiny)
        else
            label.set_xy(l0OriginPin, point4OriginBar,
                 direction == 1 ? point4OriginLow : point4OriginHigh)

    // Section 9 — "Wave Completion" marker. Fires when ENGINE 1A canonical phase
    // reaches the Demand Return or Supply Return state — the final lifecycle phase.
    // IE1A is the sole authority; score-based thresholds are not used here.
    var label l0CompletionLbl = na
    bool _waveComplete = ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return"
    if showOriginPins and (ecvAllLocations or ecvWaveCompletion) and _waveComplete
        string _compTxt = "WAVE COMPLETION\n" + waveProgressDirLabel
        if na(l0CompletionLbl)
            l0CompletionLbl := label.new(bar_index,
                 direction == 1 ? high + atr * 0.6 : low - atr * 0.6,
                 _compTxt,
                 style=direction == 1 ? label.style_label_down : label.style_label_up,
                 color=color.new(trace_L0_col, 20),
                 textcolor=color.black, size=size.small)
        else
            label.set_xy  (l0CompletionLbl, bar_index, direction == 1 ? high + atr * 0.6 : low - atr * 0.6)
            label.set_text(l0CompletionLbl, _compTxt)
    else if not na(l0CompletionLbl)
        label.delete(l0CompletionLbl)
        l0CompletionLbl := na


// ════════════════════════════════════════════════════════════════════════════
// PHASE 1-C  L1 CHILD TRACEABILITY
// Structure: the 15-minute (tf1) child wave structure.
// The calculations l1_waveProgress / l1_dominantPhase / l1_convexityMaturity
// are produced by expScr_tf1/decScr_tf1/abScr_tf1/liqScr_tf1, which come
// from request.security(tf1, f_htfBeliefs(...)).
// Zone: l1_zoneHigh / l1_zoneLow (the EXACT tf1 price range already fetched),
//       spanning the equivalent current-TF bars for that tf1 window.
// Label text mirrors "L1 (ITF) Progress" dashboard row exactly.
// ════════════════════════════════════════════════════════════════════════════
// ── PHASE 1-C  L1 CHILD TRACEABILITY ────────────────────────────────────────
// Drawn as a narrow band right of current bar at the real tf1 price level.
// Narrower than L2, wider than L3 — hierarchy is readable at a glance.
if showTraceZones and barstate.islast and not na(l1_zoneHigh) and not na(l1_zoneLow)

    string _l1txt = "L1 CHILD ORIGIN (" + tf1 + "m)\n" +
         "What Wave Price Is Trying To Make:\n" + l1_targetWave + "\n" +
         "Current Phase Within Curve Cycle:\n" + l1_currentPhase +
         "\nDom: " + str.tostring(math.round(l1_dominance)) + "%"

    if na(l1ZoneBox)
        l1ZoneBox := box.new(_l1R_near, l1_zoneHigh, _l1R_far, l1_zoneLow,
             border_color=trace_L1_col, border_width=1,
             bgcolor=color.new(trace_L1_col, 92),
             border_style=line.style_dashed)
        l1ZoneLbl := label.new(_l1R_near, l1_zoneLow, _l1txt,
             style=label.style_label_right,
             color=color.new(#10103a, 10),
             textcolor=trace_L1_col, size=size.small, textalign=text.align_left)
    else
        box.set_lefttop    (l1ZoneBox, _l1R_near, l1_zoneHigh)
        box.set_rightbottom(l1ZoneBox, _l1R_far,  l1_zoneLow)
        label.set_xy  (l1ZoneLbl, _l1R_near, l1_zoneLow)
        label.set_text(l1ZoneLbl, _l1txt)

// ════════════════════════════════════════════════════════════════════════════
// PHASE 1-D  L3 GRANDCHILD (M1 PHYSICS SENSOR) TRACEABILITY
// Structure: the 1-minute grandchild structure acting as the M1 physics sensor.
// The calculations l3_waveProgress / l3_dominantPhase are produced by
// m1AbsorptionEmer / m1LiquidityEmer / m1ConvexityEmer / m1ExpansionWeak —
// all fetched via request.security(syminfo.tickerid, "1", f_m1Physics(...)).
// Zone: l3_zoneHigh / l3_zoneLow (EXACT M1 price range already fetched),
//       spanning the equivalent current-TF bars.
// DO NOT redesign or redefine L3 — this is display-only traceability.
// Label text mirrors "L3 (Micro) Progress" dashboard row exactly.
// ════════════════════════════════════════════════════════════════════════════
// ── PHASE 1-D  L3 GRANDCHILD (M1 PHYSICS SENSOR) TRACEABILITY ───────────────
// DO NOT redesign L3 — display only. Narrow band nearest to price action.
if showTraceZones and barstate.islast and not na(l3_zoneHigh) and not na(l3_zoneLow)

    string _l3txt = "L3 MICRO ORIGIN\n" +
         "What Wave Price Is Trying To Make:\n" + l3_targetWave + "\n" +
         "Current Phase Within Curve Cycle:\n" + l3_currentPhase +
         "\nDom: " + str.tostring(math.round(l3_dominance)) + "%"

    if na(l3ZoneBox)
        l3ZoneBox := box.new(_l3R_near, l3_zoneHigh, _l3R_far, l3_zoneLow,
             border_color=color.new(trace_L3_col, 20), border_width=1,
             bgcolor=color.new(trace_L3_col, 92),
             border_style=line.style_dashed)
        l3ZoneLbl := label.new(_l3R_far, f_mid(l3_zoneHigh, l3_zoneLow), _l3txt,
             style=label.style_label_left,
             color=color.new(#10103a, 20),
             textcolor=color.new(trace_L3_col, 10), size=size.tiny, textalign=text.align_left)
    else
        box.set_lefttop    (l3ZoneBox, _l3R_near, l3_zoneHigh)
        box.set_rightbottom(l3ZoneBox, _l3R_far,  l3_zoneLow)
        label.set_xy  (l3ZoneLbl, _l3R_far, f_mid(l3_zoneHigh, l3_zoneLow))
        label.set_text(l3ZoneLbl, _l3txt)

// ════════════════════════════════════════════════════════════════════════════
// PHASE 1-F  AUTOMATIC LABEL STACKING (Section 5 — Visual Clarity Engine)
// Prevents the L2 / L0 / L1 / L3 origin labels from visually overlapping.
// Hierarchy order is enforced top-down: L2 -> L0 -> L1 -> L3. Each label's
// anchor price is read back, and if it sits within a minimum ATR-based
// vertical gap of the label above it in the hierarchy, it is nudged down
// by the remaining distance. No new calculations of wave state are made —
// this only adjusts label.set_xy placement of the four existing labels.
// ════════════════════════════════════════════════════════════════════════════
if showTraceZones and barstate.islast and not na(atr)

    float _stackGap = atr * 1.0   // minimum vertical separation between labels

    // Read current anchor prices (y) for each label, in hierarchy order.
    float _y2 = not na(l2ZoneLbl) ? label.get_y(l2ZoneLbl) : na
    float _y0 = not na(l0ZoneLbl) ? label.get_y(l0ZoneLbl) : na
    float _y1 = not na(l1ZoneLbl) ? label.get_y(l1ZoneLbl) : na
    float _y3 = not na(l3ZoneLbl) ? label.get_y(l3ZoneLbl) : na

    // L0 vs L2
    if not na(_y2) and not na(_y0) and math.abs(_y2 - _y0) < _stackGap
        _y0 := _y0 < _y2 ? _y2 - _stackGap : _y2 + _stackGap
        label.set_xy(l0ZoneLbl, label.get_x(l0ZoneLbl), _y0)

    // L1 vs L0
    if not na(_y0) and not na(_y1) and math.abs(_y0 - _y1) < _stackGap
        _y1 := _y1 < _y0 ? _y0 - _stackGap : _y0 + _stackGap
        label.set_xy(l1ZoneLbl, label.get_x(l1ZoneLbl), _y1)

    // L3 vs L1
    if not na(_y1) and not na(_y3) and math.abs(_y1 - _y3) < _stackGap
        _y3 := _y3 < _y1 ? _y1 - _stackGap : _y1 + _stackGap
        label.set_xy(l3ZoneLbl, label.get_x(l3ZoneLbl), _y3)

    // L3 vs L2 (in case L1 nudge pushed L3 back into L2's space)
    if not na(_y2) and not na(_y3) and math.abs(_y2 - _y3) < _stackGap
        _y3 := _y3 < _y2 ? _y2 - _stackGap : _y2 + _stackGap
        label.set_xy(l3ZoneLbl, label.get_x(l3ZoneLbl), _y3)

// ════════════════════════════════════════════════════════════════════════════
// PHASE 1-E  DOMINANT WAVE VISIBILITY
// Drawn ON the dominant structure's zone — not in a detached location.
// Uses existing dominantWaveLevel (from l0/l1/l2/l3 dominance engine).
// No new dominance calculations.
// ════════════════════════════════════════════════════════════════════════════
if showDominantTag and barstate.islast

    // Determine which structure's midpoint to anchor the tag to
    color _domCol  =
         dominantWaveLevel == "L2 HTF"    ? trace_L2_col :
         dominantWaveLevel == "L1 CHILD"    ? trace_L1_col :
         dominantWaveLevel == "L0 PRIMARY" ? trace_L0_col : trace_L3_col

    // Anchor price: mid of the dominant structure's zone
    float _domMid =
         dominantWaveLevel == "L2 HTF"     and not na(l2_zoneHigh) and not na(l2_zoneLow) ?
              f_mid(l2_zoneHigh, l2_zoneLow) :
         dominantWaveLevel == "L1 CHILD"     and not na(l1_zoneHigh) and not na(l1_zoneLow) ?
              f_mid(l1_zoneHigh, l1_zoneLow) :
         dominantWaveLevel == "L0 PRIMARY" and not na(point4OriginHigh) and not na(point4OriginLow) ?
              f_mid(point4OriginHigh, point4OriginLow) :
         not na(l3_zoneHigh) and not na(l3_zoneLow) ?
              f_mid(l3_zoneHigh, l3_zoneLow) : close

    // Anchor bar: right edge of the dominant structure
    int _domBar = bar_index

    string _domTxt = "DOMINANT WAVE\n" + dominantWaveLevel

    if na(dominantLabel)
        dominantLabel := label.new(_domBar, _domMid, _domTxt,
             style=label.style_label_left,
             color=color.new(#10103a, 5),
             textcolor=_domCol, size=size.normal, textalign=text.align_left)
    else
        label.set_xy       (dominantLabel, _domBar, _domMid)
        label.set_text     (dominantLabel, _domTxt)
        label.set_textcolor(dominantLabel, _domCol)


// ════════════════════════════════════════════════════════════════════════════
// SECTION 17 — FUTURE RETURN ZONE ENGINE (FRZ)  [Phase 2]
// Identifies price areas of highest interaction probability BEFORE the return.
// Uses ONLY existing detection variables — no new physics calculations.
//
// Qualification scoring — each component adds 25 points (max 100):
//   Req 1 — FU Candle        : isBullFU_prev / isBearFU_prev (gap-confirmed)
//                              OR isBullFU / isBearFU (same-bar)
//   Req 2 — Imbalance / FVG  : displacement > dispThresh  (void/gap proxy)
//   Req 3 — Liquidity Cleared: liqSweepBull / liqSweepBear / liqVacuum
//                              OR obs_LiquidityScore > 55
//   Req 4 — Displacement     : bullImpulse or bearImpulse
//
// Classification: 0-25 Weak | 26-50 Moderate | 51-75 Strong | 76-100 Exceptional
//
// Section 18 Validation: reject zones where resting liquidity is present
// (liqHeat > 60) AND no sweep has occurred — approve only clean launches.
//
// Spawn guard: one FRZ per bar maximum; dedup by zone overlap with existing zones.
// Lifecycle: Open → Partial (price touched) → Mitigated (full close-inside)
//            → Invalidated (price blew through from wrong side).
// ════════════════════════════════════════════════════════════════════════════

// ── FRZ-0: OWNER LAYER MAPPING (Section 19) ──────────────────────────────────
// Determine which wave layer is currently dominant — this becomes the creator tag.
// Uses existing dominantWaveLevel variable (no new logic).
string frz_ownerLayer =
     dominantWaveLevel == "L2 HTF"    ? "L2 HTF"    :
     dominantWaveLevel == "L1 CHILD"  ? "L1 CHILD"  :
     dominantWaveLevel == "L0 PRIMARY"? "L0 PRIMARY" : "L3 MICRO"

// ── FRZ-1: PER-BAR COMPONENT DETECTION ───────────────────────────────────────

// Req 1 — FU candle (gap-confirmed prior bar preferred; same-bar fallback)
bool frz_hasFU_gc   = isBullFU_prev or isBearFU_prev          // gap-confirmed (highest conviction)
bool frz_hasFU_sb   = isBullFU      or isBearFU               // same-bar (lower conviction)
bool frz_hasFU      = frz_hasFU_gc  or frz_hasFU_sb
int  frz_scoreFU    = frz_hasFU ? 25 : 0

// Directional hint from FU type
bool frz_fuIsBull   = isBullFU_prev or isBullFU
bool frz_fuIsBear   = isBearFU_prev or isBearFU

// Req 2 — Imbalance / FVG / displacement void
// Uses existing displacement variable — values > dispThresh confirm a price void
bool frz_hasImbalance = displacement > dispThresh
int  frz_scoreIMB     = frz_hasImbalance ? 25 : 0

// Req 3 — Liquidity cleared BEFORE the launch
bool frz_hasLiqClear = liqSweepBull or liqSweepBear or liqVacuum or
                       (obs_LiquidityScore > 55.0)
int  frz_scoreLIQ    = frz_hasLiqClear ? 25 : 0

// Req 4 — Displacement impulse (velocity + efficiency + expansion)
bool frz_hasDisp  = bullImpulse or bearImpulse
int  frz_scoreDisp = frz_hasDisp ? 25 : 0

// Raw score 0-100
int frz_rawScore = frz_scoreFU + frz_scoreIMB + frz_scoreLIQ + frz_scoreDisp

// ── FRZ-2: SECTION 18 — LIQUIDITY-FREE VALIDATION ────────────────────────────
// Reject if resting liquidity sits ahead and has NOT been swept yet.
bool frz_liqResting = liqHeat > 60 and not (liqSweepBull or liqSweepBear)
bool frz_approved   = not frz_liqResting

// ── FRZ-3: CLASSIFICATION & TIER STRINGS ─────────────────────────────────────
string frz_class =
     frz_rawScore >= 76 ? "Exceptional" :
     frz_rawScore >= 51 ? "Strong"      :
     frz_rawScore >= 26 ? "Moderate"    : "Weak"

string frz_tier =
     frz_rawScore >= 76                          ? "T1" :
     frz_rawScore >= 51                          ? "T2" :
     frz_rawScore >= 26 and frz_hasFU           ? "T3" :
     frz_rawScore >= 26 and frz_hasImbalance     ? "T4" : "–"

string frz_tierFull =
     frz_rawScore >= 76                          ? "Tier 1 ★★★" :
     frz_rawScore >= 51                          ? "Tier 2 ★★"  :
     frz_rawScore >= 26 and frz_hasFU           ? "Tier 3 ★"   :
     frz_rawScore >= 26 and frz_hasImbalance     ? "Tier 4"     : "–"

string frz_compStr =
     frz_hasFU and frz_hasImbalance and frz_hasLiqClear and frz_hasDisp ? "FU+IMB+LS+DISP" :
     frz_hasFU and frz_hasImbalance and frz_hasLiqClear                  ? "FU+IMB+LS"      :
     frz_hasFU and frz_hasImbalance and frz_hasDisp                      ? "FU+IMB+DISP"    :
     frz_hasFU and frz_hasImbalance                                       ? "FU+IMB"         :
     frz_hasFU and frz_hasLiqClear                                        ? "FU+LS"          :
     frz_hasFU                                                             ? "FU"             :
     frz_hasImbalance and frz_hasLiqClear                                 ? "IMB+LS"         :
     frz_hasImbalance                                                      ? "IMB"            : "–"

// ── FRZ-4: PERSISTENT ZONE STORAGE ───────────────────────────────────────────
// Arrays hold all live FRZs. Index 0 = oldest.

var array<float>  frz_topArr    = array.new_float ()
var array<float>  frz_botArr    = array.new_float ()
var array<int>    frz_barArr    = array.new_int   ()
var array<int>    frz_dirArr    = array.new_int   ()    // 1=bull demand, -1=bear supply
var array<int>    frz_scoreArr  = array.new_int   ()
var array<string> frz_classArr  = array.new_string()
var array<string> frz_tierArr   = array.new_string()
var array<string> frz_tierFArr  = array.new_string()    // full tier string
var array<string> frz_compArr   = array.new_string()
var array<string> frz_ownerArr  = array.new_string()    // Section 19: creator layer
var array<string> frz_statusArr = array.new_string()    // Open / Partial / Mitigated / Invalidated
var array<int>    frz_idxArr    = array.new_int   ()    // sequential FRZ number (display)
var array<box>    frz_boxArr    = array.new<box>  ()
var array<label>  frz_lblArr    = array.new<label>()

var int frz_totalSpawned = 0   // running counter for FRZ #N label

// Helper: FRZ removal (removes entry at index from all FRZ arrays)
f_frzRemove(int idx) =>
    array.remove(frz_topArr, idx)
    array.remove(frz_botArr, idx)
    array.remove(frz_barArr, idx)
    array.remove(frz_dirArr, idx)
    array.remove(frz_scoreArr, idx)
    array.remove(frz_classArr, idx)
    array.remove(frz_tierArr, idx)
    array.remove(frz_tierFArr, idx)
    array.remove(frz_compArr, idx)
    array.remove(frz_ownerArr, idx)
    array.remove(frz_statusArr, idx)
    array.remove(frz_idxArr, idx)
    array.remove(frz_boxArr, idx)
    array.remove(frz_lblArr, idx)

// ── FRZ-5: SPAWN GUARD & DEDUPLICATION ───────────────────────────────────────
// Gate: score >= min threshold, approved by Section 18, at least one primary
// signal present, active wave exists, and score > 0 (i.e. not a blank bar).
// Dedup: do not spawn if an existing live zone overlaps this candle's range.

// Determine zone direction from existing wave + FU signals
bool _frz_isBullSetup = direction == 1 or frz_fuIsBull
bool _frz_isBearSetup = direction == -1 or frz_fuIsBear
int  _frz_spawnDir = _frz_isBullSetup and not _frz_isBearSetup ? 1 : _frz_isBearSetup and not _frz_isBullSetup ? -1 : direction != 0 ? direction : 0

// Zone boundaries: use the triggering candle's range
// Bull demand FRZ → zone = low to close (demand left behind below the launch)
// Bear supply FRZ → zone = close to high (supply left behind above the launch)
float _frz_zTop = _frz_spawnDir == 1 ? math.max(open, close) : high
float _frz_zBot = _frz_spawnDir == 1 ? low                   : math.min(open, close)

// Gap-confirmed FU override: use the FU candle's range (one bar ago)
if frz_hasFU_gc
    _frz_zTop := _frz_spawnDir == 1 ? high[1] : math.max(open[1], close[1])
    _frz_zBot := _frz_spawnDir == 1 ? math.min(open[1], close[1]) : low[1]

// Ensure top > bot (safety guard)
if _frz_zTop <= _frz_zBot
    _frz_zTop := math.max(open, close, high)
    _frz_zBot := math.min(open, close, low)

// Check overlap with existing zones to avoid stacking identical zones
bool _frz_overlaps = false
int  _frzExist = array.size(frz_topArr)
if _frzExist > 0
    for _oi = 0 to _frzExist - 1
        if _oi < array.size(frz_topArr)
            float _ot = array.get(frz_topArr, _oi)
            float _ob = array.get(frz_botArr, _oi)
            // Overlap: zones share > 50% of their combined range
            float _overlapHi = math.min(_frz_zTop, _ot)
            float _overlapLo = math.max(_frz_zBot, _ob)
            float _overlap   = math.max(0.0, _overlapHi - _overlapLo)
            float _thisRange = math.max(_frz_zTop - _frz_zBot, 1e-10)
            if _overlap / _thisRange > 0.5
                _frz_overlaps := true
                break

bool frz_spawn = showFRZ                           and
                 frz_approved                       and
                 frz_rawScore >= frz_minScore       and
                 frz_rawScore > 0                   and
                 (frz_hasFU or frz_hasImbalance)    and
                 _frz_spawnDir != 0                 and
                 not _frz_overlaps

if frz_spawn
    frz_totalSpawned := frz_totalSpawned + 1

    // Color by direction and tier
    color _frzBg =
         frz_rawScore >= 76 ? color.new(_frz_spawnDir == 1 ? #00ffcc : #ff2244, 80) :
         frz_rawScore >= 51 ? color.new(_frz_spawnDir == 1 ? color.teal : color.red, 84) :
                              color.new(_frz_spawnDir == 1 ? color.teal : color.red, 90)
    color _frzBorder =
         frz_rawScore >= 76 ? color.new(_frz_spawnDir == 1 ? #00ffcc : #ff2244, 10) :
         frz_rawScore >= 51 ? color.new(_frz_spawnDir == 1 ? color.teal : color.red, 35) :
                              color.new(_frz_spawnDir == 1 ? color.teal : color.red, 55)
    int _frzBW = frz_rawScore >= 76 ? 2 : 1

    box _frzBox = box.new(
         left         = bar_index,
         top          = _frz_zTop,
         bottom       = _frz_zBot,
         right        = bar_index + frz_maxBarsActive,
         bgcolor      = _frzBg,
         border_color = _frzBorder,
         border_width = _frzBW,
         border_style = line.style_dashed)

    array.push(frz_boxArr,   _frzBox)
    array.push(frz_topArr,   _frz_zTop)
    array.push(frz_botArr,   _frz_zBot)
    array.push(frz_barArr,   bar_index)
    array.push(frz_dirArr,   _frz_spawnDir)
    array.push(frz_scoreArr, frz_rawScore)
    array.push(frz_classArr, frz_class)
    array.push(frz_tierArr,  frz_tier)
    array.push(frz_tierFArr, frz_tierFull)
    array.push(frz_compArr,  frz_compStr)
    array.push(frz_ownerArr, frz_ownerLayer)     // Section 19: creator
    array.push(frz_statusArr,"Open")
    array.push(frz_idxArr,   frz_totalSpawned)

    // ── FRZ label — spec format: "FRZ #N\nScore%\nClass\nTier\nComponents\nCreated By\nOwner" ──
    if showFRZ_Labels
        string _frzLblTxt =
             "FRZ #" + str.tostring(frz_totalSpawned) + "\n" +
             str.tostring(frz_rawScore) + "%  " + frz_class + "\n" +
             frz_tierFull + "\n" +
             frz_compStr + "\n" +
             "Created By\n" + frz_ownerLayer
        label _frzLbl = label.new(
             x         = bar_index,
             y         = _frz_spawnDir == 1 ? _frz_zBot - atr * 0.5 : _frz_zTop + atr * 0.5,
             text      = _frzLblTxt,
             style     = _frz_spawnDir == 1 ? label.style_label_up : label.style_label_down,
             color     = color.new(_frz_spawnDir == 1 ? #00ffcc : #ff2244, 12),
             textcolor = _frz_spawnDir == 1 ? color.black : color.white,
             size      = frz_rawScore >= 76 ? size.small : size.tiny,
             textalign = text.align_left)
        array.push(frz_lblArr, _frzLbl)
    else
        array.push(frz_lblArr, na)

// ── FRZ-6: LIFECYCLE ENGINE ───────────────────────────────────────────────────
// Status transitions:
//   Open       → Partial      (price wicked into zone but close was outside)
//   Open/Partial→ Mitigated   (close inside zone)
//   Open/Partial→ Invalidated (price closed through zone from wrong side)
// Expired zones (age >= frz_maxBarsActive) are also removed.

int _frzN = array.size(frz_topArr)
if _frzN > 0
    for _fi = _frzN - 1 to 0
        if _fi < array.size(frz_topArr)
            float  _ft  = array.get(frz_topArr,   _fi)
            float  _fb  = array.get(frz_botArr,   _fi)
            int    _fbb = array.get(frz_barArr,   _fi)
            int    _fd  = array.get(frz_dirArr,   _fi)
            string _fst = array.get(frz_statusArr,_fi)
            box    _bx  = array.get(frz_boxArr,   _fi)
            int    _age = bar_index - _fbb

            // Skip already-terminal zones waiting for removal
            bool _terminal = _fst == "Mitigated" or _fst == "Invalidated"

            if not _terminal
                // Partial: wick entered zone but close stayed outside
                bool _wickIn  = low  <= _ft and high >= _fb
                bool _closeIn = close >= _fb and close <= _ft

                // Invalidated: bull zone closed BELOW bot, or bear zone closed ABOVE top
                bool _invalid = (_fd == 1 and close < _fb - atr * 0.1) or (_fd == -1 and close > _ft + atr * 0.1)

                string _newStatus = _fst
                if _closeIn
                    _newStatus := "Mitigated"
                else if _invalid
                    _newStatus := "Invalidated"
                else if _wickIn and _fst == "Open"
                    _newStatus := "Partial"

                if _newStatus != _fst
                    array.set(frz_statusArr, _fi, _newStatus)
                    // Update box visual on status change
                    if not na(_bx)
                        color _stCol =
                             _newStatus == "Partial"     ? color.new(color.yellow, 82) :
                             _newStatus == "Mitigated"   ? color.new(color.gray,   88) :
                                                           color.new(color.purple,  88)
                        box.set_bgcolor(_bx, _stCol)
                        box.set_border_color(_bx, color.new(color.gray, 50))

// Extend right edge while zone is still Open or Partial
                if not na(_bx) and showFRZ and (_newStatus == "Open" or _newStatus == "Partial")
                    box.set_right(_bx, bar_index + 10)

            // Remove terminal or expired zones
            bool _remove = _terminal or _age >= frz_maxBarsActive
            if _remove
                box   _bx2 = array.get(frz_boxArr, _fi)
                label _lb2 = array.get(frz_lblArr, _fi)
                if not na(_bx2)
                    box.delete(_bx2)
                if not na(_lb2)
                    label.delete(_lb2)
                f_frzRemove(_fi)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 19 — FRZ OWNERSHIP ENGINE  [Phase 2]
// Every FRZ permanently records which wave layer created it (stored above at
// spawn time in frz_ownerArr). The label already shows "Created By / L# LAYER".
// This section derives the live summary statistics used by Section 20.
// No new arrays needed — ownership is already in frz_ownerArr.
// ════════════════════════════════════════════════════════════════════════════

// Tally live zone counts per owner layer (for Section 20 dashboard header)
int frz_ownL0 = 0
int frz_ownL1 = 0
int frz_ownL2 = 0
int frz_ownL3 = 0
int frz_activeCount = 0
int frz_bullCount   = 0
int frz_bearCount   = 0

// Best-zone summary variables
int    frz_bestScore  = 0
string frz_bestClass  = "–"
string frz_bestTier   = "–"
string frz_bestComp   = "–"
string frz_bestOwner  = "–"
string frz_bestStatus = "–"

int _frzN3 = array.size(frz_scoreArr)
if _frzN3 > 0
    for _fk = 0 to _frzN3 - 1
        if _fk < array.size(frz_scoreArr)
            string _own = array.get(frz_ownerArr,  _fk)
            string _st  = array.get(frz_statusArr, _fk)
            int    _sc  = array.get(frz_scoreArr,  _fk)
            int    _fd2 = array.get(frz_dirArr,    _fk)
            bool   _live = _st == "Open" or _st == "Partial"

            if _live
                frz_activeCount := frz_activeCount + 1
                if _fd2 == 1
                    frz_bullCount := frz_bullCount + 1
                else
                    frz_bearCount := frz_bearCount + 1

                if _own == "L0 PRIMARY"
                    frz_ownL0 := frz_ownL0 + 1
                else if _own == "L1 CHILD"
                    frz_ownL1 := frz_ownL1 + 1
                else if _own == "L2 HTF"
                    frz_ownL2 := frz_ownL2 + 1
                else
                    frz_ownL3 := frz_ownL3 + 1

                if _sc > frz_bestScore
                    frz_bestScore  := _sc
                    frz_bestClass  := array.get(frz_classArr,  _fk)
                    frz_bestTier   := array.get(frz_tierFArr,  _fk)
                    frz_bestComp   := array.get(frz_compArr,   _fk)
                    frz_bestOwner  := _own
                    frz_bestStatus := _st



// ═══════════════
// V72 — PERSISTENT STATE + FUNCTION DEFINITIONS
// ═══════════════
var int    frz_bestIdx      = -1
var int    ne_narrativeAge  = 0
var string ne_prevNarrative = "No Clear Narrative"
// ═══════════════

f_v72FindBestIdx(int _bestScore, int _arrSize) =>
    int _r = -1
    if _arrSize > 0
        for _i = 0 to _arrSize - 1
            if _i < array.size(frz_scoreArr) and array.get(frz_scoreArr, _i) == _bestScore
                string _st = array.get(frz_statusArr, _i)
                if _st == "Open" or _st == "Partial"
                    _r := _i
                    break
    _r

f_v72ScanTE(int _dir) =>
    float _bp = na
    float _bs = 0.0
    int _sz = array.size(frz_topArr)
    if _sz > 0 and _dir != 0
        for _i = 0 to _sz - 1
            if _i < _sz
                int _d = array.get(frz_dirArr, _i)
                int _s = array.get(frz_scoreArr, _i)
                float _m = (array.get(frz_topArr, _i) + array.get(frz_botArr, _i)) / 2.0
                string _x = array.get(frz_statusArr, _i)
                bool _ok = (_x == "Open" or _x == "Partial") and _d == _dir and (_dir == 1 ? _m > close : _m < close)
                if _ok and _s > _bs
                    _bs := float(_s)
                    _bp := _m
    _bp

f_v72WrEvict() =>
    if array.size(wr_waveId) > 50
        array.shift(wr_waveId)
        array.shift(wr_parentWaveId)
        array.shift(wr_rootWaveId)
        array.shift(wr_birthBar)
        array.shift(wr_deathBar)
        array.shift(wr_spawnPhase)
        array.shift(wr_deathPhase)
        array.shift(wr_depth)

f_v72DwrEvict() =>
    if array.size(dwr_waveId) > 20
        array.shift(dwr_waveId)
        array.shift(dwr_parentWaveId)
        array.shift(dwr_rootWaveId)
        array.shift(dwr_startBar)
        array.shift(dwr_endBar)
        array.shift(dwr_energy)
        array.shift(dwr_resState)
        array.shift(dwr_entryCycle)
        array.shift(dwr_lineage)


f_v72CmdDash(string _a, string _b, string _n, bool _nc, float _c, string _tt,
             float _el, float _eh, string _tr, string _g, string _rl,
             float _t1, float _t2, float _st, float _rr,
             string _ph, float _pc, float _er, float _fd,
             string _rs, float _rp, float _mh, string _hs,
             bool _adv, string _ts, string _tc) =>
    var table cd = table.new(position.middle_right, 2, 24, bgcolor=color.new(#050520, 5), border_color=color.new(#00ccff, 30), border_width=1, frame_color=color.new(#00ccff, 15), frame_width=1)
    string _z = dashTextSize == "tiny" ? size.tiny : size.small
    int _r = 0
    table.cell(cd, 0, _r, "V72 CMD", text_color=#00ccff, bgcolor=color.new(#0a0a40, 0), text_size=_z)
    table.cell(cd, 1, _r, _a, text_color=_a == "Long" ? #00ff88 : _a == "Short" ? #ff1744 : color.gray, bgcolor=color.new(#0a0a40, 0), text_size=_z)
    _r += 1
    _r := f_cd(cd, _r, "Bias", _b, _b == "Strong Bullish" or _b == "Bullish" ? color.lime : _b == "Strong Bearish" or _b == "Bearish" ? color.red : color.gray)
    _r := f_cd(cd, _r, "Narr", _n, _nc ? color.yellow : color.white)
    _r := f_cd(cd, _r, "Conf", str.tostring(math.round(_c)) + "%", _c >= 70 ? color.lime : _c >= 50 ? color.yellow : color.red)
    _r := f_cd(cd, _r, "Type", _tt, color.white)
    _r := f_cd(cd, _r, "Entry", str.tostring(math.round(_el, 2)) + "-" + str.tostring(math.round(_eh, 2)), color.aqua)
    _r := f_cd(cd, _r, "Grade", _g, _g == "A+" ? #00ff88 : _g == "A" ? color.lime : _g == "B" ? color.yellow : color.orange)
    _r := f_cd(cd, _r, "Risk", _rl, _rl == "HIGH" ? color.red : _rl == "MEDIUM" ? color.yellow : color.lime)
    _r := f_cd(cd, _r, "TP1", not na(_t1) ? str.tostring(math.round(_t1, 2)) : "—", color.lime)
    _r := f_cd(cd, _r, "TP2", not na(_t2) ? str.tostring(math.round(_t2, 2)) : "—", color.lime)
    _r := f_cd(cd, _r, "Stop", not na(_st) ? str.tostring(math.round(_st, 2)) : "—", color.red)
    _r := f_cd(cd, _r, "R:R", not na(_rr) ? str.tostring(math.round(_rr, 1)) + ":1" : "—", _rr >= 2 ? color.lime : _rr >= 1.5 ? color.yellow : color.red)
    _r := f_cd(cd, _r, "Phase", _ph + " " + str.tostring(math.round(_pc)) + "%", color.white)
    _r := f_cd(cd, _r, "ERF", str.tostring(math.round(_er)) + "%", _er >= 60 ? color.lime : _er >= 45 ? color.yellow : color.red)
    _r := f_cd(cd, _r, "FRZ", not na(_fd) ? str.tostring(math.round(_fd, 1)) + "ATR" : "—", not na(_fd) and _fd < 1 ? color.lime : color.gray)
    _r := f_cd(cd, _r, "Rot", _rs + " " + str.tostring(math.round(_rp)) + "%", _rp >= 75 ? color.red : _rp >= 50 ? color.orange : color.lime)
    _r := f_cd(cd, _r, "HTF", _hs, _mh >= 70 ? color.lime : _mh >= 50 ? color.yellow : color.red)
    if _adv
        _r := f_cd(cd, _r, "Src", _ts, color.white)
        table.cell(cd, 0, _r, "Scr", text_color=color.gray, text_size=_z)
        table.cell(cd, 1, _r, _tc, text_color=color.white, text_size=_z)


// ═══════════════
// V72 — MAIN BODY (correct dependency order, minimal scope count)
// Order: FRZ↔ERF → TE → MCE → NE → TQE → DOE → DWR → Trace → Dashboard
// ═══════════════

// ── 1. FRZ↔ERF Unification ──────────────────────────────────────────────────
frz_bestIdx := f_v72FindBestIdx(frz_bestScore, _frzN3)
float frz_bestZoneTop = frz_bestIdx >= 0 and frz_bestIdx < array.size(frz_topArr) ? array.get(frz_topArr, frz_bestIdx) : na
float frz_bestZoneBot = frz_bestIdx >= 0 and frz_bestIdx < array.size(frz_botArr) ? array.get(frz_botArr, frz_bestIdx) : na
float frz_bestZoneMid = not na(frz_bestZoneTop) ? (frz_bestZoneTop + frz_bestZoneBot) / 2.0 : na
int   frz_bestZoneDir = frz_bestIdx >= 0 and frz_bestIdx < array.size(frz_dirArr) ? array.get(frz_dirArr, frz_bestIdx) : 0
float frz_distanceToZone = not na(frz_bestZoneMid) ? math.abs(close - frz_bestZoneMid) / math.max(atr, 1e-10) : na
float frz_residualEnergy = math.max(0.0, 100.0 - (re_resolutionState == "RESOLVED" ? 90.0 : re_resolutionState == "PARTIALLY RESOLVED" ? 50.0 + re_recursiveCompletionScore * 0.40 : 20.0 + ede_dissipationProgress * 0.30))
bool frz_attractorConvergence = frz_activeCount > 0 and not na(eae_primaryAttractorPrice) and not na(frz_bestZoneMid) and math.abs(eae_primaryAttractorPrice - frz_bestZoneMid) / math.max(atr, 1e-10) < frz_convergenceATR
bool frz_inProximity = frz_activeCount > 0 and not na(frz_bestZoneMid) and math.abs(close - frz_bestZoneMid) / math.max(atr, 1e-10) < frz_proximityATR
float frz_entryBonus = frz_inProximity and frz_bestZoneDir == direction ? 15.0 : 0.0

// ── 2. Target Engine ─────────────────────────────────────────────────────────
te_tp1 := nz(f_v72ScanTE(direction), na)
te_tp2 := not na(eae_primaryAttractorPrice) and (direction == 1 ? eae_primaryAttractorPrice > close : direction == -1 ? eae_primaryAttractorPrice < close : false) ? eae_primaryAttractorPrice : na
te_tp3 := not na(eae_primaryAttractorPrice) ? (direction == 1 ? eae_primaryAttractorPrice + atr * 2.0 : direction == -1 ? eae_primaryAttractorPrice - atr * 2.0 : na) : na
te_rr_tp1 := not na(te_tp1) and not na(inv_riskInPts) and inv_riskInPts > 0 ? math.abs(te_tp1 - close) / inv_riskInPts : na
te_rr_tp2 := not na(te_tp2) and not na(inv_riskInPts) and inv_riskInPts > 0 ? math.abs(te_tp2 - close) / inv_riskInPts : na
te_rr_tp3 := not na(te_tp3) and not na(inv_riskInPts) and inv_riskInPts > 0 ? math.abs(te_tp3 - close) / inv_riskInPts : na
te_rrGate := not na(te_rr_tp1) ? te_rr_tp1 >= rrMinimum : (not na(te_rr_tp2) ? te_rr_tp2 >= rrMinimum : true)

// ── 3. MCE Alignment ─────────────────────────────────────────────────────────
int _mce_ag = (dir_tf1 == direction ? 1 : 0) + (dir_tf2 == direction ? 1 : 0) + (dir_tf3 == direction ? 1 : 0) + (dir_tf4 == direction ? 1 : 0)
float mce_alignmentScore = direction != 0 ? float(_mce_ag) / 4.0 * 100.0 : 50.0
float mce_htfAlignmentScore = mce_weightMode == "HTF-Biased" ? (dir_tf4 == direction ? 50.0 : dir_tf4 == 0 ? 25.0 : 0.0) + (dir_tf3 == direction ? 30.0 : dir_tf3 == 0 ? 15.0 : 0.0) + (dir_tf2 == direction ? 20.0 : dir_tf2 == 0 ? 10.0 : 0.0) : mce_alignmentScore
string mce_htfAlignmentSummary = mce_htfAlignmentScore >= 80 and direction == 1 ? "HTF Bull" : mce_htfAlignmentScore >= 80 and direction == -1 ? "HTF Bear" : mce_htfAlignmentScore >= 60 and rot_transferProbability < 40 ? "HTF Intact" : mce_htfAlignmentScore < 40 ? "HTF Contest" : "HTF Dev"

// ── 4. Narrative Engine ──────────────────────────────────────────────────────
string ne_dominantNarrative = f_getNarrative(direction, mce_htfAlignmentScore, ie1a_currentPhase, rot_transferProbability, rot_state, re_resolutionState)
float ne_narrativeStrength = mce_alignmentScore * 0.40 + rot_controlStability * 0.30 + (re_resolutionState == "RESOLVED" ? 30.0 : re_resolutionState == "PARTIALLY RESOLVED" ? 15.0 : 0.0)
bool ne_narrativeConflict = ne_narrativeStrength < 40.0 and rot_transferProbability > 40
ne_narrativeAge := ne_dominantNarrative == ne_prevNarrative ? ne_narrativeAge + 1 : 0
ne_prevNarrative := ne_dominantNarrative

// ── 5. TQE ───────────────────────────────────────────────────────────────────
float tqe_frzQuality = frz_activeCount > 0 ? math.min(float(frz_bestScore) * 0.50 + (frz_bestTier == "Tier 1 ★★★" ? 40.0 : frz_bestTier == "Tier 2 ★★" ? 25.0 : 10.0) + (frz_bestStatus == "Open" ? 10.0 : 5.0), 100.0) : 0.0
float tqe_liqQuality = math.min(obs_LiquidityScore * 0.50 + (liqSweepBull or liqSweepBear ? 30.0 : 0.0) + (liqVacuum ? 20.0 : 0.0), 100.0)
float tqe_rawScore = math.min(ie1a_phaseConfidence * tqe_w_ie1a + erf_confidence * tqe_w_erf + tqe_frzQuality * tqe_w_frz + mce_htfAlignmentScore * tqe_w_mce + re_recursiveCompletionScore * tqe_w_re + tqe_liqQuality * tqe_w_liq + frz_entryBonus, 100.0)
string tqe_grade = tqe_rawScore >= tqe_gradeA_plus ? "A+" : tqe_rawScore >= tqe_gradeA ? "A" : tqe_rawScore >= tqe_gradeB ? "B" : tqe_rawScore >= tqe_gradeC ? "C" : "D"
string tqe_riskLevel = rot_transferProbability > 65 or re_resolutionState == "UNRESOLVED" ? "HIGH" : rot_transferProbability > 35 or tqe_rawScore < 60 ? "MEDIUM" : "LOW"

// ── 6. DOE ───────────────────────────────────────────────────────────────────
string doe_bias = f_getBias(direction, mce_htfAlignmentScore, rot_controlStability)
string doe_action = f_getAction(inv_invalidated, erf_entryGate, te_rrGate, ie1a_currentPhase, direction, rot_transferProbability, ne_dominantNarrative)
float doe_confidence = math.min(nz(modelConfidence, 50.0) * 0.40 + mce_alignmentScore * 0.25 + (frz_attractorConvergence ? 20.0 : tqe_frzQuality * 0.15) + ie1a_phaseConfidence * 0.20, frz_attractorConvergence ? float(doe_confCapConv) : float(doe_confCap))
string doe_tradeType = ne_dominantNarrative == "Bullish Continuation" or ne_dominantNarrative == "Bearish Continuation" ? "Continuation" : ne_dominantNarrative == "Bullish Pullback" or ne_dominantNarrative == "Bearish Pullback" ? "Pullback" : ne_dominantNarrative == "Bullish Rotation" or ne_dominantNarrative == "Bearish Rotation" ? "Rotation" : "Wait"
float doe_entryMid = frz_inProximity and frz_bestZoneDir == direction and not na(frz_bestZoneTop) ? (frz_bestZoneTop + frz_bestZoneBot) / 2.0 : ie1a_currentPhase == "Demand Return" and not na(point4OriginHigh) ? (point4OriginHigh + point4OriginLow) / 2.0 : close
float doe_entryHigh = doe_entryMid + atr * 0.30
float doe_entryLow = doe_entryMid - atr * 0.30
string doe_entryTrigger = frz_inProximity ? "Limit" : ie1a_currentPhase == "Demand Return" or ie1a_currentPhase == "Supply Return" ? "LimitOnRetest" : "Market"


// ── 7. DWR ───────────────────────────────────────────────────────────────────
bool dwr_shouldSpawn = (ede_state == 4 and ede_state[1] != 4) or (ede_state == 5 and ede_state[1] != 5)
if dwr_shouldSpawn and direction != 0
    int _did = dwr_nextId
    dwr_nextId := dwr_nextId + 1
    array.push(dwr_waveId, _did)
    array.push(dwr_parentWaveId, dwr_activeDeliveryId)
    array.push(dwr_rootWaveId, wr_activeRootId)
    array.push(dwr_startBar, bar_index)
    array.push(dwr_endBar, -1)
    array.push(dwr_energy, ede_expansionEnergy)
    array.push(dwr_resState, re_resolutionState)
    array.push(dwr_entryCycle, entryCycle)
    array.push(dwr_lineage, str.tostring(wr_activeRootId) + ">" + str.tostring(_did))
    dwr_activeDeliveryId := _did
    f_v72DwrEvict()

if dwr_activeDeliveryId > 0 and array.size(dwr_waveId) > 0
    int _di = array.indexof(dwr_waveId, dwr_activeDeliveryId)
    if _di >= 0
        array.set(dwr_resState, _di, re_resolutionState)
        if re_resolutionState == "RESOLVED"
            array.set(dwr_endBar, _di, bar_index)

// ── 8. Traceability ──────────────────────────────────────────────────────────
string trc_src = doe_action == "Long" ? "IE1A:DR|" + tqe_grade : doe_action == "Short" ? "IE1A:SR|" + tqe_grade : doe_action == "No Trade" ? "IE2:Inv" : "Wait|" + ie1a_currentPhase
string trc_scr = "IE:" + str.tostring(math.round(ie1a_phaseConfidence)) + " E:" + str.tostring(math.round(erf_confidence)) + " M:" + str.tostring(math.round(mce_htfAlignmentScore))

